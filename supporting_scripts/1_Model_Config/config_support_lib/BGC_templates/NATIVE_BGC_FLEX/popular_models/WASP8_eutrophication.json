{
    "_DESCRIPTION": "WASP8 Eutrophication Model - Advanced DO/Nutrients/Algae/Sediment Diagenesis",
    "_REFERENCE": "EPA WASP8 Documentation (Wool et al., 2020)",
    "_MODEL": "Water Quality Analysis Simulation Program Version 8",
    "_VERSION": "1.0",
    "_NOTES": "State-of-the-art eutrophication model with multiple algae groups and sediment diagenesis",
    "CHEMICAL_SPECIES": {
        "LIST": {
            "1": "DO",
            "2": "CBOD_fast",
            "3": "CBOD_slow",
            "4": "NH4",
            "5": "NO3",
            "6": "ON_labile",
            "7": "ON_refrac",
            "8": "PO4",
            "9": "OP_labile",
            "10": "OP_refrac",
            "11": "DIATOM",
            "12": "GREEN",
            "13": "CYANO",
            "14": "DSi",
            "15": "PSi",
            "16": "DOC",
            "17": "POC_labile",
            "18": "POC_refrac",
            "19": "SED_PON1",
            "20": "SED_PON2",
            "21": "SED_NH4"
        },
        "BGC_GENERAL_MOBILE_SPECIES": [
            "DO",
            "CBOD_fast",
            "CBOD_slow",
            "NH4",
            "NO3",
            "ON_labile",
            "ON_refrac",
            "PO4",
            "OP_labile",
            "OP_refrac",
            "DIATOM",
            "GREEN",
            "CYANO",
            "DSi",
            "PSi",
            "DOC",
            "POC_labile",
            "POC_refrac",
            "SED_PON1",
            "SED_PON2",
            "SED_NH4"
        ],
        "_LIST_DESCRIPTIONS": {
            "DO": "Dissolved oxygen",
            "CBOD_fast": "Fast-reacting CBOD (labile)",
            "CBOD_slow": "Slow-reacting CBOD (refractory)",
            "NH4": "Ammonia nitrogen",
            "NO3": "Nitrate nitrogen",
            "ON_labile": "Labile organic nitrogen",
            "ON_refrac": "Refractory organic nitrogen",
            "PO4": "Orthophosphate",
            "OP_labile": "Labile organic phosphorus",
            "OP_refrac": "Refractory organic phosphorus",
            "DIATOM": "Diatom biomass",
            "GREEN": "Green algae biomass",
            "CYANO": "Cyanobacteria biomass",
            "DSi": "Dissolved silica",
            "PSi": "Particulate biogenic silica",
            "DOC": "Dissolved organic carbon",
            "POC_labile": "Labile particulate organic carbon",
            "POC_refrac": "Refractory particulate organic carbon",
            "SED_PON1": "Sediment labile PON (layer 1)",
            "SED_PON2": "Sediment refractory PON (layer 2)",
            "SED_NH4": "Sediment porewater NH4"
        }
    },
    "CYCLING_FRAMEWORKS": {
        "WASP_DO_SYSTEM": {
            "_DESCRIPTION": "Dissolved oxygen dynamics",
            "LIST_TRANSFORMATIONS": {
                "1": "REAERATION",
                "2": "CBOD_FAST_OXIDATION",
                "3": "CBOD_FAST_O2",
                "4": "CBOD_SLOW_OXIDATION",
                "5": "NITRIFICATION_O2",
                "6": "SOD_FLUX"
            },
            "1": {
                "_NAME": "REAERATION",
                "CONSUMED": "NONE",
                "PRODUCED": "DO",
                "KINETICS": [
                    "Ka * (DOsat - DO)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "Ka",
                    "DOsat"
                ],
                "PARAMETER_VALUES": {
                    "Ka": 2.5,
                    "DOsat": 9.0
                },
                "_PARAMETERS_INFO": {
                    "Ka": {
                        "VALUE": 2.5,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.5,
                            15.0
                        ],
                        "DESCRIPTION": "Reaeration coefficient",
                        "TEMP_COEFF": 1.024
                    },
                    "DOsat": {
                        "VALUE": 9.0,
                        "UNITS": "mg/L",
                        "DESCRIPTION": "DO saturation (temp dependent)"
                    }
                }
            },
            "2": {
                "_NAME": "CBOD_FAST_OXIDATION",
                "CONSUMED": "CBOD_fast",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "Kd1 * CBOD_fast * (DO / (Ksod + DO))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "Kd1",
                    "Ksod"
                ],
                "PARAMETER_VALUES": {
                    "Kd1": 0.3,
                    "Ksod": 0.5
                },
                "_PARAMETERS_INFO": {
                    "Kd1": {
                        "VALUE": 0.3,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.1,
                            1.0
                        ],
                        "DESCRIPTION": "Fast CBOD decay rate",
                        "TEMP_COEFF": 1.047
                    },
                    "Ksod": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L",
                        "DESCRIPTION": "Half-sat DO for oxidation"
                    }
                }
            },
            "3": {
                "_NAME": "CBOD_FAST_O2",
                "CONSUMED": "DO",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "Kd1 * CBOD_fast * (DO / (Ksod + DO))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "Kd1",
                    "Ksod"
                ],
                "PARAMETER_VALUES": {
                    "Kd1": 0.3,
                    "Ksod": 0.5
                },
                "_PARAMETERS_INFO": {
                    "Kd1": {
                        "VALUE": 0.3,
                        "UNITS": "1/day"
                    },
                    "Ksod": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L"
                    }
                }
            },
            "4": {
                "_NAME": "CBOD_SLOW_OXIDATION",
                "CONSUMED": "CBOD_slow",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "Kd2 * CBOD_slow * (DO / (Ksod + DO))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "Kd2"
                ],
                "PARAMETER_VALUES": {
                    "Kd2": 0.03
                },
                "_PARAMETERS_INFO": {
                    "Kd2": {
                        "VALUE": 0.03,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.01,
                            0.1
                        ],
                        "DESCRIPTION": "Slow CBOD decay rate"
                    }
                }
            },
            "5": {
                "_NAME": "NITRIFICATION_O2",
                "CONSUMED": "DO",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "4.57 * Kn * NH4 * (DO / (Kno2 + DO))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "Kn",
                    "Kno2"
                ],
                "PARAMETER_VALUES": {
                    "Kn": 0.2,
                    "Kno2": 0.5
                },
                "_NOTES": "4.57 mg O2 per mg NH4-N oxidized",
                "_PARAMETERS_INFO": {
                    "Kn": {
                        "VALUE": 0.2,
                        "UNITS": "1/day"
                    },
                    "Kno2": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L"
                    }
                }
            },
            "6": {
                "_NAME": "SOD_FLUX",
                "CONSUMED": "DO",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "SOD * (DO / (Ksod2 + DO)) / depth",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "SOD",
                    "Ksod2",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "SOD": 2.0,
                    "Ksod2": 1.0,
                    "depth": 2.0
                },
                "_PARAMETERS_INFO": {
                    "SOD": {
                        "VALUE": 2.0,
                        "UNITS": "g O2/m2/day",
                        "RANGE": [
                            0.5,
                            10.0
                        ],
                        "DESCRIPTION": "Sediment oxygen demand"
                    },
                    "Ksod2": {
                        "VALUE": 1.0,
                        "UNITS": "mg/L"
                    },
                    "depth": {
                        "VALUE": 2.0,
                        "UNITS": "m"
                    }
                }
            }
        },
        "WASP_NITROGEN": {
            "_DESCRIPTION": "Nitrogen cycling",
            "LIST_TRANSFORMATIONS": {
                "1": "ON_LABILE_MINERALIZATION",
                "2": "ON_REFRAC_MINERALIZATION",
                "3": "NITRIFICATION",
                "4": "DENITRIFICATION",
                "5": "BENTHIC_NH4_FLUX"
            },
            "1": {
                "_NAME": "ON_LABILE_MINERALIZATION",
                "CONSUMED": "ON_labile",
                "PRODUCED": "NH4",
                "KINETICS": [
                    "K71 * ON_labile",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "K71"
                ],
                "PARAMETER_VALUES": {
                    "K71": 0.1
                },
                "_PARAMETERS_INFO": {
                    "K71": {
                        "VALUE": 0.1,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.02,
                            0.4
                        ],
                        "DESCRIPTION": "Labile ON mineralization rate",
                        "TEMP_COEFF": 1.08
                    }
                }
            },
            "2": {
                "_NAME": "ON_REFRAC_MINERALIZATION",
                "CONSUMED": "ON_refrac",
                "PRODUCED": "NH4",
                "KINETICS": [
                    "K72 * ON_refrac",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "K72"
                ],
                "PARAMETER_VALUES": {
                    "K72": 0.01
                },
                "_PARAMETERS_INFO": {
                    "K72": {
                        "VALUE": 0.01,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.001,
                            0.05
                        ],
                        "DESCRIPTION": "Refractory ON mineralization rate"
                    }
                }
            },
            "3": {
                "_NAME": "NITRIFICATION",
                "CONSUMED": "NH4",
                "PRODUCED": "NO3",
                "KINETICS": [
                    "Kn * NH4 * (DO / (Kno2 + DO))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "Kn",
                    "Kno2"
                ],
                "PARAMETER_VALUES": {
                    "Kn": 0.2,
                    "Kno2": 0.5
                },
                "_PARAMETERS_INFO": {
                    "Kn": {
                        "VALUE": 0.2,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.05,
                            1.0
                        ],
                        "DESCRIPTION": "Nitrification rate",
                        "TEMP_COEFF": 1.08
                    },
                    "Kno2": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L",
                        "DESCRIPTION": "Half-sat DO for nitrification"
                    }
                }
            },
            "4": {
                "_NAME": "DENITRIFICATION",
                "CONSUMED": "NO3",
                "PRODUCED": "N2_loss",
                "KINETICS": [
                    "Kdn * NO3 * (Kdno2 / (Kdno2 + DO))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "Kdn",
                    "Kdno2"
                ],
                "PARAMETER_VALUES": {
                    "Kdn": 0.1,
                    "Kdno2": 0.1
                },
                "_PARAMETERS_INFO": {
                    "Kdn": {
                        "VALUE": 0.1,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.02,
                            0.5
                        ],
                        "DESCRIPTION": "Denitrification rate",
                        "TEMP_COEFF": 1.07
                    },
                    "Kdno2": {
                        "VALUE": 0.1,
                        "UNITS": "mg/L",
                        "DESCRIPTION": "DO inhibition constant"
                    }
                }
            },
            "5": {
                "_NAME": "BENTHIC_NH4_FLUX",
                "CONSUMED": "NONE",
                "PRODUCED": "NH4",
                "KINETICS": [
                    "JNH4 * (Kdno2_sed / (Kdno2_sed + DO)) / depth",
                    "mg/day"
                ],
                "PARAMETER_NAMES": [
                    "JNH4",
                    "Kdno2_sed",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "JNH4": 10.0,
                    "Kdno2_sed": 2.0,
                    "depth": 2.0
                },
                "_PARAMETERS_INFO": {
                    "JNH4": {
                        "VALUE": 10.0,
                        "UNITS": "mg N/m2/day",
                        "RANGE": [
                            1.0,
                            100.0
                        ],
                        "DESCRIPTION": "Sediment NH4 flux"
                    },
                    "Kdno2_sed": {
                        "VALUE": 2.0,
                        "UNITS": "mg/L"
                    },
                    "depth": {
                        "VALUE": 2.0,
                        "UNITS": "m"
                    }
                }
            }
        },
        "WASP_PHOSPHORUS": {
            "_DESCRIPTION": "Phosphorus cycling",
            "LIST_TRANSFORMATIONS": {
                "1": "OP_LABILE_MINERALIZATION",
                "2": "OP_REFRAC_MINERALIZATION",
                "3": "BENTHIC_PO4_FLUX"
            },
            "1": {
                "_NAME": "OP_LABILE_MINERALIZATION",
                "CONSUMED": "OP_labile",
                "PRODUCED": "PO4",
                "KINETICS": [
                    "K81 * OP_labile",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "K81"
                ],
                "PARAMETER_VALUES": {
                    "K81": 0.1
                },
                "_PARAMETERS_INFO": {
                    "K81": {
                        "VALUE": 0.1,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.02,
                            0.4
                        ],
                        "DESCRIPTION": "Labile OP mineralization rate",
                        "TEMP_COEFF": 1.08
                    }
                }
            },
            "2": {
                "_NAME": "OP_REFRAC_MINERALIZATION",
                "CONSUMED": "OP_refrac",
                "PRODUCED": "PO4",
                "KINETICS": [
                    "K82 * OP_refrac",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "K82"
                ],
                "PARAMETER_VALUES": {
                    "K82": 0.005
                },
                "_PARAMETERS_INFO": {
                    "K82": {
                        "VALUE": 0.005,
                        "UNITS": "1/day",
                        "DESCRIPTION": "Refractory OP mineralization rate"
                    }
                }
            },
            "3": {
                "_NAME": "BENTHIC_PO4_FLUX",
                "CONSUMED": "NONE",
                "PRODUCED": "PO4",
                "KINETICS": [
                    "JPO4 * (Kdp / (Kdp + DO)) / depth",
                    "mg/day"
                ],
                "PARAMETER_NAMES": [
                    "JPO4",
                    "Kdp",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "JPO4": 2.0,
                    "Kdp": 1.0,
                    "depth": 2.0
                },
                "_NOTES": "P release increases under anoxia",
                "_PARAMETERS_INFO": {
                    "JPO4": {
                        "VALUE": 2.0,
                        "UNITS": "mg P/m2/day",
                        "RANGE": [
                            0.5,
                            20.0
                        ],
                        "DESCRIPTION": "Sediment PO4 flux"
                    },
                    "Kdp": {
                        "VALUE": 1.0,
                        "UNITS": "mg/L",
                        "DESCRIPTION": "DO threshold for P release"
                    },
                    "depth": {
                        "VALUE": 2.0,
                        "UNITS": "m"
                    }
                }
            }
        },
        "WASP_PHYTOPLANKTON": {
            "_DESCRIPTION": "Multiple phytoplankton groups",
            "LIST_TRANSFORMATIONS": {
                "1": "DIATOM_GROWTH",
                "2": "DIATOM_RESPIRATION",
                "3": "GREEN_GROWTH",
                "4": "GREEN_RESPIRATION",
                "5": "CYANO_GROWTH",
                "6": "CYANO_RESPIRATION",
                "7": "ALGAE_O2_PRODUCTION",
                "8": "ALGAE_SETTLING"
            },
            "1": {
                "_NAME": "DIATOM_GROWTH",
                "CONSUMED": "NONE",
                "PRODUCED": "DIATOM",
                "KINETICS": [
                    "mu_max_D * DIATOM * f_L * f_N * f_P * f_Si * f_T",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "mu_max_D",
                    "f_L",
                    "f_N",
                    "f_P",
                    "f_Si",
                    "Ik",
                    "Kn",
                    "Kp",
                    "KSi"
                ],
                "PARAMETER_VALUES": {
                    "mu_max_D": 2.5,
                    "f_L": 0.0,
                    "f_N": 0.0,
                    "f_P": 0.0,
                    "f_Si": 0.0,
                    "Ik": 150,
                    "Kn": 0.025,
                    "Kp": 0.005,
                    "KSi": 0.1
                },
                "_PARAMETERS_INFO": {
                    "mu_max_D": {
                        "VALUE": 2.5,
                        "UNITS": "1/day",
                        "DESCRIPTION": "Max diatom growth rate"
                    },
                    "f_L": {
                        "FORMULA": "I / (Ik + I) * exp(1 - I/Ik)"
                    },
                    "f_N": {
                        "FORMULA": "min(NH4+NO3, DSi/rSiN) / (Kn + min(...))"
                    },
                    "f_P": {
                        "FORMULA": "PO4 / (Kp + PO4)"
                    },
                    "f_Si": {
                        "FORMULA": "DSi / (KSi + DSi)"
                    },
                    "Ik": {
                        "VALUE": 150,
                        "UNITS": "W/m2"
                    },
                    "Kn": {
                        "VALUE": 0.025,
                        "UNITS": "mg N/L"
                    },
                    "Kp": {
                        "VALUE": 0.005,
                        "UNITS": "mg P/L"
                    },
                    "KSi": {
                        "VALUE": 0.1,
                        "UNITS": "mg Si/L"
                    }
                }
            },
            "2": {
                "_NAME": "DIATOM_RESPIRATION",
                "CONSUMED": "DIATOM",
                "PRODUCED": "NH4",
                "KINETICS": [
                    "Kr_D * DIATOM * aNc",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "Kr_D",
                    "aNc"
                ],
                "PARAMETER_VALUES": {
                    "Kr_D": 0.1,
                    "aNc": 0.16
                },
                "_PARAMETERS_INFO": {
                    "Kr_D": {
                        "VALUE": 0.1,
                        "UNITS": "1/day",
                        "DESCRIPTION": "Diatom respiration rate"
                    },
                    "aNc": {
                        "VALUE": 0.16,
                        "UNITS": "mg N/mg C",
                        "DESCRIPTION": "N:C ratio in algae"
                    }
                }
            },
            "3": {
                "_NAME": "GREEN_GROWTH",
                "CONSUMED": "NONE",
                "PRODUCED": "GREEN",
                "KINETICS": [
                    "mu_max_G * GREEN * f_L * f_N * f_P * f_T",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "mu_max_G"
                ],
                "PARAMETER_VALUES": {
                    "mu_max_G": 2.0
                },
                "_PARAMETERS_INFO": {
                    "mu_max_G": {
                        "VALUE": 2.0,
                        "UNITS": "1/day",
                        "DESCRIPTION": "Max green algae growth rate"
                    }
                }
            },
            "4": {
                "_NAME": "GREEN_RESPIRATION",
                "CONSUMED": "GREEN",
                "PRODUCED": "NH4",
                "KINETICS": [
                    "Kr_G * GREEN * aNc",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "Kr_G",
                    "aNc"
                ],
                "PARAMETER_VALUES": {
                    "Kr_G": 0.1,
                    "aNc": 0.16
                },
                "_PARAMETERS_INFO": {
                    "Kr_G": {
                        "VALUE": 0.1,
                        "UNITS": "1/day"
                    },
                    "aNc": {
                        "VALUE": 0.16,
                        "UNITS": "mg N/mg C"
                    }
                }
            },
            "5": {
                "_NAME": "CYANO_GROWTH",
                "CONSUMED": "NONE",
                "PRODUCED": "CYANO",
                "KINETICS": [
                    "mu_max_C * CYANO * f_L * f_N_fix * f_P * f_T",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "mu_max_C",
                    "f_N_fix"
                ],
                "PARAMETER_VALUES": {
                    "mu_max_C": 1.0,
                    "f_N_fix": 1.0
                },
                "_NOTES": "Cyanobacteria can fix N2 when N is limiting",
                "_PARAMETERS_INFO": {
                    "mu_max_C": {
                        "VALUE": 1.0,
                        "UNITS": "1/day",
                        "DESCRIPTION": "Max cyanobacteria growth rate"
                    },
                    "f_N_fix": {
                        "VALUE": 1.0,
                        "DESCRIPTION": "Can fix N when NO3 is limiting"
                    }
                }
            },
            "6": {
                "_NAME": "CYANO_RESPIRATION",
                "CONSUMED": "CYANO",
                "PRODUCED": "NH4",
                "KINETICS": [
                    "Kr_C * CYANO * aNc",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "Kr_C",
                    "aNc"
                ],
                "PARAMETER_VALUES": {
                    "Kr_C": 0.08,
                    "aNc": 0.16
                },
                "_PARAMETERS_INFO": {
                    "Kr_C": {
                        "VALUE": 0.08,
                        "UNITS": "1/day"
                    },
                    "aNc": {
                        "VALUE": 0.16,
                        "UNITS": "mg N/mg C"
                    }
                }
            },
            "7": {
                "_NAME": "ALGAE_O2_PRODUCTION",
                "CONSUMED": "NONE",
                "PRODUCED": "DO",
                "KINETICS": [
                    "(mu_D * DIATOM + mu_G * GREEN + mu_C * CYANO) * aOc * PQ",
                    "1"
                ],
                "PARAMETER_NAMES": [
                    "aOc",
                    "PQ"
                ],
                "PARAMETER_VALUES": {
                    "aOc": 2.67,
                    "PQ": 1.0
                },
                "_PARAMETERS_INFO": {
                    "aOc": {
                        "VALUE": 2.67,
                        "UNITS": "mg O2/mg C",
                        "DESCRIPTION": "O2:C ratio photosynthesis"
                    },
                    "PQ": {
                        "VALUE": 1.0,
                        "DESCRIPTION": "Photosynthetic quotient"
                    }
                }
            },
            "8": {
                "_NAME": "ALGAE_SETTLING",
                "CONSUMED": "DIATOM",
                "PRODUCED": "POC_labile",
                "KINETICS": [
                    "vs_D / depth * DIATOM",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "vs_D",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "vs_D": 0.5,
                    "depth": 5.0
                },
                "_PARAMETERS_INFO": {
                    "vs_D": {
                        "VALUE": 0.5,
                        "UNITS": "m/day",
                        "DESCRIPTION": "Diatom settling velocity"
                    },
                    "depth": {
                        "VALUE": 5.0,
                        "UNITS": "m"
                    }
                }
            }
        },
        "WASP_SILICA": {
            "_DESCRIPTION": "Silica cycling for diatoms",
            "LIST_TRANSFORMATIONS": {
                "1": "SI_UPTAKE",
                "2": "PSI_DISSOLUTION",
                "3": "BENTHIC_SI_FLUX"
            },
            "1": {
                "_NAME": "SI_UPTAKE",
                "CONSUMED": "DSi",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "mu_D * DIATOM * aSic",
                    "1"
                ],
                "PARAMETER_NAMES": [
                    "aSic"
                ],
                "PARAMETER_VALUES": {
