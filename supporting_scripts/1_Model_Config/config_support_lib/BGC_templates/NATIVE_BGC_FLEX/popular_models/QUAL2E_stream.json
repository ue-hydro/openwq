{
    "_DESCRIPTION": "QUAL2E Stream Water Quality Model",
    "_REFERENCE": "Brown & Barnwell (1987) QUAL2E Documentation",
    "_MODEL": "EPA QUAL2E Enhanced Stream Water Quality Model",
    "_VERSION": "1.0",
    "_NOTES": "Classic stream water quality model with DO-BOD, nutrients, and algae",
    "CHEMICAL_SPECIES": {
        "LIST": {
            "1": "DO",
            "2": "CBOD",
            "3": "ORG_N",
            "4": "NH4-N",
            "5": "NO2-N",
            "6": "NO3-N",
            "7": "ORG_P",
            "8": "DISS_P",
            "9": "ALGAE",
            "10": "FECAL_COLIFORM"
        },
        "BGC_GENERAL_MOBILE_SPECIES": [
            "DO",
            "CBOD",
            "ORG_N",
            "NH4-N",
            "NO2-N",
            "NO3-N",
            "ORG_P",
            "DISS_P",
            "ALGAE",
            "FECAL_COLIFORM"
        ],
        "_LIST_DESCRIPTIONS": {
            "DO": "Dissolved oxygen",
            "CBOD": "Carbonaceous biochemical oxygen demand",
            "ORG_N": "Organic nitrogen",
            "NH4-N": "Ammonia nitrogen",
            "NO2-N": "Nitrite nitrogen",
            "NO3-N": "Nitrate nitrogen",
            "ORG_P": "Organic phosphorus",
            "DISS_P": "Dissolved phosphorus (orthophosphate)",
            "ALGAE": "Algal biomass (chlorophyll-a proxy)",
            "FECAL_COLIFORM": "Fecal coliform bacteria"
        }
    },
    "CYCLING_FRAMEWORKS": {
        "QUAL2E_DO_BOD": {
            "_DESCRIPTION": "Dissolved oxygen and BOD dynamics",
            "LIST_TRANSFORMATIONS": {
                "1": "REAERATION",
                "2": "CBOD_OXIDATION",
                "3": "CBOD_O2_DEMAND",
                "4": "CBOD_SETTLING",
                "5": "SOD"
            },
            "1": {
                "_NAME": "REAERATION",
                "CONSUMED": "NONE",
                "PRODUCED": "DO",
                "KINETICS": [
                    "K2 * (DO_sat - DO)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "K2",
                    "DO_sat"
                ],
                "PARAMETER_VALUES": {
                    "K2": 3.0,
                    "DO_sat": 9.0
                },
                "_NOTES": "K2 can be calculated from O'Connor-Dobbins, Churchill, or Owens-Gibbs",
                "_PARAMETERS_INFO": {
                    "K2": {
                        "VALUE": 3.0,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.5,
                            20.0
                        ],
                        "DESCRIPTION": "Reaeration coefficient",
                        "TEMP_COEFF": 1.024
                    },
                    "DO_sat": {
                        "VALUE": 9.0,
                        "UNITS": "mg/L",
                        "DESCRIPTION": "DO saturation"
                    }
                }
            },
            "2": {
                "_NAME": "CBOD_OXIDATION",
                "CONSUMED": "CBOD",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "K1 * CBOD",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "K1"
                ],
                "PARAMETER_VALUES": {
                    "K1": 0.23
                },
                "_PARAMETERS_INFO": {
                    "K1": {
                        "VALUE": 0.23,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.1,
                            1.0
                        ],
                        "DESCRIPTION": "BOD deoxygenation rate",
                        "TEMP_COEFF": 1.047
                    }
                }
            },
            "3": {
                "_NAME": "CBOD_O2_DEMAND",
                "CONSUMED": "DO",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "K1 * CBOD",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "K1"
                ],
                "PARAMETER_VALUES": {
                    "K1": 0.23
                },
                "_PARAMETERS_INFO": {
                    "K1": {
                        "VALUE": 0.23,
                        "UNITS": "1/day"
                    }
                }
            },
            "4": {
                "_NAME": "CBOD_SETTLING",
                "CONSUMED": "CBOD",
                "PRODUCED": "SED_CBOD",
                "KINETICS": [
                    "K3 * CBOD",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "K3"
                ],
                "PARAMETER_VALUES": {
                    "K3": 0.1
                },
                "_PARAMETERS_INFO": {
                    "K3": {
                        "VALUE": 0.1,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.0,
                            0.5
                        ],
                        "DESCRIPTION": "BOD settling rate"
                    }
                }
            },
            "5": {
                "_NAME": "SOD",
                "CONSUMED": "DO",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "K4 / depth",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "K4",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "K4": 1.5,
                    "depth": 1.0
                },
                "_PARAMETERS_INFO": {
                    "K4": {
                        "VALUE": 1.5,
                        "UNITS": "g O2/m2/day",
                        "RANGE": [
                            0.5,
                            10.0
                        ],
                        "DESCRIPTION": "Sediment oxygen demand",
                        "TEMP_COEFF": 1.06
                    },
                    "depth": {
                        "VALUE": 1.0,
                        "UNITS": "m"
                    }
                }
            }
        },
        "QUAL2E_NITROGEN": {
            "_DESCRIPTION": "Nitrogen transformation cycle",
            "LIST_TRANSFORMATIONS": {
                "1": "ORG_N_SETTLING",
                "2": "ORG_N_HYDROLYSIS",
                "3": "NITRIFICATION_STEP1",
                "4": "NITRIFICATION_STEP2",
                "5": "NITRIFICATION_O2_STEP1",
                "6": "NITRIFICATION_O2_STEP2",
                "7": "BENTHIC_NH4-N"
            },
            "1": {
                "_NAME": "ORG_N_SETTLING",
                "CONSUMED": "ORG_N",
                "PRODUCED": "SED_N",
                "KINETICS": [
                    "sigma_4 * ORG_N",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "sigma_4"
                ],
                "PARAMETER_VALUES": {
                    "sigma_4": 0.3
                },
                "_PARAMETERS_INFO": {
                    "sigma_4": {
                        "VALUE": 0.3,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.0,
                            1.0
                        ],
                        "DESCRIPTION": "Organic N settling rate",
                        "TEMP_COEFF": 1.024
                    }
                }
            },
            "2": {
                "_NAME": "ORG_N_HYDROLYSIS",
                "CONSUMED": "ORG_N",
                "PRODUCED": "NH4-N",
                "KINETICS": [
                    "beta_1 * ORG_N",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "beta_1"
                ],
                "PARAMETER_VALUES": {
                    "beta_1": 0.2
                },
                "_PARAMETERS_INFO": {
                    "beta_1": {
                        "VALUE": 0.2,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.02,
                            0.5
                        ],
                        "DESCRIPTION": "Organic N hydrolysis rate",
                        "TEMP_COEFF": 1.047
                    }
                }
            },
            "3": {
                "_NAME": "NITRIFICATION_STEP1",
                "CONSUMED": "NH4-N",
                "PRODUCED": "NO2-N",
                "KINETICS": [
                    "beta_2 * NH4-N",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "beta_2"
                ],
                "PARAMETER_VALUES": {
                    "beta_2": 0.3
                },
                "_PARAMETERS_INFO": {
                    "beta_2": {
                        "VALUE": 0.3,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.1,
                            1.0
                        ],
                        "DESCRIPTION": "Ammonia oxidation rate",
                        "TEMP_COEFF": 1.083
                    }
                }
            },
            "4": {
                "_NAME": "NITRIFICATION_STEP2",
                "CONSUMED": "NO2-N",
                "PRODUCED": "NO3-N",
                "KINETICS": [
                    "beta_3 * NO2-N",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "beta_3"
                ],
                "PARAMETER_VALUES": {
                    "beta_3": 1.0
                },
                "_PARAMETERS_INFO": {
                    "beta_3": {
                        "VALUE": 1.0,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.2,
                            2.0
                        ],
                        "DESCRIPTION": "Nitrite oxidation rate",
                        "TEMP_COEFF": 1.047
                    }
                }
            },
            "5": {
                "_NAME": "NITRIFICATION_O2_STEP1",
                "CONSUMED": "DO",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "3.43 * beta_2 * NH4-N",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "beta_2"
                ],
                "PARAMETER_VALUES": {
                    "beta_2": 0.3
                },
                "_NOTES": "3.43 g O2 / g NH4-N-N oxidized to NO2-N",
                "_PARAMETERS_INFO": {
                    "beta_2": {
                        "VALUE": 0.3,
                        "UNITS": "1/day"
                    }
                }
            },
            "6": {
                "_NAME": "NITRIFICATION_O2_STEP2",
                "CONSUMED": "DO",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "1.14 * beta_3 * NO2-N",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "beta_3"
                ],
                "PARAMETER_VALUES": {
                    "beta_3": 1.0
                },
                "_NOTES": "1.14 g O2 / g NO2-N-N oxidized to NO3-N",
                "_PARAMETERS_INFO": {
                    "beta_3": {
                        "VALUE": 1.0,
                        "UNITS": "1/day"
                    }
                }
            },
            "7": {
                "_NAME": "BENTHIC_NH4-N",
                "CONSUMED": "NONE",
                "PRODUCED": "NH4-N",
                "KINETICS": [
                    "sigma_3 / depth",
                    "mg/day"
                ],
                "PARAMETER_NAMES": [
                    "sigma_3",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "sigma_3": 0.5,
                    "depth": 1.0
                },
                "_PARAMETERS_INFO": {
                    "sigma_3": {
                        "VALUE": 0.5,
                        "UNITS": "mg/m2/day",
                        "RANGE": [
                            0.0,
                            5.0
                        ],
                        "DESCRIPTION": "Benthic ammonia release",
                        "TEMP_COEFF": 1.074
                    },
                    "depth": {
                        "VALUE": 1.0,
                        "UNITS": "m"
                    }
                }
            }
        },
        "QUAL2E_PHOSPHORUS": {
            "_DESCRIPTION": "Phosphorus cycling",
            "LIST_TRANSFORMATIONS": {
                "1": "ORG_P_SETTLING",
                "2": "ORG_P_DECAY",
                "3": "BENTHIC_P"
            },
            "1": {
                "_NAME": "ORG_P_SETTLING",
                "CONSUMED": "ORG_P",
                "PRODUCED": "SED_P",
                "KINETICS": [
                    "sigma_5 * ORG_P",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "sigma_5"
                ],
                "PARAMETER_VALUES": {
                    "sigma_5": 0.3
                },
                "_PARAMETERS_INFO": {
                    "sigma_5": {
                        "VALUE": 0.3,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.0,
                            1.0
                        ],
                        "DESCRIPTION": "Organic P settling rate",
                        "TEMP_COEFF": 1.024
                    }
                }
            },
            "2": {
                "_NAME": "ORG_P_DECAY",
                "CONSUMED": "ORG_P",
                "PRODUCED": "DISS_P",
                "KINETICS": [
                    "beta_4 * ORG_P",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "beta_4"
                ],
                "PARAMETER_VALUES": {
                    "beta_4": 0.2
                },
                "_PARAMETERS_INFO": {
                    "beta_4": {
                        "VALUE": 0.2,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.02,
                            0.5
                        ],
                        "DESCRIPTION": "Organic P decay rate",
                        "TEMP_COEFF": 1.047
                    }
                }
            },
            "3": {
                "_NAME": "BENTHIC_P",
                "CONSUMED": "NONE",
                "PRODUCED": "DISS_P",
                "KINETICS": [
                    "sigma_2 / depth",
                    "mg/day"
                ],
                "PARAMETER_NAMES": [
                    "sigma_2",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "sigma_2": 0.05,
                    "depth": 1.0
                },
                "_PARAMETERS_INFO": {
                    "sigma_2": {
                        "VALUE": 0.05,
                        "UNITS": "mg/m2/day",
                        "RANGE": [
                            0.0,
                            0.5
                        ],
                        "DESCRIPTION": "Benthic P release",
                        "TEMP_COEFF": 1.074
                    },
                    "depth": {
                        "VALUE": 1.0,
                        "UNITS": "m"
                    }
                }
            }
        },
        "QUAL2E_ALGAE": {
            "_DESCRIPTION": "Algal growth and respiration",
            "LIST_TRANSFORMATIONS": {
                "1": "ALGAE_GROWTH",
                "2": "ALGAE_RESPIRATION",
                "3": "ALGAE_DEATH",
                "4": "ALGAE_O2_PRODUCTION",
                "5": "ALGAE_O2_RESPIRATION",
                "6": "ALGAE_N_UPTAKE",
                "7": "ALGAE_P_UPTAKE"
            },
            "1": {
                "_NAME": "ALGAE_GROWTH",
                "CONSUMED": "NONE",
                "PRODUCED": "ALGAE",
                "KINETICS": [
                    "mu * ALGAE",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "mu"
                ],
                "PARAMETER_VALUES": {
                    "mu": 2.0
                },
                "_PARAMETERS_INFO": {
                    "mu": {
                        "VALUE": 2.0,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.5,
                            3.0
                        ],
                        "DESCRIPTION": "Maximum algal growth rate",
                        "FORMULA": "mu_max * FL * FN * FP",
                        "FL": "Light limitation factor",
                        "FN": "min(N/(KN+N), P/(KP+P))",
                        "TEMP_COEFF": 1.047
                    }
                }
            },
            "2": {
                "_NAME": "ALGAE_RESPIRATION",
                "CONSUMED": "ALGAE",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "rho * ALGAE",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "rho"
                ],
                "PARAMETER_VALUES": {
                    "rho": 0.1
                },
                "_PARAMETERS_INFO": {
                    "rho": {
                        "VALUE": 0.1,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.05,
                            0.3
                        ],
                        "DESCRIPTION": "Algal respiration rate",
                        "TEMP_COEFF": 1.047
                    }
                }
            },
            "3": {
                "_NAME": "ALGAE_DEATH",
                "CONSUMED": "ALGAE",
                "PRODUCED": "ORG_N",
                "KINETICS": [
                    "sigma_1 * ALGAE * alpha_1",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "sigma_1",
                    "alpha_1"
                ],
                "PARAMETER_VALUES": {
                    "sigma_1": 0.2,
                    "alpha_1": 0.08
                },
                "_PARAMETERS_INFO": {
                    "sigma_1": {
                        "VALUE": 0.2,
                        "UNITS": "1/day",
                        "DESCRIPTION": "Algal settling/death rate"
                    },
                    "alpha_1": {
                        "VALUE": 0.08,
                        "UNITS": "mg N/mg Chl-a",
                        "DESCRIPTION": "N content of algae"
                    }
                }
            },
            "4": {
                "_NAME": "ALGAE_O2_PRODUCTION",
                "CONSUMED": "NONE",
                "PRODUCED": "DO",
                "KINETICS": [
                    "alpha_3 * mu * ALGAE",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "mu",
                    "alpha_3"
                ],
                "PARAMETER_VALUES": {
                    "mu": 2.0,
                    "alpha_3": 1.6
                },
                "_PARAMETERS_INFO": {
                    "mu": {
                        "VALUE": 2.0,
                        "UNITS": "1/day"
                    },
                    "alpha_3": {
                        "VALUE": 1.6,
                        "UNITS": "mg O2/mg Chl-a",
                        "DESCRIPTION": "O2 production per unit algae"
                    }
                }
            },
            "5": {
                "_NAME": "ALGAE_O2_RESPIRATION",
                "CONSUMED": "DO",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "alpha_4 * rho * ALGAE",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "rho",
                    "alpha_4"
                ],
                "PARAMETER_VALUES": {
                    "rho": 0.1,
                    "alpha_4": 2.0
                },
                "_PARAMETERS_INFO": {
                    "rho": {
                        "VALUE": 0.1,
                        "UNITS": "1/day"
                    },
                    "alpha_4": {
                        "VALUE": 2.0,
                        "UNITS": "mg O2/mg Chl-a",
                        "DESCRIPTION": "O2 consumption per unit respiration"
                    }
                }
            },
            "6": {
                "_NAME": "ALGAE_N_UPTAKE",
                "CONSUMED": "NH4-N",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "alpha_1 * mu * ALGAE * P_NH4-N",
                    "1"
                ],
                "PARAMETER_NAMES": [
                    "alpha_1",
                    "mu",
                    "P_NH4-N"
                ],
                "PARAMETER_VALUES": {
                    "alpha_1": 0.08,
                    "mu": 2.0,
                    "P_NH4-N": 0.5
                },
                "_PARAMETERS_INFO": {
                    "alpha_1": {
                        "VALUE": 0.08,
                        "UNITS": "mg N/mg Chl-a"
                    },
                    "mu": {
                        "VALUE": 2.0,
                        "UNITS": "1/day"
                    },
                    "P_NH4-N": {
                        "VALUE": 0.5,
                        "DESCRIPTION": "Preference for NH4-N over NO3-N"
                    }
                }
            },
            "7": {
                "_NAME": "ALGAE_P_UPTAKE",
                "CONSUMED": "DISS_P",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "alpha_2 * mu * ALGAE",
                    "1"
                ],
                "PARAMETER_NAMES": [
                    "alpha_2",
                    "mu"
                ],
                "PARAMETER_VALUES": {
                    "alpha_2": 0.015,
                    "mu": 2.0
                },
                "_PARAMETERS_INFO": {
                    "alpha_2": {
                        "VALUE": 0.015,
                        "UNITS": "mg P/mg Chl-a",
                        "DESCRIPTION": "P content of algae"
                    },
                    "mu": {
                        "VALUE": 2.0,
                        "UNITS": "1/day"
                    }
                }
            }
        },
        "QUAL2E_COLIFORM": {
            "_DESCRIPTION": "Coliform bacteria die-off",
            "LIST_TRANSFORMATIONS": {
                "1": "COLIFORM_DIEOFF"
            },
            "1": {
                "_NAME": "COLIFORM_DIEOFF",
                "CONSUMED": "FECAL_COLIFORM",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "Kb * FECAL_COLIFORM",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "Kb"
                ],
                "PARAMETER_VALUES": {
                    "Kb": 2.0
                },
                "_PARAMETERS_INFO": {
                    "Kb": {
                        "VALUE": 2.0,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.5,
                            10.0
                        ],
                        "DESCRIPTION": "Coliform die-off rate",
                        "TEMP_COEFF": 1.047
                    }
                }
            }
        },
        "QUAL2E_REAERATION_FORMULAS": {
            "_DESCRIPTION": "Alternative K2 calculation methods",
            "LIST_TRANSFORMATIONS": {},
            "_OCONNOR_DOBBINS_INFO": {
                "FORMULA": "K2 = 3.93 * U^0.5 / H^1.5",
                "NOTES": "U = velocity (m/s), H = depth (m); for moderate streams"
            },
            "_CHURCHILL_INFO": {
                "FORMULA": "K2 = 5.03 * U^0.969 / H^1.673",
                "NOTES": "For large streams and rivers"
            },
            "_OWENS_GIBBS_INFO": {
                "FORMULA": "K2 = 5.34 * U^0.67 / H^1.85",
                "NOTES": "For shallow streams (H < 0.6m)"
            },
            "_TSIVOGLOU_INFO": {
                "FORMULA": "K2 = 31.6 * C * S * U",
                "NOTES": "C = escape coeff, S = slope, U = velocity"
            }
        }
    },
    "_COMPARTMENT_ASSIGNMENT": {
        "STREAM": [
            "QUAL2E_DO_BOD",
            "QUAL2E_NITROGEN",
            "QUAL2E_PHOSPHORUS",
            "QUAL2E_ALGAE",
            "QUAL2E_COLIFORM"
        ],
        "RIVER": [
            "QUAL2E_DO_BOD",
            "QUAL2E_NITROGEN",
            "QUAL2E_PHOSPHORUS",
            "QUAL2E_ALGAE",
            "QUAL2E_COLIFORM"
        ]
    }
}