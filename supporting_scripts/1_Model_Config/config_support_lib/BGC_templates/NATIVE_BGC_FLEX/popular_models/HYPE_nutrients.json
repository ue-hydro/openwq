{
    "_DESCRIPTION": "HYPE-Style Nutrient Cycling Model",
    "_REFERENCE": "HYPE Model Documentation (SMHI)",
    "_MODEL": "Hydrological Predictions for the Environment (HYPE)",
    "_VERSION": "1.0",
    "_NOTES": "Nordic-style catchment nutrient model with soil layers and wetland retention",
    "CHEMICAL_SPECIES": {
        "LIST": {
            "1": "IN",
            "2": "ON",
            "3": "humusN",
            "4": "fastN",
            "5": "SP",
            "6": "PP",
            "7": "humusP",
            "8": "fastP",
            "9": "PartP",
            "10": "TOC",
            "11": "SS"
        },
        "BGC_GENERAL_MOBILE_SPECIES": [
            "IN",
            "ON",
            "humusN",
            "fastN",
            "SP",
            "PP",
            "humusP",
            "fastP",
            "PartP",
            "TOC",
            "SS"
        ],
        "_LIST_DESCRIPTIONS": {
            "IN": "Inorganic nitrogen (NO3 + NH4)",
            "ON": "Organic nitrogen",
            "humusN": "Soil humus nitrogen pool",
            "fastN": "Fast-cycling organic N pool",
            "SP": "Soluble reactive phosphorus",
            "PP": "Particulate phosphorus",
            "humusP": "Soil humus phosphorus pool",
            "fastP": "Fast-cycling organic P pool",
            "PartP": "Soil particulate P (mineral)",
            "TOC": "Total organic carbon",
            "SS": "Suspended sediment"
        }
    },
    "CYCLING_FRAMEWORKS": {
        "HYPE_SOIL_N": {
            "_DESCRIPTION": "HYPE soil nitrogen processes",
            "LIST_TRANSFORMATIONS": {
                "1": "MINERALIZATION_N",
                "2": "MINERALIZATION_FAST_N",
                "3": "DENITRIFICATION",
                "4": "CROP_UPTAKE_N",
                "5": "DISSOLUTION_ON"
            },
            "1": {
                "_NAME": "MINERALIZATION_N",
                "CONSUMED": "humusN",
                "PRODUCED": "IN",
                "KINETICS": [
                    "minerfN * tmpfcn * smfcn * humusN",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "minerfN",
                    "tmpfcn",
                    "smfcn"
                ],
                "PARAMETER_VALUES": {
                    "minerfN": 5e-05,
                    "tmpfcn": 1.0,
                    "smfcn": 1.0
                },
                "_PARAMETERS_INFO": {
                    "minerfN": {
                        "VALUE": 5e-05,
                        "UNITS": "1/day",
                        "RANGE": [
                            1e-05,
                            0.0002
                        ],
                        "DESCRIPTION": "N mineralization rate from humus"
                    },
                    "tmpfcn": {
                        "VALUE": 1.0,
                        "DESCRIPTION": "Temperature function: 2^((T-20)/10)"
                    },
                    "smfcn": {
                        "VALUE": 1.0,
                        "DESCRIPTION": "Soil moisture function"
                    }
                }
            },
            "2": {
                "_NAME": "MINERALIZATION_FAST_N",
                "CONSUMED": "fastN",
                "PRODUCED": "IN",
                "KINETICS": [
                    "minerfN * 10 * tmpfcn * smfcn * fastN",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "minerfN",
                    "tmpfcn",
                    "smfcn"
                ],
                "PARAMETER_VALUES": {
                    "minerfN": 5e-05,
                    "tmpfcn": 1.0,
                    "smfcn": 1.0
                },
                "_NOTES": "Fast pool mineralizes 10x faster than humus",
                "_PARAMETERS_INFO": {
                    "minerfN": {
                        "VALUE": 5e-05,
                        "UNITS": "1/day"
                    },
                    "tmpfcn": {
                        "VALUE": 1.0
                    },
                    "smfcn": {
                        "VALUE": 1.0
                    }
                }
            },
            "3": {
                "_NAME": "DENITRIFICATION",
                "CONSUMED": "IN",
                "PRODUCED": "N2_loss",
                "KINETICS": [
                    "denitrlu * denitr * tmpfcn * smfcn_sat * IN / (IN + halfsatIN)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "denitrlu",
                    "denitr",
                    "halfsatIN",
                    "smfcn_sat"
                ],
                "PARAMETER_VALUES": {
                    "denitrlu": 1.0,
                    "denitr": 0.003,
                    "halfsatIN": 1.0,
                    "smfcn_sat": 0.5
                },
                "_PARAMETERS_INFO": {
                    "denitrlu": {
                        "VALUE": 1.0,
                        "DESCRIPTION": "Land-use dependent factor (0-1)"
                    },
                    "denitr": {
                        "VALUE": 0.003,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.0005,
                            0.01
                        ],
                        "DESCRIPTION": "Denitrification rate parameter"
                    },
                    "halfsatIN": {
                        "VALUE": 1.0,
                        "UNITS": "mg/L",
                        "DESCRIPTION": "Half-saturation for IN"
                    },
                    "smfcn_sat": {
                        "VALUE": 0.5,
                        "DESCRIPTION": "Saturation function: max(0, (sm-wp)/(fc-wp))"
                    }
                }
            },
            "4": {
                "_NAME": "CROP_UPTAKE_N",
                "CONSUMED": "IN",
                "PRODUCED": "CROP_N",
                "KINETICS": [
                    "uptakelu * uptakeN * cropcover * tmpfcn * IN / (IN + halfsatIN)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "uptakelu",
                    "uptakeN",
                    "cropcover",
                    "halfsatIN"
                ],
                "PARAMETER_VALUES": {
                    "uptakelu": 1.0,
                    "uptakeN": 0.05,
                    "cropcover": 0.5,
                    "halfsatIN": 1.0
                },
                "_PARAMETERS_INFO": {
                    "uptakelu": {
                        "VALUE": 1.0,
                        "DESCRIPTION": "Land-use factor"
                    },
                    "uptakeN": {
                        "VALUE": 0.05,
                        "UNITS": "1/day",
                        "DESCRIPTION": "Plant uptake rate"
                    },
                    "cropcover": {
                        "VALUE": 0.5,
                        "DESCRIPTION": "Crop cover fraction"
                    },
                    "halfsatIN": {
                        "VALUE": 1.0,
                        "UNITS": "mg/L"
                    }
                }
            },
            "5": {
                "_NAME": "DISSOLUTION_ON",
                "CONSUMED": "ON",
                "PRODUCED": "IN",
                "KINETICS": [
                    "dissolfN * tmpfcn * ON",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "dissolfN"
                ],
                "PARAMETER_VALUES": {
                    "dissolfN": 0.003
                },
                "_PARAMETERS_INFO": {
                    "dissolfN": {
                        "VALUE": 0.003,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.001,
                            0.01
                        ],
                        "DESCRIPTION": "ON dissolution rate"
                    }
                }
            }
        },
        "HYPE_SOIL_P": {
            "_DESCRIPTION": "HYPE soil phosphorus processes",
            "LIST_TRANSFORMATIONS": {
                "1": "MINERALIZATION_P",
                "2": "MINERALIZATION_FAST_P",
                "3": "DISSOLUTION_PP",
                "4": "P_SORPTION",
                "5": "CROP_UPTAKE_P"
            },
            "1": {
                "_NAME": "MINERALIZATION_P",
                "CONSUMED": "humusP",
                "PRODUCED": "SP",
                "KINETICS": [
                    "minerfP * tmpfcn * smfcn * humusP",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "minerfP"
                ],
                "PARAMETER_VALUES": {
                    "minerfP": 3e-05
                },
                "_PARAMETERS_INFO": {
                    "minerfP": {
                        "VALUE": 3e-05,
                        "UNITS": "1/day",
                        "RANGE": [
                            1e-05,
                            0.0001
                        ],
                        "DESCRIPTION": "P mineralization rate from humus"
                    }
                }
            },
            "2": {
                "_NAME": "MINERALIZATION_FAST_P",
                "CONSUMED": "fastP",
                "PRODUCED": "SP",
                "KINETICS": [
                    "minerfP * 10 * tmpfcn * smfcn * fastP",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "minerfP"
                ],
                "PARAMETER_VALUES": {
                    "minerfP": 3e-05
                },
                "_PARAMETERS_INFO": {
                    "minerfP": {
                        "VALUE": 3e-05,
                        "UNITS": "1/day"
                    }
                }
            },
            "3": {
                "_NAME": "DISSOLUTION_PP",
                "CONSUMED": "PartP",
                "PRODUCED": "SP",
                "KINETICS": [
                    "dissolfP * tmpfcn * PartP",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "dissolfP"
                ],
                "PARAMETER_VALUES": {
                    "dissolfP": 0.0003
                },
                "_PARAMETERS_INFO": {
                    "dissolfP": {
                        "VALUE": 0.0003,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.0001,
                            0.001
                        ],
                        "DESCRIPTION": "Particulate P dissolution rate"
                    }
                }
            },
            "4": {
                "_NAME": "P_SORPTION",
                "CONSUMED": "SP",
                "PRODUCED": "PartP",
                "KINETICS": [
                    "freession * freession * (SP - eqSP)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "freession",
                    "eqSP"
                ],
                "PARAMETER_VALUES": {
                    "freession": 0.1,
                    "eqSP": 0.01
                },
                "_NOTES": "Net sorption when SP > eqSP",
                "_PARAMETERS_INFO": {
                    "freession": {
                        "VALUE": 0.1,
                        "UNITS": "1/day",
                        "DESCRIPTION": "P sorption rate"
                    },
                    "eqSP": {
                        "VALUE": 0.01,
                        "UNITS": "mg/L",
                        "DESCRIPTION": "Equilibrium SP concentration"
                    }
                }
            },
            "5": {
                "_NAME": "CROP_UPTAKE_P",
                "CONSUMED": "SP",
                "PRODUCED": "CROP_P",
                "KINETICS": [
                    "uptakelu * uptakeP * cropcover * tmpfcn * SP / (SP + halfsatSP)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "uptakeP",
                    "halfsatSP"
                ],
                "PARAMETER_VALUES": {
                    "uptakeP": 0.01,
                    "halfsatSP": 0.02
                },
                "_PARAMETERS_INFO": {
                    "uptakeP": {
                        "VALUE": 0.01,
                        "UNITS": "1/day",
                        "DESCRIPTION": "Plant P uptake rate"
                    },
                    "halfsatSP": {
                        "VALUE": 0.02,
                        "UNITS": "mg/L"
                    }
                }
            }
        },
        "HYPE_STREAM": {
            "_DESCRIPTION": "HYPE in-stream processes",
            "LIST_TRANSFORMATIONS": {
                "1": "STREAM_DENITR",
                "2": "STREAM_ON_PRODUCTION",
                "3": "STREAM_PP_SETTLING",
                "4": "STREAM_SS_SETTLING"
            },
            "1": {
                "_NAME": "STREAM_DENITR",
                "CONSUMED": "IN",
                "PRODUCED": "N2_loss",
                "KINETICS": [
                    "denitwrm * tmpfcn_water * IN",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "denitwrm",
                    "tmpfcn_water"
                ],
                "PARAMETER_VALUES": {
                    "denitwrm": 0.001,
                    "tmpfcn_water": 1.0
                },
                "_PARAMETERS_INFO": {
                    "denitwrm": {
                        "VALUE": 0.001,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.0001,
                            0.01
                        ],
                        "DESCRIPTION": "In-stream denitrification rate"
                    },
                    "tmpfcn_water": {
                        "VALUE": 1.0,
                        "DESCRIPTION": "Water temperature function"
                    }
                }
            },
            "2": {
                "_NAME": "STREAM_ON_PRODUCTION",
                "CONSUMED": "IN",
                "PRODUCED": "ON",
                "KINETICS": [
                    "prodNpar * tmpfcn_water * IN",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "prodNpar"
                ],
                "PARAMETER_VALUES": {
                    "prodNpar": 0.0005
                },
                "_PARAMETERS_INFO": {
                    "prodNpar": {
                        "VALUE": 0.0005,
                        "UNITS": "1/day",
                        "DESCRIPTION": "Organic N production from algae"
                    }
                }
            },
            "3": {
                "_NAME": "STREAM_PP_SETTLING",
                "CONSUMED": "PP",
                "PRODUCED": "SED_P",
                "KINETICS": [
                    "sedPP * PP / depth",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "sedPP",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "sedPP": 0.5,
                    "depth": 1.0
                },
                "_PARAMETERS_INFO": {
                    "sedPP": {
                        "VALUE": 0.5,
                        "UNITS": "m/day",
                        "RANGE": [
                            0.1,
                            2.0
                        ],
                        "DESCRIPTION": "PP settling velocity"
                    },
                    "depth": {
                        "VALUE": 1.0,
                        "UNITS": "m"
                    }
                }
            },
            "4": {
                "_NAME": "STREAM_SS_SETTLING",
                "CONSUMED": "SS",
                "PRODUCED": "SED_SS",
                "KINETICS": [
                    "sedSS * SS / depth",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "sedSS",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "sedSS": 1.0,
                    "depth": 1.0
                },
                "_PARAMETERS_INFO": {
                    "sedSS": {
                        "VALUE": 1.0,
                        "UNITS": "m/day",
                        "DESCRIPTION": "SS settling velocity"
                    },
                    "depth": {
                        "VALUE": 1.0,
                        "UNITS": "m"
                    }
                }
            }
        },
        "HYPE_LAKE": {
            "_DESCRIPTION": "HYPE lake processes",
            "LIST_TRANSFORMATIONS": {
                "1": "LAKE_DENITR",
                "2": "LAKE_N_RETENTION",
                "3": "LAKE_P_RETENTION",
                "4": "LAKE_INTERNAL_P",
                "5": "LAKE_PP_SETTLING",
                "6": "LAKE_ON_SETTLING"
            },
            "1": {
                "_NAME": "LAKE_DENITR",
                "CONSUMED": "IN",
                "PRODUCED": "N2_loss",
                "KINETICS": [
                    "lakeDenitr * tmpfcn_lake * IN * (1 - ice_fraction)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "lakeDenitr",
                    "ice_fraction"
                ],
                "PARAMETER_VALUES": {
                    "lakeDenitr": 0.002,
                    "ice_fraction": 0.0
                },
                "_PARAMETERS_INFO": {
                    "lakeDenitr": {
                        "VALUE": 0.002,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.0005,
                            0.01
                        ],
                        "DESCRIPTION": "Lake denitrification rate"
                    },
                    "ice_fraction": {
                        "VALUE": 0.0,
                        "DESCRIPTION": "Ice cover fraction (0-1)"
                    }
                }
            },
            "2": {
                "_NAME": "LAKE_N_RETENTION",
                "CONSUMED": "IN",
                "PRODUCED": "SED_N",
                "KINETICS": [
                    "lakeNret * tmpfcn_lake * IN",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "lakeNret"
                ],
                "PARAMETER_VALUES": {
                    "lakeNret": 0.001
                },
                "_PARAMETERS_INFO": {
                    "lakeNret": {
                        "VALUE": 0.001,
                        "UNITS": "1/day",
                        "DESCRIPTION": "Lake N retention rate"
                    }
                }
            },
            "3": {
                "_NAME": "LAKE_P_RETENTION",
                "CONSUMED": "SP",
                "PRODUCED": "SED_P",
                "KINETICS": [
                    "lakePret * SP",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "lakePret"
                ],
                "PARAMETER_VALUES": {
                    "lakePret": 0.005
                },
                "_PARAMETERS_INFO": {
                    "lakePret": {
                        "VALUE": 0.005,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.001,
                            0.02
                        ],
                        "DESCRIPTION": "Lake P retention rate"
                    }
                }
            },
            "4": {
                "_NAME": "LAKE_INTERNAL_P",
                "CONSUMED": "NONE",
                "PRODUCED": "SP",
                "KINETICS": [
                    "lakeintpar * tmpfcn_lake * (1 - ice_fraction) / depth",
                    "mg/day"
                ],
                "PARAMETER_NAMES": [
                    "lakeintpar",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "lakeintpar": 0.5,
                    "depth": 5.0
                },
                "_NOTES": "Internal loading from sediments",
                "_PARAMETERS_INFO": {
                    "lakeintpar": {
                        "VALUE": 0.5,
                        "UNITS": "mg/m2/day",
                        "RANGE": [
                            0.1,
                            5.0
                        ],
                        "DESCRIPTION": "Lake internal P loading rate"
                    },
                    "depth": {
                        "VALUE": 5.0,
                        "UNITS": "m"
                    }
                }
            },
            "5": {
                "_NAME": "LAKE_PP_SETTLING",
                "CONSUMED": "PP",
                "PRODUCED": "SED_P",
                "KINETICS": [
                    "sedPP * PP / depth",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "sedPP",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "sedPP": 0.5,
                    "depth": 5.0
                },
                "_PARAMETERS_INFO": {
                    "sedPP": {
                        "VALUE": 0.5,
                        "UNITS": "m/day"
                    },
                    "depth": {
                        "VALUE": 5.0,
                        "UNITS": "m"
                    }
                }
            },
            "6": {
                "_NAME": "LAKE_ON_SETTLING",
                "CONSUMED": "ON",
                "PRODUCED": "SED_N",
                "KINETICS": [
                    "sedON * ON / depth",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "sedON",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "sedON": 0.3,
                    "depth": 5.0
                },
                "_PARAMETERS_INFO": {
                    "sedON": {
                        "VALUE": 0.3,
                        "UNITS": "m/day",
                        "DESCRIPTION": "ON settling velocity"
                    },
                    "depth": {
                        "VALUE": 5.0,
                        "UNITS": "m"
                    }
                }
            }
        },
        "HYPE_WETLAND": {
            "_DESCRIPTION": "HYPE wetland nutrient retention",
            "LIST_TRANSFORMATIONS": {
                "1": "WETLAND_N_RETENTION",
                "2": "WETLAND_P_RETENTION"
            },
            "1": {
                "_NAME": "WETLAND_N_RETENTION",
                "CONSUMED": "IN",
                "PRODUCED": "SED_N",
                "KINETICS": [
                    "wetNret * IN",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "wetNret"
                ],
                "PARAMETER_VALUES": {
                    "wetNret": 0.01
                },
                "_PARAMETERS_INFO": {
                    "wetNret": {
                        "VALUE": 0.01,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.005,
                            0.05
                        ],
                        "DESCRIPTION": "Wetland N retention rate"
                    }
                }
            },
            "2": {
                "_NAME": "WETLAND_P_RETENTION",
                "CONSUMED": "SP",
                "PRODUCED": "SED_P",
                "KINETICS": [
                    "wetPret * SP",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "wetPret"
                ],
                "PARAMETER_VALUES": {
                    "wetPret": 0.02
                },
                "_PARAMETERS_INFO": {
                    "wetPret": {
                        "VALUE": 0.02,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.01,
                            0.1
                        ],
                        "DESCRIPTION": "Wetland P retention rate"
                    }
                }
            }
        },
        "HYPE_TEMPERATURE_FUNCTIONS": {
            "_DESCRIPTION": "Temperature correction factors used in HYPE",
            "LIST_TRANSFORMATIONS": {},
            "_Q10_FUNCTION_INFO": {
                "FORMULA": "tmpfcn = Q10^((T - Tref) / 10)",
                "Q10": 2.0,
                "Tref": 20.0,
                "NOTES": "Standard Q10 formulation"
            },
            "_ARRHENIUS_INFO": {
                "FORMULA": "tmpfcn = exp(A * (T - Tref))",
                "A": 0.069,
                "Tref": 20.0,
                "NOTES": "Equivalent to Q10=2"
            },
            "_MOISTURE_FUNCTION_INFO": {
                "FORMULA": "smfcn = (sm - wp) / (fc - wp)",
                "NOTES": "sm=soil moisture, wp=wilting point, fc=field capacity"
            }
        }
    },
    "_COMPARTMENT_ASSIGNMENT": {
        "SOIL_LAYER_1": [
            "HYPE_SOIL_N",
            "HYPE_SOIL_P"
        ],
        "SOIL_LAYER_2": [
            "HYPE_SOIL_N",
            "HYPE_SOIL_P"
        ],
        "SOIL_LAYER_3": [
            "HYPE_SOIL_N",
            "HYPE_SOIL_P"
        ],
        "STREAM": [
            "HYPE_STREAM"
        ],
        "LAKE": [
            "HYPE_LAKE"
        ],
        "WETLAND": [
            "HYPE_WETLAND"
        ]
    }
}