{
    "_DESCRIPTION": "Anaerobic Ammonium Oxidation (Anammox) with Thermodynamic Control",
    "_REFERENCE": "Jin & Bethke (2007); Strous et al. (1999)",
    "_REACTION": "NH4-N+ + NO2-N- -> N2 + 2 H2O",
    "_DELTA_G0": "-357 kJ/mol (highly exergonic)",
    "_IMPORTANCE": "Major pathway for N removal in anoxic marine environments",
    "MODULE_NAME": "NATIVE_BGC_FLEX",
    "CHEMICAL_SPECIES": {
        "LIST": {
            "1": "NH4-N",
            "2": "NO2-N",
            "3": "N2_loss",
            "4": "DO",
            "5": "X_anammox"
        },
        "BGC_GENERAL_MOBILE_SPECIES": [
            "NH4-N",
            "NO2-N"
        ],
        "_LIST_DESCRIPTIONS": {
            "NH4-N": "Ammonium nitrogen",
            "NO2-N": "Nitrite nitrogen",
            "N2_loss": "Dinitrogen gas loss (denitrification product)",
            "DO": "Dissolved oxygen",
            "X_anammox": "Anammox bacteria biomass"
        }
    },
    "CYCLING_FRAMEWORKS": {
        "ANAMMOX_THERMO": {
            "LIST_TRANSFORMATIONS": {
                "1": "anammox",
                "2": "anammox_growth",
                "3": "anammox_decay"
            },
            "_THERMODYNAMIC_CONSTANTS": {
                "deltaG0": -357.0,
                "deltaG_ATP": 45.0,
                "chi": 2,
                "R_kJ": 0.008314,
                "NOTES": [
                    "Anammox is highly exergonic (\u0394G\u00b0 = -357 kJ/mol)",
                    "F_T \u2248 1.0 under all conditions",
                    "Strict anaerobes - completely inhibited by O2",
                    "Very slow growing organisms (doubling time ~11 days)",
                    "Important in oxygen minimum zones (OMZ) and sediments"
                ]
            },
            "1": {
                "_name": "anammox",
                "_description": "Anaerobic oxidation of NH4-N+ using NO2-N- as electron acceptor",
                "_reaction": "NH4-N+ + NO2-N- -> N2 + 2 H2O",
                "CONSUMED": "NH4-N",
                "PRODUCED": "N2_loss",
                "KINETICS": [
                    "k_anmx * X_anammox * (NH4-N/(Km_NH4N+NH4-N)) * (NO2-N/(Km_NO2N+NO2-N)) * (Ki_O2/(Ki_O2+DO)) * (1 - exp(-((357-45)/(2*0.008314*(T+273)))))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_anmx",
                    "Km_NH4N",
                    "Km_NO2N",
                    "Ki_O2"
                ],
                "PARAMETER_VALUES": {
                    "k_anmx": 2.0,
                    "Km_NH4N": 0.1,
                    "Km_NO2N": 0.05,
                    "Ki_O2": 0.01
                },
                "_notes": [
                    "Very low k_anmx reflects slow anammox growth",
                    "Very low Ki_O2 - strict anaerobe",
                    "Requires both NH4-N and NO2-N - often coupled with partial nitrification"
                ]
            },
            "2": {
                "_name": "anammox_growth",
                "CONSUMED": "NH4-N",
                "PRODUCED": "X_anammox",
                "KINETICS": [
                    "Y_anmx * k_anmx * X_anammox * (NH4-N/(Km_NH4N+NH4-N)) * (NO2-N/(Km_NO2N+NO2-N)) * (Ki_O2/(Ki_O2+DO)) * (1 - exp(-((357-45)/(2*0.008314*(T+273)))))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "Y_anmx",
                    "k_anmx",
                    "Km_NH4N",
                    "Km_NO2N",
                    "Ki_O2"
                ],
                "PARAMETER_VALUES": {
                    "Y_anmx": 0.11,
                    "k_anmx": 2.0,
                    "Km_NH4N": 0.1,
                    "Km_NO2N": 0.05,
                    "Ki_O2": 0.01
                },
                "_notes": "Low yield - autotrophic metabolism"
            },
            "3": {
                "_name": "anammox_decay",
                "CONSUMED": "X_anammox",
                "PRODUCED": "NH4-N",
                "KINETICS": [
                    "k_decay * X_anammox",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_decay"
                ],
                "PARAMETER_VALUES": {
                    "k_decay": 0.01
                },
                "_notes": "Very low decay rate - slow turnover organisms"
            }
        }
    },
    "_USE_CASES": [
        "Oxygen minimum zones (OMZ) in oceans",
        "Anoxic sediments with NO2-N supply from incomplete denitrification",
        "Wastewater treatment (DEMON, SHARON-Anammox processes)",
        "Stratified lakes with anoxic hypolimnion"
    ]
}