{
    "_DESCRIPTION": "Iron Reduction with Thermodynamic Control",
    "_REFERENCE": "Jin & Bethke (2007); Roden (2003)",
    "_REACTION": "CH2O + 4 Fe(OH)3 + 8 H+ -> CO2 + 4 Fe2+ + 11 H2O",
    "_DELTA_G0": "-50 kJ/mol e- (intermediate in redox ladder)",
    "MODULE_NAME": "NATIVE_BGC_FLEX",
    "CHEMICAL_SPECIES": {
        "LIST": {
            "1": "Fe_III",
            "2": "Fe_II",
            "3": "DOC",
            "4": "CO2",
            "5": "DO",
            "6": "NO3-N",
            "7": "X_irb"
        },
        "BGC_GENERAL_MOBILE_SPECIES": [
            "Fe_II",
            "DOC",
            "CO2"
        ],
        "_LIST_DESCRIPTIONS": {
            "Fe_III": "Iron(III) oxide/hydroxide (oxidized)",
            "Fe_II": "Dissolved iron(II) (reduced)",
            "DOC": "Dissolved organic carbon",
            "CO2": "Dissolved carbon dioxide",
            "DO": "Dissolved oxygen",
            "NO3-N": "Nitrate nitrogen",
            "X_irb": "Iron-reducing bacteria biomass"
        }
    },
    "CYCLING_FRAMEWORKS": {
        "IRON_REDUCTION_THERMO": {
            "LIST_TRANSFORMATIONS": {
                "1": "iron_reduction",
                "2": "irb_growth",
                "3": "irb_decay",
                "4": "iron_oxidation"
            },
            "_THERMODYNAMIC_CONSTANTS": {
                "deltaG0": -50.0,
                "deltaG_ATP": 45.0,
                "chi": 2,
                "R_kJ": 0.008314,
                "NOTES": [
                    "Fe(III) reduction is intermediate in the redox ladder",
                    "Proceeds after O2 and NO3-N depletion, before SO4-S reduction",
                    "Fe(III) is often solid phase (ferrihydrite, goethite)",
                    "Surface area limitation important for solid Fe(III)"
                ]
            },
            "1": {
                "_name": "iron_reduction",
                "_description": "Dissimilatory Fe(III) reduction to Fe(II)",
                "CONSUMED": "Fe_III",
                "PRODUCED": "Fe_II",
                "KINETICS": [
                    "k_irb * X_irb * (Fe_III/(Km_Fe3+Fe_III)) * (DOC/(Km_DOC+DOC)) * (Ki_O2/(Ki_O2+DO)) * (Ki_NO3-N/(Ki_NO3-N+NO3-N)) * (1 - exp(-((50-45)/(2*0.008314*(T+273)))))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_irb",
                    "Km_Fe3",
                    "Km_DOC",
                    "Ki_O2",
                    "Ki_NO3-N"
                ],
                "PARAMETER_VALUES": {
                    "k_irb": 10.0,
                    "Km_Fe3": 10.0,
                    "Km_DOC": 2.0,
                    "Ki_O2": 0.2,
                    "Ki_NO3-N": 0.5
                },
                "_notes": [
                    "F_T = 1 - exp(-5/(2*0.008314*293)) = 1 - exp(-1.03) \u2248 0.64",
                    "Iron reduction is moderately thermodynamically limited",
                    "More sensitive to conditions than denitrification"
                ]
            },
            "2": {
                "_name": "irb_growth",
                "CONSUMED": "DOC",
                "PRODUCED": "X_irb",
                "KINETICS": [
                    "Y_irb * k_irb * X_irb * (Fe_III/(Km_Fe3+Fe_III)) * (DOC/(Km_DOC+DOC)) * (Ki_O2/(Ki_O2+DO)) * (Ki_NO3-N/(Ki_NO3-N+NO3-N)) * (1 - exp(-((50-45)/(2*0.008314*(T+273)))))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "Y_irb",
                    "k_irb",
                    "Km_Fe3",
                    "Km_DOC",
                    "Ki_O2",
                    "Ki_NO3-N"
                ],
                "PARAMETER_VALUES": {
                    "Y_irb": 0.25,
                    "k_irb": 10.0,
                    "Km_Fe3": 10.0,
                    "Km_DOC": 2.0,
                    "Ki_O2": 0.2,
                    "Ki_NO3-N": 0.5
                }
            },
            "3": {
                "_name": "irb_decay",
                "CONSUMED": "X_irb",
                "PRODUCED": "DOC",
                "KINETICS": [
                    "k_decay * X_irb",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_decay"
                ],
                "PARAMETER_VALUES": {
                    "k_decay": 0.05
                }
            },
            "4": {
                "_name": "iron_oxidation",
                "_description": "Abiotic Fe(II) oxidation by O2",
                "CONSUMED": "Fe_II",
                "PRODUCED": "Fe_III",
                "KINETICS": [
                    "k_feox * Fe_II * DO",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_feox"
                ],
                "PARAMETER_VALUES": {
                    "k_feox": 50.0
                },
                "_notes": "Fast abiotic reaction, pH dependent in reality"
            }
        }
    }
}