{
    "_DESCRIPTION": "Aerobic Respiration with Thermodynamic Control",
    "_REFERENCE": "Jin & Bethke (2003, 2007); Regnier et al. (2011)",
    "_REACTION": "CH2O + O2 -> CO2 + H2O",
    "_DELTA_G0": "-125 kJ/mol e- (most favorable electron acceptor)",
    "MODULE_NAME": "NATIVE_BGC_FLEX",
    "CHEMICAL_SPECIES": {
        "LIST": {
            "1": "DO",
            "2": "DOC",
            "3": "CO2",
            "4": "X_aer"
        },
        "BGC_GENERAL_MOBILE_SPECIES": [
            "DO",
            "DOC",
            "CO2"
        ],
        "_LIST_DESCRIPTIONS": {
            "DO": "Dissolved oxygen",
            "DOC": "Dissolved organic carbon",
            "CO2": "Dissolved carbon dioxide",
            "X_aer": "Aerobic heterotroph biomass"
        }
    },
    "CYCLING_FRAMEWORKS": {
        "AEROBIC_RESPIRATION_THERMO": {
            "LIST_TRANSFORMATIONS": {
                "1": "aerobic_respiration",
                "2": "aerobe_growth",
                "3": "aerobe_decay",
                "4": "reaeration"
            },
            "_THERMODYNAMIC_CONSTANTS": {
                "deltaG0": -125.0,
                "deltaG_ATP": 45.0,
                "chi": 2,
                "R_kJ": 0.008314,
                "F_T_at_20C": "1 - exp(-80/(2*0.008314*293)) = 1 - exp(-16.4) \u2248 1.0"
            },
            "1": {
                "_name": "aerobic_respiration",
                "CONSUMED": "DO",
                "PRODUCED": "CO2",
                "KINETICS": [
                    "k_resp * X_aer * (DO/(Km_O2+DO)) * (DOC/(Km_DOC+DOC)) * (1 - exp(-((125-45)/(2*0.008314*(T+273)))))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_resp",
                    "Km_O2",
                    "Km_DOC"
                ],
                "PARAMETER_VALUES": {
                    "k_resp": 25.0,
                    "Km_O2": 0.5,
                    "Km_DOC": 2.0
                },
                "_notes": "F_T \u2248 1.0 - aerobic respiration is always thermodynamically favorable"
            },
            "2": {
                "_name": "aerobe_growth",
                "CONSUMED": "DOC",
                "PRODUCED": "X_aer",
                "KINETICS": [
                    "Y_aer * k_resp * X_aer * (DO/(Km_O2+DO)) * (DOC/(Km_DOC+DOC)) * (1 - exp(-((125-45)/(2*0.008314*(T+273)))))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "Y_aer",
                    "k_resp",
                    "Km_O2",
                    "Km_DOC"
                ],
                "PARAMETER_VALUES": {
                    "Y_aer": 0.4,
                    "k_resp": 25.0,
                    "Km_O2": 0.5,
                    "Km_DOC": 2.0
                }
            },
            "3": {
                "_name": "aerobe_decay",
                "CONSUMED": "X_aer",
                "PRODUCED": "DOC",
                "KINETICS": [
                    "k_decay * X_aer",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_decay"
                ],
                "PARAMETER_VALUES": {
                    "k_decay": 0.1
                }
            },
            "4": {
                "_name": "reaeration",
                "_description": "Gas exchange with atmosphere",
                "CONSUMED": "ATMOSPHERE",
                "PRODUCED": "DO",
                "KINETICS": [
                    "k_reaer * (DO_sat - DO)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_reaer",
                    "DO_sat"
                ],
                "PARAMETER_VALUES": {
                    "k_reaer": 2.0,
                    "DO_sat": 9.0
                }
            }
        }
    }
}