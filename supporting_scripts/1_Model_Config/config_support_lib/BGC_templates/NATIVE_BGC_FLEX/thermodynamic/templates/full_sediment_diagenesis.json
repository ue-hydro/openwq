{
    "_DESCRIPTION": "Complete Sediment Diagenesis Model with Full Redox Cascade",
    "_REFERENCE": "Van Cappellen & Wang (1996); Boudreau (1997); Regnier et al. (2011)",
    "_PURPOSE": "Comprehensive model for sediment biogeochemistry with thermodynamic control",
    "_VERSION": "1.0",
    "MODULE_NAME": "NATIVE_BGC_FLEX",
    "CHEMICAL_SPECIES": {
        "LIST": {
            "1": "DO",
            "2": "NO3-N",
            "3": "Mn_IV",
            "4": "Fe_III",
            "5": "SO4-S",
            "6": "DOC",
            "7": "POC",
            "8": "NH4-N",
            "9": "Mn_II",
            "10": "Fe_II",
            "11": "H2S",
            "12": "CH4",
            "13": "CO2",
            "14": "N2_loss",
            "15": "FeS"
        },
        "BGC_GENERAL_MOBILE_SPECIES": [
            "DO",
            "NO3-N",
            "SO4-S",
            "DOC",
            "NH4-N",
            "Mn_II",
            "Fe_II",
            "H2S",
            "CH4",
            "CO2"
        ],
        "_LIST_DESCRIPTIONS": {
            "DO": "Dissolved oxygen",
            "NO3-N": "Nitrate nitrogen",
            "Mn_IV": "Manganese(IV) oxide (oxidized)",
            "Fe_III": "Iron(III) oxide/hydroxide (oxidized)",
            "SO4-S": "Sulfate sulfur",
            "DOC": "Dissolved organic carbon",
            "POC": "Particulate organic carbon",
            "NH4-N": "Ammonium nitrogen",
            "Mn_II": "Dissolved manganese(II) (reduced)",
            "Fe_II": "Dissolved iron(II) (reduced)",
            "H2S": "Dissolved hydrogen sulfide",
            "CH4": "Dissolved methane",
            "CO2": "Dissolved carbon dioxide",
            "N2_loss": "Dinitrogen gas loss (denitrification product)",
            "FeS": "Iron sulfide precipitate"
        }
    },
    "CYCLING_FRAMEWORKS": {
        "SEDIMENT_DIAGENESIS": {
            "LIST_TRANSFORMATIONS": {
                "1": "poc_hydrolysis",
                "2": "aerobic_respiration",
                "3": "denitrification",
                "4": "mn_reduction",
                "5": "fe_reduction",
                "6": "sulfate_reduction",
                "7": "methanogenesis",
                "8": "mn_oxidation",
                "9": "fe_oxidation",
                "10": "sulfide_oxidation",
                "11": "methane_oxidation",
                "12": "fes_precipitation",
                "13": "fes_oxidation"
            },
            "_REDOX_LADDER": {
                "1_O2": {
                    "deltaG0": -125,
                    "process": "aerobic_respiration"
                },
                "2_NO3-N": {
                    "deltaG0": -119,
                    "process": "denitrification"
                },
                "3_Mn_IV": {
                    "deltaG0": -95,
                    "process": "mn_reduction"
                },
                "4_Fe_III": {
                    "deltaG0": -50,
                    "process": "fe_reduction"
                },
                "5_SO4-S": {
                    "deltaG0": -25,
                    "process": "sulfate_reduction"
                },
                "6_CO2": {
                    "deltaG0": -20,
                    "process": "methanogenesis"
                }
            },
            "1": {
                "_name": "poc_hydrolysis",
                "_description": "Enzymatic breakdown of POC to DOC",
                "CONSUMED": "POC",
                "PRODUCED": "DOC",
                "KINETICS": [
                    "k_hyd * POC * 1.05^(T-20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_hyd"
                ],
                "PARAMETER_VALUES": {
                    "k_hyd": 0.01
                }
            },
            "2": {
                "_name": "aerobic_respiration",
                "_reaction": "CH2O + O2 -> CO2 + H2O",
                "_deltaG0": -125,
                "CONSUMED": "DO",
                "PRODUCED": "CO2",
                "KINETICS": [
                    "k_aer * (DO/(Km_O2+DO)) * (DOC/(Km_DOC+DOC)) * (1 - exp(-((125-45)/(2*0.008314*(T+273)))))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_aer",
                    "Km_O2",
                    "Km_DOC"
                ],
                "PARAMETER_VALUES": {
                    "k_aer": 50.0,
                    "Km_O2": 0.02,
                    "Km_DOC": 1.0
                }
            },
            "3": {
                "_name": "denitrification",
                "_reaction": "5 CH2O + 4 NO3-N- -> 5 CO2 + 2 N2 + 4 OH-",
                "_deltaG0": -119,
                "CONSUMED": "NO3-N",
                "PRODUCED": "N2_loss",
                "KINETICS": [
                    "k_denit * (NO3-N/(Km_NO3-N+NO3-N)) * (DOC/(Km_DOC+DOC)) * (Ki_O2/(Ki_O2+DO)) * (1 - exp(-((119-45)/(2*0.008314*(T+273)))))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_denit",
                    "Km_NO3-N",
                    "Km_DOC",
                    "Ki_O2"
                ],
                "PARAMETER_VALUES": {
                    "k_denit": 30.0,
                    "Km_NO3-N": 0.01,
                    "Km_DOC": 1.0,
                    "Ki_O2": 0.02
                }
            },
            "4": {
                "_name": "mn_reduction",
                "_reaction": "CH2O + 2 MnO2 + 4 H+ -> CO2 + 2 Mn2+ + 3 H2O",
                "_deltaG0": -95,
                "CONSUMED": "Mn_IV",
                "PRODUCED": "Mn_II",
                "KINETICS": [
                    "k_mn * (Mn_IV/(Km_Mn4+Mn_IV)) * (DOC/(Km_DOC+DOC)) * (Ki_O2/(Ki_O2+DO)) * (Ki_NO3-N/(Ki_NO3-N+NO3-N)) * (1 - exp(-((95-45)/(2*0.008314*(T+273)))))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_mn",
                    "Km_Mn4",
                    "Km_DOC",
                    "Ki_O2",
                    "Ki_NO3-N"
                ],
                "PARAMETER_VALUES": {
                    "k_mn": 20.0,
                    "Km_Mn4": 1.0,
                    "Km_DOC": 1.0,
                    "Ki_O2": 0.02,
                    "Ki_NO3-N": 0.01
                }
            },
            "5": {
                "_name": "fe_reduction",
                "_reaction": "CH2O + 4 Fe(OH)3 + 8 H+ -> CO2 + 4 Fe2+ + 11 H2O",
                "_deltaG0": -50,
                "CONSUMED": "Fe_III",
                "PRODUCED": "Fe_II",
                "KINETICS": [
                    "k_fe * (Fe_III/(Km_Fe3+Fe_III)) * (DOC/(Km_DOC+DOC)) * (Ki_O2/(Ki_O2+DO)) * (Ki_NO3-N/(Ki_NO3-N+NO3-N)) * (1 - exp(-((50-45)/(2*0.008314*(T+273)))))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_fe",
                    "Km_Fe3",
                    "Km_DOC",
                    "Ki_O2",
                    "Ki_NO3-N"
                ],
                "PARAMETER_VALUES": {
                    "k_fe": 10.0,
                    "Km_Fe3": 5.0,
                    "Km_DOC": 1.0,
                    "Ki_O2": 0.02,
                    "Ki_NO3-N": 0.01
                },
                "_notes": "F_T \u2248 0.64 at standard conditions - moderately thermodynamically limited"
            },
            "6": {
                "_name": "sulfate_reduction",
                "_reaction": "2 CH2O + SO4-S-- -> 2 CO2 + H2S + 2 OH-",
                "_deltaG0": -25,
                "CONSUMED": "SO4-S",
                "PRODUCED": "H2S",
                "KINETICS": [
                    "k_so4 * (SO4-S/(Km_SO4-S+SO4-S)) * (DOC/(Km_DOC+DOC)) * (Ki_O2/(Ki_O2+DO)) * (Ki_NO3-N/(Ki_NO3-N+NO3-N)) * (Ki_Fe3/(Ki_Fe3+Fe_III)) * max(0, (1 - exp(-(max(0, 25 - 20 + 10*log10(max(0.001,DOC)/(max(0.001,H2S)+0.001)))/(2*0.008314*(T+273))))))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_so4",
                    "Km_SO4-S",
                    "Km_DOC",
                    "Ki_O2",
                    "Ki_NO3-N",
                    "Ki_Fe3"
                ],
                "PARAMETER_VALUES": {
                    "k_so4": 5.0,
                    "Km_SO4-S": 1.0,
                    "Km_DOC": 1.0,
                    "Ki_O2": 0.02,
                    "Ki_NO3-N": 0.01,
                    "Ki_Fe3": 1.0
                }
            },
            "7": {
                "_name": "methanogenesis",
                "_reaction": "2 CH2O -> CH4 + CO2",
                "_deltaG0": -20,
                "CONSUMED": "DOC",
                "PRODUCED": "CH4",
                "KINETICS": [
                    "k_meth * (DOC/(Km_DOC_meth+DOC)) * (Ki_O2_m/(Ki_O2_m+DO)) * (Ki_NO3-N_m/(Ki_NO3-N_m+NO3-N)) * (Ki_SO4-S/(Ki_SO4-S+SO4-S)) * max(0, (1 - exp(-(max(0, 20 - 11 + 8*log10(max(0.001,DOC)/(max(0.001,CH4)+0.001)))/(2*0.008314*(T+273))))))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_meth",
                    "Km_DOC_meth",
                    "Ki_O2_m",
                    "Ki_NO3-N_m",
                    "Ki_SO4-S"
                ],
                "PARAMETER_VALUES": {
                    "k_meth": 1.0,
                    "Km_DOC_meth": 2.0,
                    "Ki_O2_m": 0.01,
                    "Ki_NO3-N_m": 0.01,
                    "Ki_SO4-S": 0.5
                }
            },
            "8": {
                "_name": "mn_oxidation",
                "_description": "Abiotic Mn(II) oxidation by O2",
                "CONSUMED": "Mn_II",
                "PRODUCED": "Mn_IV",
                "KINETICS": [
                    "k_mnox * Mn_II * DO",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_mnox"
                ],
                "PARAMETER_VALUES": {
                    "k_mnox": 10.0
                }
            },
            "9": {
                "_name": "fe_oxidation",
                "_description": "Abiotic Fe(II) oxidation by O2",
                "CONSUMED": "Fe_II",
                "PRODUCED": "Fe_III",
                "KINETICS": [
                    "k_feox * Fe_II * DO",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_feox"
                ],
                "PARAMETER_VALUES": {
                    "k_feox": 100.0
                }
            },
            "10": {
                "_name": "sulfide_oxidation",
                "_description": "Chemical and biological H2S oxidation",
                "CONSUMED": "H2S",
                "PRODUCED": "SO4-S",
                "KINETICS": [
                    "k_sox * H2S * DO",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_sox"
                ],
                "PARAMETER_VALUES": {
                    "k_sox": 50.0
                }
            },
            "11": {
                "_name": "methane_oxidation",
                "_description": "Aerobic methane oxidation",
                "CONSUMED": "CH4",
                "PRODUCED": "CO2",
                "KINETICS": [
                    "k_mox * CH4 * (DO/(Km_O2_mox+DO))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_mox",
                    "Km_O2_mox"
                ],
                "PARAMETER_VALUES": {
                    "k_mox": 20.0,
                    "Km_O2_mox": 0.1
                }
            },
            "12": {
                "_name": "fes_precipitation",
                "_description": "Iron sulfide mineral formation",
                "CONSUMED": "Fe_II",
                "PRODUCED": "FeS",
                "KINETICS": [
                    "k_fes * Fe_II * H2S",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_fes"
                ],
                "PARAMETER_VALUES": {
                    "k_fes": 100.0
                }
            },
            "13": {
                "_name": "fes_oxidation",
                "_description": "FeS oxidation when O2 present",
                "CONSUMED": "FeS",
                "PRODUCED": "Fe_III",
                "KINETICS": [
                    "k_fesox * FeS * DO",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_fesox"
                ],
                "PARAMETER_VALUES": {
                    "k_fesox": 10.0
                }
            }
        }
    },
    "_EXPECTED_BEHAVIOR": {
        "OXIC_LAYER": "O2 > 0.1 mg/L: Aerobic respiration dominates",
        "SUBOXIC_LAYER": "O2 depleted: Denitrification, Mn and Fe reduction",
        "ANOXIC_LAYER": "All metal oxides depleted: Sulfate reduction",
        "METHANOGENIC_LAYER": "SO4-S depleted: Methanogenesis"
    }
}