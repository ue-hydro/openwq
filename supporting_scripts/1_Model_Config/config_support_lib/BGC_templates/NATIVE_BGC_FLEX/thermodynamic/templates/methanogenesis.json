{
    "_DESCRIPTION": "Methanogenesis with Thermodynamic Control",
    "_REFERENCE": "Jin & Bethke (2007); Conrad (1999)",
    "_PATHWAYS": {
        "ACETOCLASTIC": "CH3COOH -> CH4 + CO2 (\u0394G\u00b0 = -31 kJ/mol)",
        "HYDROGENOTROPHIC": "4 H2 + CO2 -> CH4 + 2 H2O (\u0394G\u00b0 = -131 kJ/mol at standard, but H2 is limiting)"
    },
    "_DELTA_G0": "-20 kJ/mol e- (lowest in redox ladder - most thermodynamically constrained)",
    "MODULE_NAME": "NATIVE_BGC_FLEX",
    "CHEMICAL_SPECIES": {
        "LIST": {
            "1": "DOC",
            "2": "CH4",
            "3": "CO2",
            "4": "DO",
            "5": "NO3-N",
            "6": "SO4-S",
            "7": "X_meth"
        },
        "BGC_GENERAL_MOBILE_SPECIES": [
            "DOC",
            "CH4",
            "CO2"
        ],
        "_LIST_DESCRIPTIONS": {
            "DOC": "Dissolved organic carbon",
            "CH4": "Dissolved methane",
            "CO2": "Dissolved carbon dioxide",
            "DO": "Dissolved oxygen",
            "NO3-N": "Nitrate nitrogen",
            "SO4-S": "Sulfate sulfur",
            "X_meth": "Methanogen biomass"
        }
    },
    "CYCLING_FRAMEWORKS": {
        "METHANOGENESIS_THERMO": {
            "LIST_TRANSFORMATIONS": {
                "1": "acetoclastic_methanogenesis",
                "2": "methanogen_growth",
                "3": "methanogen_decay",
                "4": "methane_oxidation",
                "5": "methane_ebullition"
            },
            "_THERMODYNAMIC_CONSTANTS": {
                "deltaG0_acetoclastic": -31.0,
                "deltaG0_per_electron": -20.0,
                "deltaG_min": 10.6,
                "chi": 2,
                "R_kJ": 0.008314,
                "NOTES": [
                    "Methanogenesis has the lowest \u0394G\u00b0 in the redox ladder",
                    "Only proceeds when all other electron acceptors depleted",
                    "Very sensitive to H2S accumulation (sulfate reducers compete)",
                    "\u0394G_min for methanogens is lower (~10-15 kJ/mol) than other microbes"
                ]
            },
            "1": {
                "_name": "acetoclastic_methanogenesis",
                "_description": "Acetate fermentation to CH4 and CO2",
                "_reaction": "CH3COOH -> CH4 + CO2",
                "CONSUMED": "DOC",
                "PRODUCED": "CH4",
                "KINETICS": [
                    "k_meth * X_meth * (DOC/(Km_doc+DOC)) * (Ki_O2/(Ki_O2+DO)) * (Ki_NO3N/(Ki_NO3N+NO3-N)) * (Ki_SO4S/(Ki_SO4S+SO4-S)) * max(0, (1 - exp(-(max(0, 31 + 15*log10(max(0.001,(DOC/12)/(CH4/16+0.001)))) - 11)/(2*0.008314*(T+273)))))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_meth",
                    "Km_doc",
                    "Ki_O2",
                    "Ki_NO3N",
                    "Ki_SO4S"
                ],
                "PARAMETER_VALUES": {
                    "k_meth": 3.0,
                    "Km_doc": 5.0,
                    "Ki_O2": 0.05,
                    "Ki_NO3N": 0.1,
                    "Ki_SO4S": 1.0
                },
                "_notes": [
                    "Triple inhibition: O2, NO3-N, and SO4-S all suppress methanogenesis",
                    "Lower \u0394G_min (11 kJ/mol) reflects methanogen physiology",
                    "Slow rate constant reflects slow growth of methanogens"
                ]
            },
            "2": {
                "_name": "methanogen_growth",
                "CONSUMED": "DOC",
                "PRODUCED": "X_meth",
                "KINETICS": [
                    "Y_meth * k_meth * X_meth * (DOC/(Km_doc+DOC)) * (Ki_O2/(Ki_O2+DO)) * (Ki_NO3N/(Ki_NO3N+NO3-N)) * (Ki_SO4S/(Ki_SO4S+SO4-S)) * max(0, (1 - exp(-(max(0, 31 + 15*log10(max(0.001,(DOC/12)/(CH4/16+0.001)))) - 11)/(2*0.008314*(T+273)))))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "Y_meth",
                    "k_meth",
                    "Km_doc",
                    "Ki_O2",
                    "Ki_NO3N",
                    "Ki_SO4S"
                ],
                "PARAMETER_VALUES": {
                    "Y_meth": 0.1,
                    "k_meth": 3.0,
                    "Km_doc": 5.0,
                    "Ki_O2": 0.05,
                    "Ki_NO3N": 0.1,
                    "Ki_SO4S": 1.0
                },
                "_notes": "Low yield reflects low energy gain from methanogenesis"
            },
            "3": {
                "_name": "methanogen_decay",
                "CONSUMED": "X_meth",
                "PRODUCED": "DOC",
                "KINETICS": [
                    "k_decay * X_meth",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_decay"
                ],
                "PARAMETER_VALUES": {
                    "k_decay": 0.02
                }
            },
            "4": {
                "_name": "methane_oxidation",
                "_description": "Aerobic methane oxidation when O2 available",
                "CONSUMED": "CH4",
                "PRODUCED": "CO2",
                "KINETICS": [
                    "k_mox * CH4 * (DO/(Km_O2_mox+DO))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_mox",
                    "Km_O2_mox"
                ],
                "PARAMETER_VALUES": {
                    "k_mox": 10.0,
                    "Km_O2_mox": 0.5
                }
            },
            "5": {
                "_name": "methane_ebullition",
                "_description": "Bubble loss when CH4 exceeds saturation",
                "CONSUMED": "CH4",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_ebull * max(0, CH4 - ch4_sat)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_ebull",
                    "ch4_sat"
                ],
                "PARAMETER_VALUES": {
                    "k_ebull": 1.0,
                    "ch4_sat": 20.0
                }
            }
        }
    }
}