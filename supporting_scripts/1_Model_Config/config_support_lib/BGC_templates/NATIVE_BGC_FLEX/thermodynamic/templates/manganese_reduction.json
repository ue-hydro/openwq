{
    "_DESCRIPTION": "Manganese Reduction with Thermodynamic Control",
    "_REFERENCE": "Jin & Bethke (2007); Thamdrup (2000)",
    "_REACTION": "CH2O + 2 MnO2 + 4 H+ -> CO2 + 2 Mn2+ + 3 H2O",
    "_DELTA_G0": "-95 kJ/mol e- (between NO3-N and Fe(III) in redox ladder)",
    "MODULE_NAME": "NATIVE_BGC_FLEX",
    "CHEMICAL_SPECIES": {
        "LIST": {
            "1": "Mn_IV",
            "2": "Mn_II",
            "3": "DOC",
            "4": "DO",
            "5": "NO3-N",
            "6": "X_mrb"
        },
        "BGC_GENERAL_MOBILE_SPECIES": [
            "Mn_II",
            "DOC"
        ],
        "_LIST_DESCRIPTIONS": {
            "Mn_IV": "Manganese(IV) oxide (oxidized)",
            "Mn_II": "Dissolved manganese(II) (reduced)",
            "DOC": "Dissolved organic carbon",
            "DO": "Dissolved oxygen",
            "NO3-N": "Nitrate nitrogen",
            "X_mrb": "Manganese-reducing bacteria biomass"
        }
    },
    "CYCLING_FRAMEWORKS": {
        "MANGANESE_REDUCTION_THERMO": {
            "LIST_TRANSFORMATIONS": {
                "1": "manganese_reduction",
                "2": "mrb_growth",
                "3": "mrb_decay",
                "4": "manganese_oxidation"
            },
            "_THERMODYNAMIC_CONSTANTS": {
                "deltaG0": -95.0,
                "deltaG_ATP": 45.0,
                "chi": 2,
                "R_kJ": 0.008314,
                "NOTES": [
                    "Mn(IV) reduction is energetically favorable (\u0394G\u00b0 = -95)",
                    "Proceeds after O2 and NO3-N depletion",
                    "Often limited by Mn oxide availability (solid phase)",
                    "Important in coastal/marine sediments"
                ]
            },
            "1": {
                "_name": "manganese_reduction",
                "_description": "Dissimilatory Mn(IV) reduction to Mn(II)",
                "CONSUMED": "Mn_IV",
                "PRODUCED": "Mn_II",
                "KINETICS": [
                    "k_mrb * X_mrb * (Mn_IV/(Km_Mn4+Mn_IV)) * (DOC/(Km_doc+DOC)) * (Ki_O2/(Ki_O2+DO)) * (Ki_NO3N/(Ki_NO3N+NO3-N)) * (1 - exp(-((95-45)/(2*0.008314*(T+273)))))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_mrb",
                    "Km_Mn4",
                    "Km_doc",
                    "Ki_O2",
                    "Ki_NO3N"
                ],
                "PARAMETER_VALUES": {
                    "k_mrb": 12.0,
                    "Km_Mn4": 5.0,
                    "Km_doc": 2.0,
                    "Ki_O2": 0.2,
                    "Ki_NO3N": 0.3
                },
                "_notes": [
                    "F_T = 1 - exp(-50/(2*0.008314*293)) = 1 - exp(-10.3) \u2248 1.0",
                    "Mn reduction is thermodynamically favorable",
                    "Usually limited by Mn oxide availability, not thermodynamics"
                ]
            },
            "2": {
                "_name": "mrb_growth",
                "CONSUMED": "DOC",
                "PRODUCED": "X_mrb",
                "KINETICS": [
                    "Y_mrb * k_mrb * X_mrb * (Mn_IV/(Km_Mn4+Mn_IV)) * (DOC/(Km_doc+DOC)) * (Ki_O2/(Ki_O2+DO)) * (Ki_NO3N/(Ki_NO3N+NO3-N)) * (1 - exp(-((95-45)/(2*0.008314*(T+273)))))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "Y_mrb",
                    "k_mrb",
                    "Km_Mn4",
                    "Km_doc",
                    "Ki_O2",
                    "Ki_NO3N"
                ],
                "PARAMETER_VALUES": {
                    "Y_mrb": 0.3,
                    "k_mrb": 12.0,
                    "Km_Mn4": 5.0,
                    "Km_doc": 2.0,
                    "Ki_O2": 0.2,
                    "Ki_NO3N": 0.3
                }
            },
            "3": {
                "_name": "mrb_decay",
                "CONSUMED": "X_mrb",
                "PRODUCED": "DOC",
                "KINETICS": [
                    "k_decay * X_mrb",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_decay"
                ],
                "PARAMETER_VALUES": {
                    "k_decay": 0.05
                }
            },
            "4": {
                "_name": "manganese_oxidation",
                "_description": "Abiotic/biotic Mn(II) oxidation by O2",
                "CONSUMED": "Mn_II",
                "PRODUCED": "Mn_IV",
                "KINETICS": [
                    "k_mnox * Mn_II * DO",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_mnox"
                ],
                "PARAMETER_VALUES": {
                    "k_mnox": 10.0
                },
                "_notes": "Slower than Fe oxidation, often microbially mediated"
            }
        }
    }
}