{
    "_DESCRIPTION": "Organic Carbon Cycle - DOC/POC dynamics with microbial processing",
    "_REFERENCE": "WASP8, Wetzel (2001) Limnology",
    "_VERSION": "1.0",
    "CHEMICAL_SPECIES": {
        "LIST": {
            "1": "DOC_labile",
            "2": "DOC_refrac",
            "3": "POC_labile",
            "4": "POC_refrac",
            "5": "DIC",
            "6": "CH4",
            "7": "DO",
            "8": "ALGAE_C"
        },
        "BGC_GENERAL_MOBILE_SPECIES": [
            "DOC_labile",
            "DOC_refrac",
            "POC_labile",
            "POC_refrac",
            "DIC",
            "CH4",
            "DO",
            "ALGAE_C"
        ],
        "_LIST_DESCRIPTIONS": {
            "DOC_labile": "Labile dissolved organic carbon",
            "DOC_refrac": "Refractory dissolved organic carbon",
            "POC_labile": "Labile particulate organic carbon",
            "POC_refrac": "Refractory particulate organic carbon",
            "DIC": "Dissolved inorganic carbon (CO2 + HCO3 + CO3)",
            "CH4": "Methane (dissolved)",
            "DO": "Dissolved oxygen",
            "ALGAE_C": "Algal carbon biomass"
        }
    },
    "CYCLING_FRAMEWORKS": {
        "CARBON_CYCLE": {
            "_DESCRIPTION": "Complete organic carbon cycling",
            "LIST_TRANSFORMATIONS": {
                "1": "POC_LABILE_HYDROLYSIS",
                "2": "POC_REFRAC_HYDROLYSIS",
                "3": "DOC_LABILE_RESPIRATION",
                "4": "DOC_REFRAC_RESPIRATION",
                "5": "RESPIRATION_O2_CONSUMPTION",
                "6": "METHANOGENESIS",
                "7": "METHANE_OXIDATION",
                "8": "METHANE_EBULLITION",
                "9": "PHOTOSYNTHESIS",
                "10": "ALGAL_RESPIRATION",
                "11": "ALGAL_DEATH",
                "12": "POC_SETTLING",
                "13": "POC_REFRAC_SETTLING",
                "14": "CO2_EXCHANGE"
            },
            "1": {
                "_NAME": "POC_LABILE_HYDROLYSIS",
                "CONSUMED": "POC_labile",
                "PRODUCED": "DOC_labile",
                "KINETICS": [
                    "k_hydrol_L * POC_labile * 1.05^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_hydrol_L"
                ],
                "PARAMETER_VALUES": {
                    "k_hydrol_L": 0.15
                },
                "_PARAMETERS_INFO": {
                    "k_hydrol_L": {
                        "VALUE": 0.15,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.05,
                            0.5
                        ],
                        "DESCRIPTION": "Labile POC hydrolysis rate"
                    }
                }
            },
            "2": {
                "_NAME": "POC_REFRAC_HYDROLYSIS",
                "CONSUMED": "POC_refrac",
                "PRODUCED": "DOC_refrac",
                "KINETICS": [
                    "k_hydrol_R * POC_refrac * 1.03^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_hydrol_R"
                ],
                "PARAMETER_VALUES": {
                    "k_hydrol_R": 0.01
                },
                "_PARAMETERS_INFO": {
                    "k_hydrol_R": {
                        "VALUE": 0.01,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.001,
                            0.05
                        ],
                        "DESCRIPTION": "Refractory POC hydrolysis rate"
                    }
                }
            },
            "3": {
                "_NAME": "DOC_LABILE_RESPIRATION",
                "CONSUMED": "DOC_labile",
                "PRODUCED": "DIC",
                "KINETICS": [
                    "k_resp_L * DOC_labile * (DO / (K_O2 + DO)) * 1.07^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_resp_L",
                    "K_O2"
                ],
                "PARAMETER_VALUES": {
                    "k_resp_L": 0.2,
                    "K_O2": 0.5
                },
                "_PARAMETERS_INFO": {
                    "k_resp_L": {
                        "VALUE": 0.2,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.1,
                            0.5
                        ],
                        "DESCRIPTION": "Labile DOC respiration rate"
                    },
                    "K_O2": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L",
                        "DESCRIPTION": "Half-saturation O2 for respiration"
                    }
                }
            },
            "4": {
                "_NAME": "DOC_REFRAC_RESPIRATION",
                "CONSUMED": "DOC_refrac",
                "PRODUCED": "DIC",
                "KINETICS": [
                    "k_resp_R * DOC_refrac * (DO / (K_O2 + DO)) * 1.05^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_resp_R",
                    "K_O2"
                ],
                "PARAMETER_VALUES": {
                    "k_resp_R": 0.01,
                    "K_O2": 0.5
                },
                "_PARAMETERS_INFO": {
                    "k_resp_R": {
                        "VALUE": 0.01,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.001,
                            0.05
                        ],
                        "DESCRIPTION": "Refractory DOC respiration rate"
                    },
                    "K_O2": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L"
                    }
                }
            },
            "5": {
                "_NAME": "RESPIRATION_O2_CONSUMPTION",
                "CONSUMED": "DO",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "2.67 * (k_resp_L * DOC_labile + k_resp_R * DOC_refrac) * (DO / (K_O2 + DO)) * 1.07^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_resp_L",
                    "k_resp_R",
                    "K_O2"
                ],
                "PARAMETER_VALUES": {
                    "k_resp_L": 0.2,
                    "k_resp_R": 0.01,
                    "K_O2": 0.5
                },
                "_NOTES": "Stoichiometry: 2.67 mg O2 per mg C respired (C6H12O6 + 6O2 -> 6CO2 + 6H2O)",
                "_PARAMETERS_INFO": {
                    "k_resp_L": {
                        "VALUE": 0.2,
                        "UNITS": "1/day"
                    },
                    "k_resp_R": {
                        "VALUE": 0.01,
                        "UNITS": "1/day"
                    },
                    "K_O2": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L"
                    }
                }
            },
            "6": {
                "_NAME": "METHANOGENESIS",
                "CONSUMED": "DOC_labile",
                "PRODUCED": "CH4",
                "KINETICS": [
                    "k_meth * DOC_labile * (K_O2_inhib / (K_O2_inhib + DO)) * 1.10^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_meth",
                    "K_O2_inhib"
                ],
                "PARAMETER_VALUES": {
                    "k_meth": 0.05,
                    "K_O2_inhib": 0.2
                },
                "_NOTES": "Strictly anaerobic process",
                "_PARAMETERS_INFO": {
                    "k_meth": {
                        "VALUE": 0.05,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.01,
                            0.2
                        ],
                        "DESCRIPTION": "Methanogenesis rate"
                    },
                    "K_O2_inhib": {
                        "VALUE": 0.2,
                        "UNITS": "mg/L",
                        "DESCRIPTION": "O2 inhibition for methanogenesis"
                    }
                }
            },
            "7": {
                "_NAME": "METHANE_OXIDATION",
                "CONSUMED": "CH4",
                "PRODUCED": "DIC",
                "KINETICS": [
                    "k_CH4_ox * CH4 * (DO / (K_O2_CH4 + DO)) * 1.08^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_CH4_ox",
                    "K_O2_CH4"
                ],
                "PARAMETER_VALUES": {
                    "k_CH4_ox": 0.5,
                    "K_O2_CH4": 0.5
                },
                "_PARAMETERS_INFO": {
                    "k_CH4_ox": {
                        "VALUE": 0.5,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.1,
                            2.0
                        ],
                        "DESCRIPTION": "Methane oxidation rate"
                    },
                    "K_O2_CH4": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L"
                    }
                }
            },
            "8": {
                "_NAME": "METHANE_EBULLITION",
                "CONSUMED": "CH4",
                "PRODUCED": "CH4_atm_loss",
                "KINETICS": [
                    "k_ebull * max(0, CH4 - CH4_sat)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_ebull",
                    "CH4_sat"
                ],
                "PARAMETER_VALUES": {
                    "k_ebull": 10.0,
                    "CH4_sat": 0.02
                },
                "_PARAMETERS_INFO": {
                    "k_ebull": {
                        "VALUE": 10.0,
                        "UNITS": "1/day",
                        "DESCRIPTION": "Ebullition rate when supersaturated"
                    },
                    "CH4_sat": {
                        "VALUE": 0.02,
                        "UNITS": "mg/L",
                        "DESCRIPTION": "CH4 saturation concentration"
                    }
                }
            },
            "9": {
                "_NAME": "PHOTOSYNTHESIS",
                "CONSUMED": "DIC",
                "PRODUCED": "ALGAE_C",
                "KINETICS": [
                    "mu_max * ALGAE_C * (DIC / (K_DIC + DIC)) * f_light * f_nutrient * 1.066^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "mu_max",
                    "K_DIC",
                    "f_light",
                    "f_nutrient"
                ],
                "PARAMETER_VALUES": {
                    "mu_max": 2.0,
                    "K_DIC": 1.0,
                    "f_light": 0.5,
                    "f_nutrient": 0.8
                },
                "_PARAMETERS_INFO": {
                    "mu_max": {
                        "VALUE": 2.0,
                        "UNITS": "1/day",
                        "DESCRIPTION": "Maximum algal growth rate"
                    },
                    "K_DIC": {
                        "VALUE": 1.0,
                        "UNITS": "mg/L",
                        "DESCRIPTION": "Half-saturation for DIC uptake"
                    },
                    "f_light": {
                        "VALUE": 0.5,
                        "DESCRIPTION": "Light limitation"
                    },
                    "f_nutrient": {
                        "VALUE": 0.8,
                        "DESCRIPTION": "Nutrient limitation"
                    }
                }
            },
            "10": {
                "_NAME": "ALGAL_RESPIRATION",
                "CONSUMED": "ALGAE_C",
                "PRODUCED": "DOC_labile",
                "KINETICS": [
                    "k_resp_A * ALGAE_C * 1.08^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_resp_A"
                ],
                "PARAMETER_VALUES": {
                    "k_resp_A": 0.1
                },
                "_PARAMETERS_INFO": {
                    "k_resp_A": {
                        "VALUE": 0.1,
                        "UNITS": "1/day",
                        "DESCRIPTION": "Algal respiration rate"
                    }
                }
            },
            "11": {
                "_NAME": "ALGAL_DEATH",
                "CONSUMED": "ALGAE_C",
                "PRODUCED": "POC_labile",
                "KINETICS": [
                    "k_death * ALGAE_C",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_death"
                ],
                "PARAMETER_VALUES": {
                    "k_death": 0.05
                },
                "_PARAMETERS_INFO": {
                    "k_death": {
                        "VALUE": 0.05,
                        "UNITS": "1/day",
                        "DESCRIPTION": "Algal death rate"
                    }
                }
            },
            "12": {
                "_NAME": "POC_SETTLING",
                "CONSUMED": "POC_labile",
                "PRODUCED": "SED_C_loss",
                "KINETICS": [
                    "v_s / depth * POC_labile",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "v_s",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "v_s": 0.5,
                    "depth": 2.0
                },
                "_PARAMETERS_INFO": {
                    "v_s": {
                        "VALUE": 0.5,
                        "UNITS": "m/day",
                        "DESCRIPTION": "POC settling velocity"
                    },
                    "depth": {
                        "VALUE": 2.0,
                        "UNITS": "m"
                    }
                }
            },
            "13": {
                "_NAME": "POC_REFRAC_SETTLING",
                "CONSUMED": "POC_refrac",
                "PRODUCED": "SED_C_loss",
                "KINETICS": [
                    "v_s / depth * POC_refrac",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "v_s",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "v_s": 0.5,
                    "depth": 2.0
                },
                "_PARAMETERS_INFO": {
                    "v_s": {
                        "VALUE": 0.5,
                        "UNITS": "m/day"
                    },
                    "depth": {
                        "VALUE": 2.0,
                        "UNITS": "m"
                    }
                }
            },
            "14": {
                "_NAME": "CO2_EXCHANGE",
                "CONSUMED": "DIC",
                "PRODUCED": "CO2_atm",
                "KINETICS": [
                    "k_CO2 * (DIC * f_CO2 - CO2_sat)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_CO2",
                    "f_CO2",
                    "CO2_sat"
                ],
                "PARAMETER_VALUES": {
                    "k_CO2": 0.5,
                    "f_CO2": 0.01,
                    "CO2_sat": 0.5
                },
                "_NOTES": "Net flux can be positive (evasion) or negative (invasion)",
                "_PARAMETERS_INFO": {
                    "k_CO2": {
                        "VALUE": 0.5,
                        "UNITS": "1/day",
                        "DESCRIPTION": "CO2 gas exchange coefficient"
                    },
                    "f_CO2": {
                        "VALUE": 0.01,
                        "DESCRIPTION": "Fraction of DIC as free CO2"
                    },
                    "CO2_sat": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L",
                        "DESCRIPTION": "Atmospheric CO2 equilibrium"
                    }
                }
            }
        }
    },
    "_COMPARTMENT_ASSIGNMENT": {
        "LAKE": [
            "CARBON_CYCLE"
        ],
        "WETLAND": [
            "CARBON_CYCLE"
        ],
        "RIVER": [
            "CARBON_CYCLE"
        ]
    }
}