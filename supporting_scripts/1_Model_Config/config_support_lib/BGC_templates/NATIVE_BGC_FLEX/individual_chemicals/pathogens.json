{
    "_DESCRIPTION": "Pathogen Fate and Transport - E. coli, fecal coliforms, viruses",
    "_REFERENCE": "WASP, Chapra (2008), Thomann & Mueller (1987)",
    "_VERSION": "1.0",
    "CHEMICAL_SPECIES": {
        "LIST": {
            "1": "E_coli",
            "2": "Fecal_coliform",
            "3": "Enterococci",
            "4": "Total_coliform",
            "5": "Virus",
            "6": "Cryptosporidium",
            "7": "Giardia"
        },
        "BGC_GENERAL_MOBILE_SPECIES": [
            "E_coli",
            "Fecal_coliform",
            "Enterococci",
            "Total_coliform",
            "Virus",
            "Cryptosporidium",
            "Giardia"
        ],
        "_LIST_DESCRIPTIONS": {
            "E_coli": "Escherichia coli",
            "Fecal_coliform": "Fecal coliform bacteria",
            "Enterococci": "Enterococcus bacteria",
            "Total_coliform": "Total coliform bacteria",
            "Virus": "Enteric viruses",
            "Cryptosporidium": "Cryptosporidium oocysts",
            "Giardia": "Giardia cysts"
        }
    },
    "CYCLING_FRAMEWORKS": {
        "ECOLI_DYNAMICS": {
            "_DESCRIPTION": "E. coli die-off with multiple stressors",
            "LIST_TRANSFORMATIONS": {
                "1": "ECOLI_DIEOFF_BASE",
                "2": "ECOLI_SOLAR_INACTIVATION",
                "3": "ECOLI_SETTLING",
                "4": "ECOLI_RESUSPENSION"
            },
            "1": {
                "_NAME": "ECOLI_DIEOFF_BASE",
                "CONSUMED": "E_coli",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_die_base * E_coli * theta^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_die_base",
                    "theta"
                ],
                "PARAMETER_VALUES": {
                    "k_die_base": 1.0,
                    "theta": 1.07
                },
                "_PARAMETERS_INFO": {
                    "k_die_base": {
                        "VALUE": 1.0,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.2,
                            5.0
                        ],
                        "DESCRIPTION": "Base die-off rate at 20C in dark"
                    },
                    "theta": {
                        "VALUE": 1.07,
                        "RANGE": [
                            1.04,
                            1.1
                        ],
                        "DESCRIPTION": "Temperature coefficient"
                    }
                }
            },
            "2": {
                "_NAME": "ECOLI_SOLAR_INACTIVATION",
                "CONSUMED": "E_coli",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_solar * I_avg * E_coli",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_solar",
                    "I_avg"
                ],
                "PARAMETER_VALUES": {
                    "k_solar": 0.02,
                    "I_avg": 200
                },
                "_NOTES": "UV-B is primary inactivator; attenuated by turbidity",
                "_PARAMETERS_INFO": {
                    "k_solar": {
                        "VALUE": 0.02,
                        "UNITS": "m2/W/day",
                        "RANGE": [
                            0.01,
                            0.1
                        ],
                        "DESCRIPTION": "Solar inactivation coefficient"
                    },
                    "I_avg": {
                        "VALUE": 200,
                        "UNITS": "W/m2",
                        "DESCRIPTION": "Average solar irradiance in water"
                    }
                }
            },
            "3": {
                "_NAME": "ECOLI_SETTLING",
                "CONSUMED": "E_coli",
                "PRODUCED": "SED_Ecoli",
                "KINETICS": [
                    "v_s_bact / depth * E_coli",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "v_s_bact",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "v_s_bact": 0.5,
                    "depth": 2.0
                },
                "_PARAMETERS_INFO": {
                    "v_s_bact": {
                        "VALUE": 0.5,
                        "UNITS": "m/day",
                        "RANGE": [
                            0.1,
                            2.0
                        ],
                        "DESCRIPTION": "Bacterial settling velocity"
                    },
                    "depth": {
                        "VALUE": 2.0,
                        "UNITS": "m"
                    }
                }
            },
            "4": {
                "_NAME": "ECOLI_RESUSPENSION",
                "CONSUMED": "NONE",
                "PRODUCED": "E_coli",
                "KINETICS": [
                    "k_resus * SED_Ecoli / depth",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_resus",
                    "SED_Ecoli",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "k_resus": 0.1,
                    "SED_Ecoli": 10000,
                    "depth": 2.0
                },
                "_NOTES": "Flow-dependent; increases during storms",
                "_PARAMETERS_INFO": {
                    "k_resus": {
                        "VALUE": 0.1,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.0,
                            1.0
                        ],
                        "DESCRIPTION": "Resuspension rate from sediments"
                    },
                    "SED_Ecoli": {
                        "VALUE": 10000,
                        "UNITS": "CFU/m2",
                        "DESCRIPTION": "Sediment E. coli concentration"
                    },
                    "depth": {
                        "VALUE": 2.0,
                        "UNITS": "m"
                    }
                }
            }
        },
        "FECAL_COLIFORM_DYNAMICS": {
            "_DESCRIPTION": "Fecal coliform decay",
            "LIST_TRANSFORMATIONS": {
                "1": "FC_DIEOFF",
                "2": "FC_SOLAR",
                "3": "FC_SETTLING"
            },
            "1": {
                "_NAME": "FC_DIEOFF",
                "CONSUMED": "Fecal_coliform",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_die_FC * Fecal_coliform * 1.07^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_die_FC"
                ],
                "PARAMETER_VALUES": {
                    "k_die_FC": 0.8
                },
                "_PARAMETERS_INFO": {
                    "k_die_FC": {
                        "VALUE": 0.8,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.2,
                            3.0
                        ],
                        "DESCRIPTION": "FC die-off rate at 20C"
                    }
                }
            },
            "2": {
                "_NAME": "FC_SOLAR",
                "CONSUMED": "Fecal_coliform",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_solar_FC * I_avg * Fecal_coliform",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_solar_FC",
                    "I_avg"
                ],
                "PARAMETER_VALUES": {
                    "k_solar_FC": 0.015,
                    "I_avg": 200
                },
                "_PARAMETERS_INFO": {
                    "k_solar_FC": {
                        "VALUE": 0.015,
                        "UNITS": "m2/W/day"
                    },
                    "I_avg": {
                        "VALUE": 200,
                        "UNITS": "W/m2"
                    }
                }
            },
            "3": {
                "_NAME": "FC_SETTLING",
                "CONSUMED": "Fecal_coliform",
                "PRODUCED": "SED_FC",
                "KINETICS": [
                    "v_s_bact / depth * Fecal_coliform",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "v_s_bact",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "v_s_bact": 0.5,
                    "depth": 2.0
                },
                "_PARAMETERS_INFO": {
                    "v_s_bact": {
                        "VALUE": 0.5,
                        "UNITS": "m/day"
                    },
                    "depth": {
                        "VALUE": 2.0,
                        "UNITS": "m"
                    }
                }
            }
        },
        "ENTEROCOCCI_DYNAMICS": {
            "_DESCRIPTION": "Enterococcus decay (marine indicator)",
            "LIST_TRANSFORMATIONS": {
                "1": "ENT_DIEOFF",
                "2": "ENT_SOLAR"
            },
            "1": {
                "_NAME": "ENT_DIEOFF",
                "CONSUMED": "Enterococci",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_die_ENT * Enterococci * 1.05^(T - 20) * (1 + 0.1 * salinity)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_die_ENT",
                    "salinity"
                ],
                "PARAMETER_VALUES": {
                    "k_die_ENT": 1.2,
                    "salinity": 0
                },
                "_NOTES": "More resistant than E. coli; primary marine indicator",
                "_PARAMETERS_INFO": {
                    "k_die_ENT": {
                        "VALUE": 1.2,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.5,
                            4.0
                        ],
                        "DESCRIPTION": "Enterococcus die-off rate"
                    },
                    "salinity": {
                        "VALUE": 0,
                        "UNITS": "ppt",
                        "DESCRIPTION": "Salinity (enhances die-off)"
                    }
                }
            },
            "2": {
                "_NAME": "ENT_SOLAR",
                "CONSUMED": "Enterococci",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_solar_ENT * I_avg * Enterococci",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_solar_ENT",
                    "I_avg"
                ],
                "PARAMETER_VALUES": {
                    "k_solar_ENT": 0.03,
                    "I_avg": 200
                },
                "_PARAMETERS_INFO": {
                    "k_solar_ENT": {
                        "VALUE": 0.03,
                        "UNITS": "m2/W/day",
                        "DESCRIPTION": "More sensitive to solar than E. coli"
                    },
                    "I_avg": {
                        "VALUE": 200,
                        "UNITS": "W/m2"
                    }
                }
            }
        },
        "VIRUS_DYNAMICS": {
            "_DESCRIPTION": "Enteric virus persistence",
            "LIST_TRANSFORMATIONS": {
                "1": "VIRUS_INACTIVATION",
                "2": "VIRUS_SOLAR",
                "3": "VIRUS_ADSORPTION"
            },
            "1": {
                "_NAME": "VIRUS_INACTIVATION",
                "CONSUMED": "Virus",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_inact_V * Virus * 1.03^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_inact_V"
                ],
                "PARAMETER_VALUES": {
                    "k_inact_V": 0.3
                },
                "_NOTES": "Viruses more persistent than bacteria",
                "_PARAMETERS_INFO": {
                    "k_inact_V": {
                        "VALUE": 0.3,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.05,
                            1.0
                        ],
                        "DESCRIPTION": "Virus inactivation rate"
                    }
                }
            },
            "2": {
                "_NAME": "VIRUS_SOLAR",
                "CONSUMED": "Virus",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_solar_V * I_avg * Virus",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_solar_V",
                    "I_avg"
                ],
                "PARAMETER_VALUES": {
                    "k_solar_V": 0.01,
                    "I_avg": 200
                },
                "_PARAMETERS_INFO": {
                    "k_solar_V": {
                        "VALUE": 0.01,
                        "UNITS": "m2/W/day",
                        "DESCRIPTION": "Virus UV inactivation"
                    },
                    "I_avg": {
                        "VALUE": 200,
                        "UNITS": "W/m2"
                    }
                }
            },
            "3": {
                "_NAME": "VIRUS_ADSORPTION",
                "CONSUMED": "Virus",
                "PRODUCED": "Virus_part",
                "KINETICS": [
                    "k_ads_V * Virus * TSS / 1000",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_ads_V",
                    "TSS"
                ],
                "PARAMETER_VALUES": {
                    "k_ads_V": 0.1,
                    "TSS": 20
                },
                "_PARAMETERS_INFO": {
                    "k_ads_V": {
                        "VALUE": 0.1,
                        "UNITS": "L/mg/day",
                        "DESCRIPTION": "Virus adsorption to particles"
                    },
                    "TSS": {
                        "VALUE": 20,
                        "UNITS": "mg/L"
                    }
                }
            }
        },
        "PROTOZOA_DYNAMICS": {
            "_DESCRIPTION": "Cryptosporidium and Giardia persistence",
            "LIST_TRANSFORMATIONS": {
                "1": "CRYPTO_INACTIVATION",
                "2": "CRYPTO_SETTLING",
                "3": "GIARDIA_INACTIVATION",
                "4": "GIARDIA_SETTLING"
            },
            "1": {
                "_NAME": "CRYPTO_INACTIVATION",
                "CONSUMED": "Cryptosporidium",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_inact_C * Cryptosporidium * 1.02^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_inact_C"
                ],
                "PARAMETER_VALUES": {
                    "k_inact_C": 0.05
                },
                "_NOTES": "Very persistent in environment",
                "_PARAMETERS_INFO": {
                    "k_inact_C": {
                        "VALUE": 0.05,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.01,
                            0.2
                        ],
                        "DESCRIPTION": "Crypto inactivation rate"
                    }
                }
            },
            "2": {
                "_NAME": "CRYPTO_SETTLING",
                "CONSUMED": "Cryptosporidium",
                "PRODUCED": "SED_Crypto",
                "KINETICS": [
                    "v_s_oocyst / depth * Cryptosporidium",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "v_s_oocyst",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "v_s_oocyst": 0.3,
                    "depth": 2.0
                },
                "_PARAMETERS_INFO": {
                    "v_s_oocyst": {
                        "VALUE": 0.3,
                        "UNITS": "m/day",
                        "DESCRIPTION": "Oocyst settling velocity"
                    },
                    "depth": {
                        "VALUE": 2.0,
                        "UNITS": "m"
                    }
                }
            },
            "3": {
                "_NAME": "GIARDIA_INACTIVATION",
                "CONSUMED": "Giardia",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_inact_G * Giardia * 1.04^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_inact_G"
                ],
                "PARAMETER_VALUES": {
                    "k_inact_G": 0.1
                },
                "_PARAMETERS_INFO": {
                    "k_inact_G": {
                        "VALUE": 0.1,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.02,
                            0.3
                        ],
                        "DESCRIPTION": "Giardia inactivation rate"
                    }
                }
            },
            "4": {
                "_NAME": "GIARDIA_SETTLING",
                "CONSUMED": "Giardia",
                "PRODUCED": "SED_Giardia",
                "KINETICS": [
                    "v_s_cyst / depth * Giardia",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "v_s_cyst",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "v_s_cyst": 1.0,
                    "depth": 2.0
                },
                "_PARAMETERS_INFO": {
                    "v_s_cyst": {
                        "VALUE": 1.0,
                        "UNITS": "m/day",
                        "DESCRIPTION": "Cyst settling velocity (larger than oocysts)"
                    },
                    "depth": {
                        "VALUE": 2.0,
                        "UNITS": "m"
                    }
                }
            }
        },
        "DIE_OFF_FORMULAS": {
            "_DESCRIPTION": "Reference formulas for pathogen die-off",
            "LIST_TRANSFORMATIONS": {},
            "_MANCINI_1978_INFO": {
                "FORMULA": "k = 0.8 + 0.006 * (% seawater) at 20C",
                "NOTES": "Classic relationship for FC in marine waters"
            },
            "_BEAUDEAU_2001_INFO": {
                "FORMULA": "k = k_dark * (1 + alpha * I)",
                "NOTES": "Separates dark die-off from light inactivation"
            },
            "_T90_CONVERSION_INFO": {
                "FORMULA": "k = 2.303 / T90",
                "NOTES": "T90 is time for 90% reduction"
            },
            "_TYPICAL_T90_VALUES_INFO": {
                "E_coli_freshwater": "2-3 days",
                "E_coli_seawater": "1-2 days",
                "Enterococcus_freshwater": "3-5 days",
                "Virus_freshwater": "5-20 days",
                "Cryptosporidium": "50-100 days",
                "Giardia": "20-50 days"
            }
        }
    },
    "_COMPARTMENT_ASSIGNMENT": {
        "RIVER": [
            "ECOLI_DYNAMICS",
            "FECAL_COLIFORM_DYNAMICS",
            "ENTEROCOCCI_DYNAMICS",
            "VIRUS_DYNAMICS",
            "PROTOZOA_DYNAMICS"
        ],
        "LAKE": [
            "ECOLI_DYNAMICS",
            "FECAL_COLIFORM_DYNAMICS",
            "ENTEROCOCCI_DYNAMICS",
            "VIRUS_DYNAMICS",
            "PROTOZOA_DYNAMICS"
        ],
        "ESTUARY": [
            "ECOLI_DYNAMICS",
            "FECAL_COLIFORM_DYNAMICS",
            "ENTEROCOCCI_DYNAMICS",
            "VIRUS_DYNAMICS",
            "PROTOZOA_DYNAMICS"
        ]
    }
}