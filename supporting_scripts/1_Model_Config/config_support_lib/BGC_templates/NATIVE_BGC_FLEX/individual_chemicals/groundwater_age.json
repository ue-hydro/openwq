{
    "_DESCRIPTION": "Groundwater Age Tracking and Environmental Tracers",
    "_REFERENCE": "Cook & Herczeg (2000) Environmental Tracers; McGuire & McDonnell (2006) WRR",
    "_VERSION": "1.0",
    "_PROCESSES": {
        "MEAN_AGE": "Mean age of water parcels (residence time distribution)",
        "TRACER_DECAY": "Radioactive decay of age-dating tracers",
        "CFCs": "Chlorofluorocarbon atmospheric tracers",
        "SF6": "Sulfur hexafluoride modern tracer",
        "TRITIUM": "Tritium (3H) decay and bomb-peak tracking",
        "CARBON14": "Radiocarbon dating for old groundwater"
    },
    "_NOTES": [
        "Groundwater age helps understand flow paths and vulnerability",
        "Mean age \u2260 point-source age due to mixing",
        "CFCs and SF6 best for water recharged after 1950s",
        "Tritium useful for bomb-peak (1960s) water",
        "14C for old groundwater (100-40,000 years)",
        "Age tracers can be combined to constrain residence time distributions"
    ],
    "MODULE_NAME": "NATIVE_BGC_FLEX",
    "CHEMICAL_SPECIES": {
        "LIST": {
            "1": "AGE_mean",
            "2": "AGE_young",
            "3": "AGE_old",
            "4": "CFC11",
            "5": "CFC12",
            "6": "SF6",
            "7": "TRITIUM",
            "8": "HELIUM3_trit",
            "9": "CARBON14",
            "10": "TRACER_conservative",
            "11": "TRACER_reactive"
        },
        "BGC_GENERAL_MOBILE_SPECIES": [
            "AGE_mean",
            "AGE_young",
            "AGE_old",
            "CFC11",
            "CFC12",
            "SF6",
            "TRITIUM",
            "HELIUM3_trit",
            "CARBON14",
            "TRACER_conservative",
            "TRACER_reactive"
        ],
        "_LIST_DESCRIPTIONS": {
            "AGE_mean": "Mean groundwater age",
            "AGE_young": "Young water fraction",
            "AGE_old": "Old water fraction",
            "CFC11": "CFC-11 tracer (trichlorofluoromethane)",
            "CFC12": "CFC-12 tracer (dichlorodifluoromethane)",
            "SF6": "Sulfur hexafluoride tracer",
            "TRITIUM": "Tritium tracer (3H)",
            "HELIUM3_trit": "Tritiogenic helium-3",
            "CARBON14": "Carbon-14 tracer",
            "TRACER_conservative": "Conservative tracer",
            "TRACER_reactive": "Reactive tracer"
        }
    },
    "CYCLING_FRAMEWORKS": {
        "MEAN_AGE_TRACKING": {
            "_description": "Direct mean age calculation via age mass balance",
            "_reference": "Goode (1996) WRR; Cornaton & Perrochet (2006)",
            "_notes": [
                "Age increases at rate of 1 day/day in subsurface",
                "Recharge water has age = 0",
                "Mixing: mean age = sum(Qi * age_i) / sum(Qi)"
            ],
            "LIST_TRANSFORMATIONS": {
                "1": "age_accumulation",
                "2": "age_reset_recharge"
            },
            "1": {
                "_name": "age_accumulation",
                "_description": "Age increases linearly with time in subsurface",
                "_reaction": "AGE_mean + dt -> AGE_mean + 1",
                "_notes": "This is a source term: d(Age)/dt = 1. Implemented as production rate.",
                "CONSUMED": "AGE_mean",
                "PRODUCED": "AGE_mean",
                "KINETICS": [
                    "k_age",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_age"
                ],
                "PARAMETER_VALUES": {
                    "k_age": 1.0
                },
                "_parameter_ranges": {
                    "k_age": {
                        "value": 1.0,
                        "units": "days/day",
                        "source": "Physical definition of age"
                    }
                }
            },
            "2": {
                "_name": "age_reset_recharge",
                "_description": "Recharge water resets age to zero",
                "_notes": "k_recharge should be set via boundary conditions, not kinetics",
                "CONSUMED": "AGE_mean",
                "PRODUCED": "AGE_young",
                "KINETICS": [
                    "k_recharge * AGE_mean",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_recharge"
                ],
                "PARAMETER_VALUES": {
                    "k_recharge": 0.0
                }
            }
        },
        "BINARY_AGE_FRACTIONS": {
            "_description": "Track young vs old water fractions",
            "_reference": "Suckow (2014) Applied Geochemistry",
            "_notes": [
                "Binary mixing model: water is young (<50 yr) or old (>50 yr)",
                "Fraction young = tracer_measured / tracer_young_endmember"
            ],
            "LIST_TRANSFORMATIONS": {
                "1": "young_to_old_transition",
                "2": "young_tracer_decay"
            },
            "1": {
                "_name": "young_to_old_transition",
                "_description": "Young water becomes old after threshold age",
                "_notes": "Threshold typically 50 years for CFC-based definition",
                "CONSUMED": "AGE_young",
                "PRODUCED": "AGE_old",
                "KINETICS": [
                    "k_transition * AGE_young * step(AGE_mean - age_threshold)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_transition",
                    "age_threshold"
                ],
                "PARAMETER_VALUES": {
                    "k_transition": 0.001,
                    "age_threshold": 18250
                },
                "_parameter_ranges": {
                    "age_threshold": {
                        "value": 18250,
                        "units": "days",
                        "source": "50 years \u00d7 365 days"
                    }
                }
            },
            "2": {
                "_name": "young_tracer_decay",
                "_description": "Young fraction tracer decay",
                "CONSUMED": "AGE_young",
                "PRODUCED": "AGE_old",
                "KINETICS": [
                    "k_decay * AGE_young",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_decay"
                ],
                "PARAMETER_VALUES": {
                    "k_decay": 0.0001
                }
            }
        },
        "CFC_TRACERS": {
            "_description": "Chlorofluorocarbon atmospheric tracers for post-1940s water",
            "_reference": "Busenberg & Plummer (1992) WRR",
            "_notes": [
                "CFCs entered atmosphere from 1940s-1990s (now declining)",
                "CFC-11: CCl3F, t1/2 = 45 yr (atmospheric)",
                "CFC-12: CCl2F2, t1/2 = 100 yr (atmospheric)",
                "CFC-113: C2Cl3F3, t1/2 = 85 yr (atmospheric)",
                "In groundwater: conservative (no decay) but can be degraded under anoxic"
            ],
            "LIST_TRANSFORMATIONS": {
                "1": "cfc11_equilibration",
                "2": "cfc12_equilibration",
                "3": "cfc11_degradation",
                "4": "cfc12_degradation"
            },
            "1": {
                "_name": "cfc11_equilibration",
                "_description": "CFC-11 equilibration with recharge atmosphere",
                "_notes": "Concentration at recharge reflects atmospheric history",
                "CONSUMED": "CFC11",
                "PRODUCED": "CFC11",
                "KINETICS": [
                    "k_equil * (cfc11_atm - CFC11)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_equil",
                    "cfc11_atm"
                ],
                "PARAMETER_VALUES": {
                    "k_equil": 0.1,
                    "cfc11_atm": 250
                },
                "_parameter_ranges": {
                    "CFC11_atm": {
                        "min": 0,
                        "max": 280,
                        "units": "pmol/kg",
                        "source": "Atmospheric history curve"
                    }
                }
            },
            "2": {
                "_name": "cfc12_equilibration",
                "_description": "CFC-12 equilibration with recharge atmosphere",
                "CONSUMED": "CFC12",
                "PRODUCED": "CFC12",
                "KINETICS": [
                    "k_equil * (cfc12_atm - CFC12)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_equil",
                    "cfc12_atm"
                ],
                "PARAMETER_VALUES": {
                    "k_equil": 0.1,
                    "cfc12_atm": 550
                }
            },
            "3": {
                "_name": "cfc11_degradation",
                "_description": "CFC-11 degradation under anoxic conditions",
                "_notes": "CFCs can degrade in anoxic/sulfidic environments",
                "CONSUMED": "CFC11",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_deg_cfc * CFC11 * (Ks_DO / (Ks_DO + DO))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_deg_cfc",
                    "Ks_DO"
                ],
                "PARAMETER_VALUES": {
                    "k_deg_cfc": 0.001,
                    "Ks_DO": 0.5
                },
                "_parameter_ranges": {
                    "k_deg_cfc": {
                        "min": 0,
                        "max": 0.01,
                        "units": "1/day",
                        "source": "Only under anoxia"
                    }
                }
            },
            "4": {
                "_name": "cfc12_degradation",
                "_description": "CFC-12 degradation (slower than CFC-11)",
                "CONSUMED": "CFC12",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_deg_cfc12 * CFC12 * (Ks_DO / (Ks_DO + DO))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_deg_cfc12",
                    "Ks_DO"
                ],
                "PARAMETER_VALUES": {
                    "k_deg_cfc12": 0.0005,
                    "Ks_DO": 0.5
                }
            }
        },
        "SF6_TRACER": {
            "_description": "Sulfur hexafluoride - modern tracer",
            "_reference": "Busenberg & Plummer (2000) WRR",
            "_notes": [
                "SF6 increasing in atmosphere since 1970s",
                "Very stable - no degradation in groundwater",
                "Best for water recharged after 1990",
                "Can have excess from terrigenic sources"
            ],
            "LIST_TRANSFORMATIONS": {
                "1": "sf6_equilibration",
                "2": "sf6_terrigenic_source"
            },
            "1": {
                "_name": "sf6_equilibration",
                "_description": "SF6 equilibration with atmosphere at recharge",
                "CONSUMED": "SF6",
                "PRODUCED": "SF6",
                "KINETICS": [
                    "k_equil * (sf6_atm - SF6)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_equil",
                    "sf6_atm"
                ],
                "PARAMETER_VALUES": {
                    "k_equil": 0.1,
                    "sf6_atm": 2.5
                },
                "_parameter_ranges": {
                    "SF6_atm": {
                        "min": 0,
                        "max": 10,
                        "units": "fmol/kg",
                        "source": "Increasing ~7%/year"
                    }
                }
            },
            "2": {
                "_name": "sf6_terrigenic_source",
                "_description": "Terrigenic SF6 from igneous rocks",
                "_notes": "Can cause apparent ages too young",
                "CONSUMED": "NONE",
                "PRODUCED": "SF6",
                "KINETICS": [
                    "k_terrigenic",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_terrigenic"
                ],
                "PARAMETER_VALUES": {
                    "k_terrigenic": 0.0
                }
            }
        },
        "TRITIUM_HELIUM": {
            "_description": "Tritium-Helium-3 dating system",
            "_reference": "Schlosser et al. (1988) EPSL; Solomon & Cook (2000)",
            "_notes": [
                "Tritium (3H) from bomb testing peaked in 1963",
                "Decays to 3He with t1/2 = 12.32 years",
                "3H-3He age = ln(1 + 3He_trit/3H) / lambda",
                "Good for ages 0-50 years"
            ],
            "LIST_TRANSFORMATIONS": {
                "1": "tritium_decay",
                "2": "helium3_production",
                "3": "helium3_degassing"
            },
            "1": {
                "_name": "tritium_decay",
                "_description": "Radioactive decay of tritium",
                "_reaction": "3H -> 3He + beta",
                "CONSUMED": "TRITIUM",
                "PRODUCED": "HELIUM3_trit",
                "KINETICS": [
                    "lambda_H3 * TRITIUM",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "lambda_H3"
                ],
                "PARAMETER_VALUES": {
                    "lambda_H3": 0.000154
                },
                "_parameter_ranges": {
                    "lambda_H3": {
                        "value": 0.000154,
                        "units": "1/day",
                        "source": "t1/2 = 12.32 yr = 4500 days"
                    }
                }
            },
            "2": {
                "_name": "helium3_production",
                "_description": "Tritiogenic 3He production from 3H decay",
                "_notes": "Tracks ingrowth of 3He from tritium",
                "CONSUMED": "TRITIUM",
                "PRODUCED": "HELIUM3_trit",
                "KINETICS": [
                    "lambda_H3 * TRITIUM",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "lambda_H3"
                ],
                "PARAMETER_VALUES": {
                    "lambda_H3": 0.000154
                }
            },
            "3": {
                "_name": "helium3_degassing",
                "_description": "3He loss via degassing in unsaturated zone",
                "_notes": "f_unsat = 0 in saturated zone, 1 in unsaturated",
                "CONSUMED": "HELIUM3_trit",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_degas * HELIUM3_trit * f_unsat",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_degas",
                    "f_unsat"
                ],
                "PARAMETER_VALUES": {
                    "k_degas": 0.1,
                    "f_unsat": 0.0
                }
            }
        },
        "CARBON14": {
            "_description": "Radiocarbon dating for old groundwater",
            "_reference": "Clark & Fritz (1997) Environmental Isotopes",
            "_notes": [
                "14C has t1/2 = 5,730 years",
                "Useful for ages 100 - 40,000 years",
                "Initial 14C activity affected by soil CO2",
                "Dilution by dead carbon (carbonates) must be corrected"
            ],
            "LIST_TRANSFORMATIONS": {
                "1": "c14_decay",
                "2": "c14_dilution"
            },
            "1": {
                "_name": "c14_decay",
                "_description": "Radioactive decay of 14C",
                "_reaction": "14C -> 14N + beta",
                "CONSUMED": "CARBON14",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "lambda_C14 * CARBON14",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "lambda_C14"
                ],
                "PARAMETER_VALUES": {
                    "lambda_C14": 3.31e-07
                },
                "_parameter_ranges": {
                    "lambda_C14": {
                        "value": 3.31e-07,
                        "units": "1/day",
                        "source": "t1/2 = 5730 yr"
                    }
                }
            },
            "2": {
                "_name": "c14_dilution",
                "_description": "14C dilution by dead carbon from carbonate dissolution",
                "_notes": "Carbonates have 0 pmC, diluting DIC 14C content",
                "CONSUMED": "CARBON14",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_dilution * CARBON14 * (DIC_carb / DIC_total)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_dilution",
                    "DIC_carb",
                    "DIC_total"
                ],
                "PARAMETER_VALUES": {
                    "k_dilution": 0.01,
                    "DIC_carb": 0.5,
                    "DIC_total": 1.0
                }
            }
        },
        "CONSERVATIVE_TRACERS": {
            "_description": "Generic conservative and reactive tracers",
            "_notes": "For tracer tests and residence time estimation",
            "LIST_TRANSFORMATIONS": {
                "1": "conservative_transport",
                "2": "reactive_decay"
            },
            "1": {
                "_name": "conservative_transport",
                "_description": "Conservative tracer (no reaction)",
                "_notes": "Useful for flow path delineation",
                "CONSUMED": "TRACER_conservative",
                "PRODUCED": "TRACER_conservative",
                "KINETICS": [
                    "0.0",
                    "1/day"
                ],
                "PARAMETER_NAMES": [],
                "PARAMETER_VALUES": {}
            },
            "2": {
                "_name": "reactive_decay",
                "_description": "First-order decay of reactive tracer",
                "CONSUMED": "TRACER_reactive",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_decay * TRACER_reactive",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_decay"
                ],
                "PARAMETER_VALUES": {
                    "k_decay": 0.01
                }
            }
        }
    }
}