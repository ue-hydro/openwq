{
    "_DESCRIPTION": "Iron and Manganese Redox Cycling",
    "_REFERENCE": "Stumm & Morgan (1996), WASP TOXI",
    "_VERSION": "1.0",
    "CHEMICAL_SPECIES": {
        "LIST": {
            "1": "Fe_II",
            "2": "Fe_III",
            "3": "Fe_oxy",
            "4": "Mn_II",
            "5": "Mn_IV",
            "6": "MnO2",
            "7": "DO",
            "8": "H2S",
            "9": "PO4-P",
            "10": "Fe_P",
            "11": "SED_Fe",
            "12": "SED_Mn"
        },
        "BGC_GENERAL_MOBILE_SPECIES": [
            "Fe_II",
            "Fe_III",
            "Fe_oxy",
            "Mn_II",
            "Mn_IV",
            "MnO2",
            "DO",
            "H2S",
            "PO4-P",
            "Fe_P"
        ],
        "_LIST_DESCRIPTIONS": {
            "Fe_II": "Ferrous iron (reduced, soluble)",
            "Fe_III": "Ferric iron (oxidized, precipitates)",
            "Fe_oxy": "Particulate iron oxyhydroxides (FeOOH)",
            "Mn_II": "Manganous manganese (reduced, soluble)",
            "Mn_IV": "Manganic manganese (oxidized, precipitates)",
            "MnO2": "Particulate manganese dioxide",
            "DO": "Dissolved oxygen",
            "H2S": "Hydrogen sulfide",
            "PO4-P": "Phosphate (Fe-P coupling)",
            "Fe_P": "Fe P",
            "SED_Fe": "Settled Fe (sediment sink)",
            "SED_Mn": "Settled Mn (sediment sink)"
        }
    },
    "CYCLING_FRAMEWORKS": {
        "IRON_REDOX": {
            "_DESCRIPTION": "Iron oxidation-reduction cycling",
            "LIST_TRANSFORMATIONS": {
                "1": "FE_OXIDATION_ABIOTIC",
                "2": "FE_OXIDATION_SIMPLIFIED",
                "3": "FE_III_PRECIPITATION",
                "4": "FE_REDUCTION_MICROBIAL",
                "5": "FE_REDUCTION_SULFIDE",
                "6": "FE_OXY_SETTLING",
                "7": "FE_SEDIMENT_FLUX"
            },
            "1": {
                "_NAME": "FE_OXIDATION_ABIOTIC",
                "CONSUMED": "Fe_II",
                "PRODUCED": "Fe_III",
                "KINETICS": [
                    "k_ox_Fe * Fe_II * DO * (OH)^2",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_ox_Fe",
                    "OH"
                ],
                "PARAMETER_VALUES": {
                    "k_ox_Fe": 8000000000000.0,
                    "OH": 1e-07
                },
                "_NOTES": "Rate increases 100x per pH unit; very fast above pH 7",
                "_PARAMETERS_INFO": {
                    "k_ox_Fe": {
                        "VALUE": 8000000000000.0,
                        "UNITS": "L3/mol2/atm/min",
                        "DESCRIPTION": "Fe(II) oxidation rate constant"
                    },
                    "OH": {
                        "VALUE": 1e-07,
                        "UNITS": "mol/L",
                        "DESCRIPTION": "Hydroxide concentration (pH dependent)"
                    }
                }
            },
            "2": {
                "_NAME": "FE_OXIDATION_SIMPLIFIED",
                "CONSUMED": "Fe_II",
                "PRODUCED": "Fe_III",
                "KINETICS": [
                    "k_ox_Fe_simple * Fe_II * (DO / (K_O2 + DO)) * 1.1^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_ox_Fe_simple",
                    "K_O2"
                ],
                "PARAMETER_VALUES": {
                    "k_ox_Fe_simple": 5.0,
                    "K_O2": 0.5
                },
                "_PARAMETERS_INFO": {
                    "k_ox_Fe_simple": {
                        "VALUE": 5.0,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.5,
                            50.0
                        ],
                        "DESCRIPTION": "Simplified oxidation rate at neutral pH"
                    },
                    "K_O2": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L"
                    }
                }
            },
            "3": {
                "_NAME": "FE_III_PRECIPITATION",
                "CONSUMED": "Fe_III",
                "PRODUCED": "Fe_oxy",
                "KINETICS": [
                    "k_precip_Fe * Fe_III",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_precip_Fe"
                ],
                "PARAMETER_VALUES": {
                    "k_precip_Fe": 10.0
                },
                "_NOTES": "Fe(III) rapidly precipitates above pH 3",
                "_PARAMETERS_INFO": {
                    "k_precip_Fe": {
                        "VALUE": 10.0,
                        "UNITS": "1/day",
                        "DESCRIPTION": "Fe(III) precipitation as oxyhydroxide"
                    }
                }
            },
            "4": {
                "_NAME": "FE_REDUCTION_MICROBIAL",
                "CONSUMED": "Fe_oxy",
                "PRODUCED": "Fe_II",
                "KINETICS": [
                    "k_red_Fe * Fe_oxy * (K_O2_inhib / (K_O2_inhib + DO)) * 1.1^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_red_Fe",
                    "K_O2_inhib"
                ],
                "PARAMETER_VALUES": {
                    "k_red_Fe": 0.1,
                    "K_O2_inhib": 0.5
                },
                "_NOTES": "Dissimilatory iron reduction under anoxic conditions",
                "_PARAMETERS_INFO": {
                    "k_red_Fe": {
                        "VALUE": 0.1,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.01,
                            1.0
                        ],
                        "DESCRIPTION": "Microbial Fe reduction rate"
                    },
                    "K_O2_inhib": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L",
                        "DESCRIPTION": "O2 inhibition constant"
                    }
                }
            },
            "5": {
                "_NAME": "FE_REDUCTION_SULFIDE",
                "CONSUMED": "Fe_oxy",
                "PRODUCED": "Fe_II",
                "KINETICS": [
                    "k_FeS * Fe_oxy * H2S",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_FeS"
                ],
                "PARAMETER_VALUES": {
                    "k_FeS": 100.0
                },
                "_NOTES": "Chemical reduction by H2S very rapid",
                "_PARAMETERS_INFO": {
                    "k_FeS": {
                        "VALUE": 100.0,
                        "UNITS": "L/mg/day",
                        "DESCRIPTION": "Fe reduction by sulfide (fast)"
                    }
                }
            },
            "6": {
                "_NAME": "FE_OXY_SETTLING",
                "CONSUMED": "Fe_oxy",
                "PRODUCED": "SED_Fe",
                "KINETICS": [
                    "v_s / depth * Fe_oxy",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "v_s",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "v_s": 2.0,
                    "depth": 5.0
                },
                "_PARAMETERS_INFO": {
                    "v_s": {
                        "VALUE": 2.0,
                        "UNITS": "m/day"
                    },
                    "depth": {
                        "VALUE": 5.0,
                        "UNITS": "m"
                    }
                }
            },
            "7": {
                "_NAME": "FE_SEDIMENT_FLUX",
                "CONSUMED": "NONE",
                "PRODUCED": "Fe_II",
                "KINETICS": [
                    "J_Fe / depth * (K_O2_sed / (K_O2_sed + DO))",
                    "mg/day"
                ],
                "PARAMETER_NAMES": [
                    "J_Fe",
                    "K_O2_sed",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "J_Fe": 20.0,
                    "K_O2_sed": 2.0,
                    "depth": 5.0
                },
                "_PARAMETERS_INFO": {
                    "J_Fe": {
                        "VALUE": 20.0,
                        "UNITS": "mg/m2/day",
                        "RANGE": [
                            5.0,
                            100.0
                        ],
                        "DESCRIPTION": "Sediment Fe flux under anoxia"
                    },
                    "K_O2_sed": {
                        "VALUE": 2.0,
                        "UNITS": "mg/L"
                    },
                    "depth": {
                        "VALUE": 5.0,
                        "UNITS": "m"
                    }
                }
            }
        },
        "MANGANESE_REDOX": {
            "_DESCRIPTION": "Manganese oxidation-reduction cycling",
            "LIST_TRANSFORMATIONS": {
                "1": "MN_OXIDATION",
                "2": "MN_PRECIPITATION",
                "3": "MN_REDUCTION",
                "4": "MNO2_SETTLING",
                "5": "MN_SEDIMENT_FLUX"
            },
            "1": {
                "_NAME": "MN_OXIDATION",
                "CONSUMED": "Mn_II",
                "PRODUCED": "Mn_IV",
                "KINETICS": [
                    "k_ox_Mn * Mn_II * (DO / (K_O2 + DO)) * 1.08^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_ox_Mn",
                    "K_O2"
                ],
                "PARAMETER_VALUES": {
                    "k_ox_Mn": 0.5,
                    "K_O2": 1.0
                },
                "_NOTES": "Mn oxidation slower than Fe; microbially catalyzed",
                "_PARAMETERS_INFO": {
                    "k_ox_Mn": {
                        "VALUE": 0.5,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.1,
                            5.0
                        ],
                        "DESCRIPTION": "Mn(II) oxidation rate"
                    },
                    "K_O2": {
                        "VALUE": 1.0,
                        "UNITS": "mg/L"
                    }
                }
            },
            "2": {
                "_NAME": "MN_PRECIPITATION",
                "CONSUMED": "Mn_IV",
                "PRODUCED": "MnO2",
                "KINETICS": [
                    "k_precip_Mn * Mn_IV",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_precip_Mn"
                ],
                "PARAMETER_VALUES": {
                    "k_precip_Mn": 5.0
                },
                "_PARAMETERS_INFO": {
                    "k_precip_Mn": {
                        "VALUE": 5.0,
                        "UNITS": "1/day",
                        "DESCRIPTION": "MnO2 precipitation rate"
                    }
                }
            },
            "3": {
                "_NAME": "MN_REDUCTION",
                "CONSUMED": "MnO2",
                "PRODUCED": "Mn_II",
                "KINETICS": [
                    "k_red_Mn * MnO2 * (K_O2_inhib / (K_O2_inhib + DO)) * 1.1^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_red_Mn",
                    "K_O2_inhib"
                ],
                "PARAMETER_VALUES": {
                    "k_red_Mn": 0.2,
                    "K_O2_inhib": 0.5
                },
                "_NOTES": "Mn reduction occurs at higher Eh than Fe reduction",
                "_PARAMETERS_INFO": {
                    "k_red_Mn": {
                        "VALUE": 0.2,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.05,
                            1.0
                        ],
                        "DESCRIPTION": "Microbial Mn reduction rate"
                    },
                    "K_O2_inhib": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L"
                    }
                }
            },
            "4": {
                "_NAME": "MNO2_SETTLING",
                "CONSUMED": "MnO2",
                "PRODUCED": "SED_Mn",
                "KINETICS": [
                    "v_s / depth * MnO2",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "v_s",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "v_s": 2.0,
                    "depth": 5.0
                },
                "_PARAMETERS_INFO": {
                    "v_s": {
                        "VALUE": 2.0,
                        "UNITS": "m/day"
                    },
                    "depth": {
                        "VALUE": 5.0,
                        "UNITS": "m"
                    }
                }
            },
            "5": {
                "_NAME": "MN_SEDIMENT_FLUX",
                "CONSUMED": "NONE",
                "PRODUCED": "Mn_II",
                "KINETICS": [
                    "J_Mn / depth * (K_O2_sed / (K_O2_sed + DO))",
                    "mg/day"
                ],
                "PARAMETER_NAMES": [
                    "J_Mn",
                    "K_O2_sed",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "J_Mn": 10.0,
                    "K_O2_sed": 2.0,
                    "depth": 5.0
                },
                "_PARAMETERS_INFO": {
                    "J_Mn": {
                        "VALUE": 10.0,
                        "UNITS": "mg/m2/day",
                        "RANGE": [
                            2.0,
                            50.0
                        ],
                        "DESCRIPTION": "Sediment Mn flux under anoxia"
                    },
                    "K_O2_sed": {
                        "VALUE": 2.0,
                        "UNITS": "mg/L"
                    },
                    "depth": {
                        "VALUE": 5.0,
                        "UNITS": "m"
                    }
                }
            }
        },
        "FE_P_COUPLING": {
            "_DESCRIPTION": "Iron-phosphorus interactions",
            "LIST_TRANSFORMATIONS": {
                "1": "P_SORPTION_TO_FE",
                "2": "P_RELEASE_FROM_FE"
            },
            "1": {
                "_NAME": "P_SORPTION_TO_FE",
                "CONSUMED": "PO4-P",
                "PRODUCED": "Fe_P",
                "KINETICS": [
                    "k_ads_P_Fe * PO4-P * Fe_oxy",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_ads_P_Fe"
                ],
                "PARAMETER_VALUES": {
                    "k_ads_P_Fe": 0.5
                },
                "_PARAMETERS_INFO": {
                    "k_ads_P_Fe": {
                        "VALUE": 0.5,
                        "UNITS": "L/mg/day",
                        "DESCRIPTION": "P adsorption to Fe oxyhydroxides"
                    }
                }
            },
            "2": {
                "_NAME": "P_RELEASE_FROM_FE",
                "CONSUMED": "Fe_P",
                "PRODUCED": "PO4-P",
                "KINETICS": [
                    "k_des_P_Fe * Fe_P * (K_O2_inhib / (K_O2_inhib + DO))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_des_P_Fe",
                    "K_O2_inhib"
                ],
                "PARAMETER_VALUES": {
                    "k_des_P_Fe": 0.2,
                    "K_O2_inhib": 0.5
                },
                "_NOTES": "Classic internal P loading mechanism",
                "_PARAMETERS_INFO": {
                    "k_des_P_Fe": {
                        "VALUE": 0.2,
                        "UNITS": "1/day",
                        "DESCRIPTION": "P release when Fe reduces"
                    },
                    "K_O2_inhib": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L"
                    }
                }
            }
        },
        "REDOX_SEQUENCE": {
            "_DESCRIPTION": "Terminal electron acceptor sequence",
            "_NOTES": "Under decreasing Eh (more reducing conditions)",
            "LIST_TRANSFORMATIONS": {}
        }
    },
    "_COMPARTMENT_ASSIGNMENT": {
        "LAKE_HYPOLIMNION": [
            "IRON_REDOX",
            "MANGANESE_REDOX",
            "FE_P_COUPLING"
        ],
        "RESERVOIR_BOTTOM": [
            "IRON_REDOX",
            "MANGANESE_REDOX",
            "FE_P_COUPLING"
        ],
        "WETLAND": [
            "IRON_REDOX",
            "MANGANESE_REDOX",
            "FE_P_COUPLING"
        ],
        "GROUNDWATER": [
            "IRON_REDOX",
            "MANGANESE_REDOX"
        ]
    }
}
