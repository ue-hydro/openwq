{
    "_DESCRIPTION": "Simple Nitrogen Cycle - Basic NH4-N/NO3-N/Org-N transformations",
    "_REFERENCE": "Chapra (2008) Surface Water-Quality Modeling",
    "_VERSION": "1.0",
    "CHEMICAL_SPECIES": {
        "LIST": {
            "1": "NH4-N",
            "2": "NO3-N",
            "3": "ORG_N",
            "4": "N2_loss"
        },
        "BGC_GENERAL_MOBILE_SPECIES": [
            "NH4-N",
            "NO3-N",
            "ORG_N"
        ],
        "_LIST_DESCRIPTIONS": {
            "NH4-N": "Ammonium nitrogen",
            "NO3-N": "Nitrate nitrogen",
            "ORG_N": "Organic nitrogen (dissolved + particulate)",
            "N2_loss": "N2 loss to atmosphere/sediment"
        }
    },
    "CYCLING_FRAMEWORKS": {
        "SIMPLE_N_CYCLE": {
            "_DESCRIPTION": "Three-pool nitrogen cycle with temperature correction",
            "LIST_TRANSFORMATIONS": {
                "1": "MINERALIZATION",
                "2": "NITRIFICATION",
                "3": "DENITRIFICATION"
            },
            "1": {
                "_NAME": "MINERALIZATION",
                "CONSUMED": "ORG_N",
                "PRODUCED": "NH4-N",
                "KINETICS": [
                    "k_min * ORG_N * 1.08^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_min"
                ],
                "PARAMETER_VALUES": {
                    "k_min": 0.05
                },
                "_PARAMETERS_INFO": {
                    "k_min": {
                        "VALUE": 0.05,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.02,
                            0.2
                        ],
                        "DESCRIPTION": "Organic N mineralization rate at 20C"
                    }
                }
            },
            "2": {
                "_NAME": "NITRIFICATION",
                "CONSUMED": "NH4-N",
                "PRODUCED": "NO3-N",
                "KINETICS": [
                    "k_nitrif * NH4-N * 1.08^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_nitrif"
                ],
                "PARAMETER_VALUES": {
                    "k_nitrif": 0.1
                },
                "_PARAMETERS_INFO": {
                    "k_nitrif": {
                        "VALUE": 0.1,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.01,
                            0.5
                        ],
                        "DESCRIPTION": "Nitrification rate at 20C"
                    }
                }
            },
            "3": {
                "_NAME": "DENITRIFICATION",
                "CONSUMED": "NO3-N",
                "PRODUCED": "N2_loss",
                "KINETICS": [
                    "k_denitrif * NO3-N * 1.07^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_denitrif"
                ],
                "PARAMETER_VALUES": {
                    "k_denitrif": 0.02
                },
                "_NOTES": "N2_loss is a sink (lost to atmosphere)",
                "_PARAMETERS_INFO": {
                    "k_denitrif": {
                        "VALUE": 0.02,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.001,
                            0.1
                        ],
                        "DESCRIPTION": "Denitrification rate at 20C"
                    }
                }
            }
        }
    },
    "_COMPARTMENT_ASSIGNMENT": {
        "SOIL": [
            "SIMPLE_N_CYCLE"
        ],
        "RIVER": [
            "SIMPLE_N_CYCLE"
        ],
        "LAKE": [
            "SIMPLE_N_CYCLE"
        ]
    }
}
