{
    "_DESCRIPTION": "Pesticide Fate and Transport - Degradation, sorption, volatilization",
    "_REFERENCE": "PRZM, PELMO, Mackay (2001) Multimedia Fate Models",
    "_VERSION": "1.0",
    "CHEMICAL_SPECIES": {
        "LIST": {
            "1": "PEST_diss",
            "2": "PEST_part",
            "3": "PEST_DOC",
            "4": "METAB_1",
            "5": "METAB_2",
            "6": "DOC",
            "7": "TSS"
        },
        "BGC_GENERAL_MOBILE_SPECIES": [
            "PEST_diss",
            "PEST_part",
            "PEST_DOC",
            "METAB_1",
            "METAB_2",
            "DOC",
            "TSS"
        ],
        "_LIST_DESCRIPTIONS": {
            "PEST_diss": "Dissolved pesticide in water",
            "PEST_part": "Pesticide sorbed to particles",
            "PEST_DOC": "Pesticide bound to DOC",
            "METAB_1": "Primary metabolite",
            "METAB_2": "Secondary metabolite",
            "DOC": "Dissolved organic carbon",
            "TSS": "Total suspended solids"
        }
    },
    "CYCLING_FRAMEWORKS": {
        "PESTICIDE_FATE": {
            "_DESCRIPTION": "Complete pesticide fate model",
            "LIST_TRANSFORMATIONS": {
                "1": "HYDROLYSIS",
                "2": "PHOTOLYSIS",
                "3": "BIODEGRADATION_AEROBIC",
                "4": "BIODEGRADATION_ANAEROBIC",
                "5": "SORPTION_PARTICLES",
                "6": "DESORPTION_PARTICLES",
                "7": "SORPTION_DOC",
                "8": "DESORPTION_DOC",
                "9": "VOLATILIZATION",
                "10": "SETTLING",
                "11": "METAB1_DEGRADATION",
                "12": "METAB2_MINERALIZATION"
            },
            "1": {
                "_NAME": "HYDROLYSIS",
                "CONSUMED": "PEST_diss",
                "PRODUCED": "METAB_1",
                "KINETICS": [
                    "k_hyd * PEST_diss * 10^(pH - 7)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_hyd",
                    "pH"
                ],
                "PARAMETER_VALUES": {
                    "k_hyd": 0.01,
                    "pH": 7.5
                },
                "_NOTES": "Many pesticides have pH-dependent hydrolysis",
                "_PARAMETERS_INFO": {
                    "k_hyd": {
                        "VALUE": 0.01,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.0,
                            0.5
                        ],
                        "DESCRIPTION": "Base hydrolysis rate at pH 7"
                    },
                    "pH": {
                        "VALUE": 7.5,
                        "DESCRIPTION": "Water pH"
                    }
                }
            },
            "2": {
                "_NAME": "PHOTOLYSIS",
                "CONSUMED": "PEST_diss",
                "PRODUCED": "METAB_1",
                "KINETICS": [
                    "k_photo * PEST_diss * I_avg / I_ref * exp(-k_ext * depth / 2)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_photo",
                    "I_avg",
                    "I_ref",
                    "k_ext",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "k_photo": 0.1,
                    "I_avg": 300,
                    "I_ref": 300,
                    "k_ext": 2.0,
                    "depth": 1.0
                },
                "_PARAMETERS_INFO": {
                    "k_photo": {
                        "VALUE": 0.1,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.0,
                            2.0
                        ],
                        "DESCRIPTION": "Photolysis rate at reference irradiance"
                    },
                    "I_avg": {
                        "VALUE": 300,
                        "UNITS": "W/m2",
                        "DESCRIPTION": "Surface irradiance"
                    },
                    "I_ref": {
                        "VALUE": 300,
                        "UNITS": "W/m2",
                        "DESCRIPTION": "Reference irradiance"
                    },
                    "k_ext": {
                        "VALUE": 2.0,
                        "UNITS": "1/m",
                        "DESCRIPTION": "Light extinction coefficient"
                    },
                    "depth": {
                        "VALUE": 1.0,
                        "UNITS": "m"
                    }
                }
            },
            "3": {
                "_NAME": "BIODEGRADATION_AEROBIC",
                "CONSUMED": "PEST_diss",
                "PRODUCED": "METAB_1",
                "KINETICS": [
                    "k_bio * PEST_diss * (DO / (K_O2 + DO)) * 1.07^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_bio",
                    "K_O2",
                    "DO"
                ],
                "PARAMETER_VALUES": {
                    "k_bio": 0.05,
                    "K_O2": 0.5,
                    "DO": 8.0
                },
                "_PARAMETERS_INFO": {
                    "k_bio": {
                        "VALUE": 0.05,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.001,
                            0.5
                        ],
                        "DESCRIPTION": "Aerobic biodegradation rate at 20C"
                    },
                    "K_O2": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L",
                        "DESCRIPTION": "Half-saturation for O2"
                    },
                    "DO": {
                        "VALUE": 8.0,
                        "UNITS": "mg/L"
                    }
                }
            },
            "4": {
                "_NAME": "BIODEGRADATION_ANAEROBIC",
                "CONSUMED": "PEST_diss",
                "PRODUCED": "METAB_1",
                "KINETICS": [
                    "k_bio_an * PEST_diss * (K_O2_inhib / (K_O2_inhib + DO)) * 1.05^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_bio_an",
                    "K_O2_inhib",
                    "DO"
                ],
                "PARAMETER_VALUES": {
                    "k_bio_an": 0.01,
                    "K_O2_inhib": 0.5,
                    "DO": 8.0
                },
                "_NOTES": "Some pesticides degrade faster under anoxic conditions",
                "_PARAMETERS_INFO": {
                    "k_bio_an": {
                        "VALUE": 0.01,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.0,
                            0.1
                        ],
                        "DESCRIPTION": "Anaerobic biodegradation rate"
                    },
                    "K_O2_inhib": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L"
                    },
                    "DO": {
                        "VALUE": 8.0,
                        "UNITS": "mg/L"
                    }
                }
            },
            "5": {
                "_NAME": "SORPTION_PARTICLES",
                "CONSUMED": "PEST_diss",
                "PRODUCED": "PEST_part",
                "KINETICS": [
                    "k_ads * PEST_diss * TSS / 1000",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_ads"
                ],
                "PARAMETER_VALUES": {
                    "k_ads": 0.5
                },
                "_PARAMETERS_INFO": {
                    "k_ads": {
                        "VALUE": 0.5,
                        "UNITS": "L/mg/day",
                        "RANGE": [
                            0.01,
                            5.0
                        ],
                        "DESCRIPTION": "Adsorption rate to particles"
                    }
                }
            },
            "6": {
                "_NAME": "DESORPTION_PARTICLES",
                "CONSUMED": "PEST_part",
                "PRODUCED": "PEST_diss",
                "KINETICS": [
                    "k_des * PEST_part",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_des"
                ],
                "PARAMETER_VALUES": {
                    "k_des": 0.1
                },
                "_PARAMETERS_INFO": {
                    "k_des": {
                        "VALUE": 0.1,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.01,
                            1.0
                        ],
                        "DESCRIPTION": "Desorption rate"
                    }
                }
            },
            "7": {
                "_NAME": "SORPTION_DOC",
                "CONSUMED": "PEST_diss",
                "PRODUCED": "PEST_DOC",
                "KINETICS": [
                    "k_DOC * PEST_diss * DOC",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_DOC"
                ],
                "PARAMETER_VALUES": {
                    "k_DOC": 0.1
                },
                "_NOTES": "DOC-bound fraction is mobile but not bioavailable",
                "_PARAMETERS_INFO": {
                    "k_DOC": {
                        "VALUE": 0.1,
                        "UNITS": "L/mg/day",
                        "RANGE": [
                            0.01,
                            1.0
                        ],
                        "DESCRIPTION": "DOC binding rate"
                    }
                }
            },
            "8": {
                "_NAME": "DESORPTION_DOC",
                "CONSUMED": "PEST_DOC",
                "PRODUCED": "PEST_diss",
                "KINETICS": [
                    "k_des_DOC * PEST_DOC",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_des_DOC"
                ],
                "PARAMETER_VALUES": {
                    "k_des_DOC": 0.2
                },
                "_PARAMETERS_INFO": {
                    "k_des_DOC": {
                        "VALUE": 0.2,
                        "UNITS": "1/day"
                    }
                }
            },
            "9": {
                "_NAME": "VOLATILIZATION",
                "CONSUMED": "PEST_diss",
                "PRODUCED": "PEST_atm_loss",
                "KINETICS": [
                    "k_vol * PEST_diss",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_vol"
                ],
                "PARAMETER_VALUES": {
                    "k_vol": 0.01
                },
                "_NOTES": "k_vol = K_L * A / V where K_L is overall mass transfer coeff",
                "_PARAMETERS_INFO": {
                    "k_vol": {
                        "VALUE": 0.01,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.0,
                            0.5
                        ],
                        "DESCRIPTION": "Volatilization rate (Henry's law dependent)"
                    }
                }
            },
            "10": {
                "_NAME": "SETTLING",
                "CONSUMED": "PEST_part",
                "PRODUCED": "SED_PEST",
                "KINETICS": [
                    "v_s / depth * PEST_part",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "v_s",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "v_s": 1.0,
                    "depth": 2.0
                },
                "_PARAMETERS_INFO": {
                    "v_s": {
                        "VALUE": 1.0,
                        "UNITS": "m/day",
                        "DESCRIPTION": "Particle settling velocity"
                    },
                    "depth": {
                        "VALUE": 2.0,
                        "UNITS": "m"
                    }
                }
            },
            "11": {
                "_NAME": "METAB1_DEGRADATION",
                "CONSUMED": "METAB_1",
                "PRODUCED": "METAB_2",
                "KINETICS": [
                    "k_deg_M1 * METAB_1 * 1.07^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_deg_M1"
                ],
                "PARAMETER_VALUES": {
                    "k_deg_M1": 0.1
                },
                "_PARAMETERS_INFO": {
                    "k_deg_M1": {
                        "VALUE": 0.1,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.01,
                            0.5
                        ],
                        "DESCRIPTION": "Primary metabolite degradation rate"
                    }
                }
            },
            "12": {
                "_NAME": "METAB2_MINERALIZATION",
                "CONSUMED": "METAB_2",
                "PRODUCED": "CO2_loss",
                "KINETICS": [
                    "k_min_M2 * METAB_2 * 1.07^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_min_M2"
                ],
                "PARAMETER_VALUES": {
                    "k_min_M2": 0.2
                },
                "_PARAMETERS_INFO": {
                    "k_min_M2": {
                        "VALUE": 0.2,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.05,
                            1.0
                        ],
                        "DESCRIPTION": "Final mineralization rate"
                    }
                }
            }
        },
        "COMMON_PESTICIDES": {
            "_DESCRIPTION": "Parameter sets for specific pesticides",
            "LIST_TRANSFORMATIONS": {},
            "_ATRAZINE_INFO": {
                "k_hyd": 0.0001,
                "k_photo": 0.002,
                "k_bio": 0.007,
                "Koc": 100,
                "DT50_water": 80,
                "DT50_soil": 60,
                "NOTES": "Triazine herbicide; persistent"
            },
            "_GLYPHOSATE_INFO": {
                "k_hyd": 0.0,
                "k_photo": 0.01,
                "k_bio": 0.05,
                "Koc": 24000,
                "DT50_water": 7,
                "DT50_soil": 15,
                "NOTES": "Highly sorbed; relatively short half-life"
            },
            "_CHLORPYRIFOS_INFO": {
                "k_hyd": 0.02,
                "k_photo": 0.05,
                "k_bio": 0.03,
                "Koc": 8500,
                "DT50_water": 25,
                "DT50_soil": 30,
                "NOTES": "Organophosphate insecticide"
            },
            "_IMIDACLOPRID_INFO": {
                "k_hyd": 0.0003,
                "k_photo": 0.2,
                "k_bio": 0.01,
                "Koc": 225,
                "DT50_water": 30,
                "DT50_soil": 180,
                "NOTES": "Neonicotinoid; photo-labile"
            },
            "_METOLACHLOR_INFO": {
                "k_hyd": 0.0001,
                "k_photo": 0.01,
                "k_bio": 0.02,
                "Koc": 200,
                "DT50_water": 26,
                "DT50_soil": 20,
                "NOTES": "Chloroacetanilide herbicide"
            },
            "_DIAZINON_INFO": {
                "k_hyd": 0.07,
                "k_photo": 0.1,
                "k_bio": 0.05,
                "Koc": 1000,
                "DT50_water": 12,
                "DT50_soil": 40,
                "NOTES": "pH-dependent hydrolysis"
            },
            "_DDT_INFO": {
                "k_hyd": 0.0001,
                "k_photo": 0.0,
                "k_bio": 0.001,
                "Koc": 150000,
                "DT50_water": 1000,
                "DT50_soil": 3000,
                "NOTES": "Legacy pollutant; extremely persistent"
            }
        },
        "PARTITIONING_FORMULAS": {
            "_DESCRIPTION": "Equilibrium partitioning calculations",
            "LIST_TRANSFORMATIONS": {},
            "_KD_FROM_KOC_INFO": {
                "FORMULA": "Kd = Koc * foc",
                "NOTES": "foc = fraction organic carbon in solids"
            },
            "_FRACTION_DISSOLVED_INFO": {
                "FORMULA": "f_diss = 1 / (1 + Kd * TSS/1000 + K_DOC * DOC)",
                "NOTES": "Accounts for particle and DOC binding"
            },
            "_HENRY_LAW_INFO": {
                "FORMULA": "k_vol = K_L * A / V = K_L / depth",
                "NOTES": "K_L depends on wind speed and chemical properties"
            },
            "_DT50_TO_K_INFO": {
                "FORMULA": "k = ln(2) / DT50 = 0.693 / DT50",
                "NOTES": "Convert half-life to first-order rate"
            }
        }
    },
    "_COMPARTMENT_ASSIGNMENT": {
        "RIVER": [
            "PESTICIDE_FATE"
        ],
        "LAKE": [
            "PESTICIDE_FATE"
        ],
        "SOIL": [
            "PESTICIDE_FATE"
        ],
        "GROUNDWATER": [
            "PESTICIDE_FATE"
        ]
    }
}