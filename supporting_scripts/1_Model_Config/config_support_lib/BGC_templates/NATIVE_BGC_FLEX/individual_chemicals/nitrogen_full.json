{
    "_DESCRIPTION": "Complete Nitrogen Cycle - All N forms with O2 limitation and plant uptake",
    "_REFERENCE": "SWAT, HYPE, and Chapra (2008)",
    "_VERSION": "1.0",
    "CHEMICAL_SPECIES": {
        "LIST": {
            "1": "NH4-N",
            "2": "NO3-N",
            "3": "NO2-N",
            "4": "DON",
            "5": "PON",
            "6": "N2O",
            "7": "DO",
            "8": "N2O_atm_loss",
            "9": "N2_loss",
            "10": "NH3_loss"
        },
        "BGC_GENERAL_MOBILE_SPECIES": [
            "NH4-N",
            "NO3-N",
            "NO2-N",
            "DON",
            "PON",
            "N2O",
            "DO"
        ],
        "_LIST_DESCRIPTIONS": {
            "NH4-N": "Ammonium nitrogen",
            "NO3-N": "Nitrate nitrogen",
            "NO2-N": "Nitrite nitrogen",
            "DON": "Dissolved organic nitrogen",
            "PON": "Particulate organic nitrogen",
            "N2O": "Nitrous oxide (GHG emission tracker)",
            "DO": "Dissolved oxygen (required for O2-limited reactions)",
            "N2O_atm_loss": "N2O loss to atmosphere/sediment",
            "N2_loss": "N2 loss to atmosphere/sediment",
            "NH3_loss": "NH3 loss to atmosphere/sediment"
        }
    },
    "CYCLING_FRAMEWORKS": {
        "FULL_N_CYCLE": {
            "_DESCRIPTION": "Complete nitrogen cycle with all transformations",
            "LIST_TRANSFORMATIONS": {
                "1": "PON_HYDROLYSIS",
                "2": "DON_MINERALIZATION",
                "3": "NITRIFICATION_STEP1",
                "4": "NITRIFICATION_STEP2",
                "5": "NITRIFICATION_O2_DEMAND",
                "6": "DENITRIFICATION",
                "7": "N2O_PRODUCTION_DENITRIF",
                "8": "N2O_EMISSION",
                "9": "VOLATILIZATION",
                "10": "PLANT_UPTAKE_NH4-N",
                "11": "PLANT_UPTAKE_NO3-N",
                "12": "IMMOBILIZATION",
                "13": "FIXATION"
            },
            "1": {
                "_NAME": "PON_HYDROLYSIS",
                "CONSUMED": "PON",
                "PRODUCED": "DON",
                "KINETICS": [
                    "k_hydrol * PON * 1.05^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_hydrol"
                ],
                "PARAMETER_VALUES": {
                    "k_hydrol": 0.1
                },
                "_PARAMETERS_INFO": {
                    "k_hydrol": {
                        "VALUE": 0.1,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.02,
                            0.5
                        ],
                        "DESCRIPTION": "PON hydrolysis to DON"
                    }
                }
            },
            "2": {
                "_NAME": "DON_MINERALIZATION",
                "CONSUMED": "DON",
                "PRODUCED": "NH4-N",
                "KINETICS": [
                    "k_min * DON * 1.08^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_min"
                ],
                "PARAMETER_VALUES": {
                    "k_min": 0.08
                },
                "_PARAMETERS_INFO": {
                    "k_min": {
                        "VALUE": 0.08,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.02,
                            0.3
                        ],
                        "DESCRIPTION": "DON mineralization to NH4-N"
                    }
                }
            },
            "3": {
                "_NAME": "NITRIFICATION_STEP1",
                "CONSUMED": "NH4-N",
                "PRODUCED": "NO2-N",
                "KINETICS": [
                    "k_nitrif1 * NH4-N * (DO / (K_O2_nitrif + DO)) * 1.08^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_nitrif1",
                    "K_O2_nitrif"
                ],
                "PARAMETER_VALUES": {
                    "k_nitrif1": 0.15,
                    "K_O2_nitrif": 0.5
                },
                "_PARAMETERS_INFO": {
                    "k_nitrif1": {
                        "VALUE": 0.15,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.05,
                            0.5
                        ],
                        "DESCRIPTION": "NH4-N to NO2-N rate (Nitrosomonas)"
                    },
                    "K_O2_nitrif": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L",
                        "RANGE": [
                            0.2,
                            2.0
                        ],
                        "DESCRIPTION": "Half-saturation O2 for nitrification"
                    }
                }
            },
            "4": {
                "_NAME": "NITRIFICATION_STEP2",
                "CONSUMED": "NO2-N",
                "PRODUCED": "NO3-N",
                "KINETICS": [
                    "k_nitrif2 * NO2-N * (DO / (K_O2_nitrif + DO)) * 1.08^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_nitrif2",
                    "K_O2_nitrif"
                ],
                "PARAMETER_VALUES": {
                    "k_nitrif2": 0.5,
                    "K_O2_nitrif": 0.5
                },
                "_NOTES": "Nitrobacter typically faster than Nitrosomonas, so NO2-N doesn't accumulate",
                "_PARAMETERS_INFO": {
                    "k_nitrif2": {
                        "VALUE": 0.5,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.2,
                            2.0
                        ],
                        "DESCRIPTION": "NO2-N to NO3-N rate (Nitrobacter)"
                    },
                    "K_O2_nitrif": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L"
                    }
                }
            },
            "5": {
                "_NAME": "NITRIFICATION_O2_DEMAND",
                "CONSUMED": "DO",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "4.57 * k_nitrif1 * NH4-N * (DO / (K_O2_nitrif + DO)) * 1.08^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_nitrif1",
                    "K_O2_nitrif"
                ],
                "PARAMETER_VALUES": {
                    "k_nitrif1": 0.15,
                    "K_O2_nitrif": 0.5
                },
                "_NOTES": "Stoichiometry: 4.57 mg O2 per mg NH4-N-N oxidized",
                "_PARAMETERS_INFO": {
                    "k_nitrif1": {
                        "VALUE": 0.15,
                        "UNITS": "1/day"
                    },
                    "K_O2_nitrif": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L"
                    }
                }
            },
            "6": {
                "_NAME": "DENITRIFICATION",
                "CONSUMED": "NO3-N",
                "PRODUCED": "N2_loss",
                "KINETICS": [
                    "k_denitrif * NO3-N * (K_O2_inhib / (K_O2_inhib + DO)) * 1.07^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_denitrif",
                    "K_O2_inhib"
                ],
                "PARAMETER_VALUES": {
                    "k_denitrif": 0.1,
                    "K_O2_inhib": 0.5
                },
                "_PARAMETERS_INFO": {
                    "k_denitrif": {
                        "VALUE": 0.1,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.01,
                            0.5
                        ],
                        "DESCRIPTION": "Denitrification rate (anaerobic)"
                    },
                    "K_O2_inhib": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L",
                        "RANGE": [
                            0.1,
                            1.0
                        ],
                        "DESCRIPTION": "O2 inhibition constant for denitrification"
                    }
                }
            },
            "7": {
                "_NAME": "N2O_PRODUCTION_DENITRIF",
                "CONSUMED": "NO3-N",
                "PRODUCED": "N2O",
                "KINETICS": [
                    "frac_nitrous * k_denitrif * NO3-N * (K_O2_inhib / (K_O2_inhib + DO)) * 1.07^(T - 20)",
                    "1"
                ],
                "PARAMETER_NAMES": [
                    "frac_nitrous",
                    "k_denitrif",
                    "K_O2_inhib"
                ],
                "PARAMETER_VALUES": {
                    "frac_nitrous": 0.05,
                    "k_denitrif": 0.1,
                    "K_O2_inhib": 0.5
                },
                "_PARAMETERS_INFO": {
                    "frac_nitrous": {
                        "VALUE": 0.05,
                        "UNITS": "fraction",
                        "RANGE": [
                            0.01,
                            0.2
                        ],
                        "DESCRIPTION": "Fraction of denitrification producing N2O"
                    },
                    "k_denitrif": {
                        "VALUE": 0.1,
                        "UNITS": "1/day"
                    },
                    "K_O2_inhib": {
                        "VALUE": 0.5,
                        "UNITS": "mg/L"
                    }
                }
            },
            "8": {
                "_NAME": "N2O_EMISSION",
                "CONSUMED": "N2O",
                "PRODUCED": "N2O_atm_loss",
                "KINETICS": [
                    "k_nitrous_emit * N2O",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_nitrous_emit"
                ],
                "PARAMETER_VALUES": {
                    "k_nitrous_emit": 1.0
                },
                "_PARAMETERS_INFO": {
                    "k_nitrous_emit": {
                        "VALUE": 1.0,
                        "UNITS": "1/day",
                        "DESCRIPTION": "N2O emission rate to atmosphere"
                    }
                }
            },
            "9": {
                "_NAME": "VOLATILIZATION",
                "CONSUMED": "NH4-N",
                "PRODUCED": "NH3_loss",
                "KINETICS": [
                    "k_vol * NH4-N * f_pH",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_vol",
                    "f_pH"
                ],
                "PARAMETER_VALUES": {
                    "k_vol": 0.01,
                    "f_pH": 0.1
                },
                "_NOTES": "Significant only at high pH (>8.5)",
                "_PARAMETERS_INFO": {
                    "k_vol": {
                        "VALUE": 0.01,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.0,
                            0.1
                        ],
                        "DESCRIPTION": "Ammonia volatilization rate"
                    },
                    "f_pH": {
                        "VALUE": 0.1,
                        "DESCRIPTION": "pH factor (increases with pH > 8)"
                    }
                }
            },
            "10": {
                "_NAME": "PLANT_UPTAKE_NH4-N",
                "CONSUMED": "NH4-N",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_uptake * NH4-N * (NH4-N / (NH4-N + NO3-N + 0.01)) * f_season * 1.05^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_uptake",
                    "f_season"
                ],
                "PARAMETER_VALUES": {
                    "k_uptake": 0.1,
                    "f_season": 1.0
                },
                "_PARAMETERS_INFO": {
                    "k_uptake": {
                        "VALUE": 0.1,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.0,
                            0.5
                        ],
                        "DESCRIPTION": "Plant N uptake rate"
                    },
                    "f_season": {
                        "VALUE": 1.0,
                        "RANGE": [
                            0.0,
                            1.0
                        ],
                        "DESCRIPTION": "Seasonal factor (0 winter, 1 peak growing season)"
                    }
                }
            },
            "11": {
                "_NAME": "PLANT_UPTAKE_NO3-N",
                "CONSUMED": "NO3-N",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_uptake * NO3-N * (NO3-N / (NH4-N + NO3-N + 0.01)) * f_season * 1.05^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_uptake",
                    "f_season"
                ],
                "PARAMETER_VALUES": {
                    "k_uptake": 0.1,
                    "f_season": 1.0
                },
                "_PARAMETERS_INFO": {
                    "k_uptake": {
                        "VALUE": 0.1,
                        "UNITS": "1/day"
                    },
                    "f_season": {
                        "VALUE": 1.0
                    }
                }
            },
            "12": {
                "_NAME": "IMMOBILIZATION",
                "CONSUMED": "NH4-N",
                "PRODUCED": "DON",
                "KINETICS": [
                    "k_immob * NH4-N * 1.05^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_immob"
                ],
                "PARAMETER_VALUES": {
                    "k_immob": 0.02
                },
                "_PARAMETERS_INFO": {
                    "k_immob": {
                        "VALUE": 0.02,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.001,
                            0.1
                        ],
                        "DESCRIPTION": "Microbial N immobilization"
                    }
                }
            },
            "13": {
                "_NAME": "FIXATION",
                "CONSUMED": "NONE",
                "PRODUCED": "DON",
                "KINETICS": [
                    "k_fix * 1.05^(T - 20)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_fix"
                ],
                "PARAMETER_VALUES": {
                    "k_fix": 0.01
                },
                "_NOTES": "Zero-order; significant in N-limited systems with cyanobacteria",
                "_PARAMETERS_INFO": {
                    "k_fix": {
                        "VALUE": 0.01,
                        "UNITS": "mg/L/day",
                        "RANGE": [
                            0.0,
                            0.1
                        ],
                        "DESCRIPTION": "Biological N fixation rate"
                    }
                }
            }
        }
    },
    "_COMPARTMENT_ASSIGNMENT": {
        "SOIL": [
            "FULL_N_CYCLE"
        ],
        "RIVER": [
            "FULL_N_CYCLE"
        ],
        "LAKE": [
            "FULL_N_CYCLE"
        ],
        "GROUNDWATER": [
            "FULL_N_CYCLE"
        ]
    }
}
