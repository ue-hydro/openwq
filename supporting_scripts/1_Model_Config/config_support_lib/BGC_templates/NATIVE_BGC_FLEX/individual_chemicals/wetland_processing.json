{
    "_DESCRIPTION": "Wetland Nutrient Processing Module for BMP Effectiveness Studies",
    "_REFERENCE": "Kadlec & Wallace (2009) Treatment Wetlands; Mitsch & Gosselink (2015)",
    "_VERSION": "1.0",
    "_PROCESSES": {
        "NITROGEN_REMOVAL": "Denitrification, plant uptake, sedimentation",
        "PHOSPHORUS_RETENTION": "Adsorption, precipitation, plant uptake",
        "TSS_REMOVAL": "Settling, filtration by vegetation",
        "PATHOGEN_REMOVAL": "UV exposure, die-off, predation",
        "ORGANIC_MATTER": "Production, decomposition, accretion"
    },
    "_NOTES": [
        "Wetlands are natural BMPs for nutrient removal",
        "N removal primarily via denitrification (permanent)",
        "P removal via sedimentation and sorption (may saturate)",
        "Performance depends on HRT, loading, vegetation, temperature",
        "First-order k-C* model common for design"
    ],
    "MODULE_NAME": "NATIVE_BGC_FLEX",
    "CHEMICAL_SPECIES": {
        "LIST": {
            "1": "NO3-N",
            "2": "NH4-N",
            "3": "N_ORG",
            "4": "N2_gas",
            "5": "PO4-P",
            "6": "P_ORG",
            "7": "P_SED",
            "8": "TSS",
            "9": "BOD",
            "10": "DO",
            "11": "PATHOGEN",
            "12": "DOC",
            "13": "PLANT_N",
            "14": "PLANT_P"
        },
        "BGC_GENERAL_MOBILE_SPECIES": [
            "NO3-N",
            "NH4-N",
            "N_ORG",
            "PO4-P",
            "P_ORG",
            "TSS",
            "BOD",
            "DO",
            "PATHOGEN",
            "DOC"
        ],
        "_LIST_DESCRIPTIONS": {
            "NO3-N": "Nitrate nitrogen",
            "NH4-N": "Ammonium nitrogen",
            "N_ORG": "Organic nitrogen (dissolved + particulate)",
            "N2_gas": "Dissolved dinitrogen gas",
            "PO4-P": "Dissolved reactive phosphorus (orthophosphate)",
            "P_ORG": "Organic phosphorus",
            "P_SED": "Sediment-bound phosphorus",
            "TSS": "Total suspended solids",
            "BOD": "Biochemical oxygen demand",
            "DO": "Dissolved oxygen",
            "PATHOGEN": "Pathogen indicator organisms",
            "DOC": "Dissolved organic carbon",
            "PLANT_N": "Plant nitrogen pool",
            "PLANT_P": "Plant phosphorus pool"
        }
    },
    "CYCLING_FRAMEWORKS": {
        "NITROGEN_WETLAND": {
            "_description": "Wetland nitrogen cycling and removal",
            "_notes": [
                "Denitrification is main N removal pathway (permanent)",
                "Plant uptake is temporary storage (released at senescence)",
                "Typical removal rates: 200-2000 kg N/ha/yr"
            ],
            "LIST_TRANSFORMATIONS": {
                "1": "denitrification_wetland",
                "2": "nitrification_wetland",
                "3": "n_plant_uptake",
                "4": "n_sedimentation",
                "5": "n_mineralization",
                "6": "n_plant_senescence"
            },
            "1": {
                "_name": "denitrification_wetland",
                "_description": "Microbial denitrification in anoxic zones",
                "_reaction": "NO3-N + C -> N2 (gas loss)",
                "_notes": "Primary permanent N removal mechanism",
                "CONSUMED": "NO3-N",
                "PRODUCED": "N2_gas",
                "KINETICS": [
                    "k_denit_wet * NO3-N * (DOC / (Ks_C + DOC)) * (Ks_O2 / (Ks_O2 + DO)) * theta^(Treach_K - 293)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_denit_wet",
                    "Ks_C",
                    "Ks_O2",
                    "theta"
                ],
                "PARAMETER_VALUES": {
                    "k_denit_wet": 0.3,
                    "Ks_C": 5.0,
                    "Ks_O2": 0.5,
                    "theta": 1.08
                },
                "_parameter_ranges": {
                    "k_denit_wet": {
                        "min": 0.1,
                        "max": 1.0,
                        "units": "1/day",
                        "source": "Kadlec & Wallace 2009"
                    }
                }
            },
            "2": {
                "_name": "nitrification_wetland",
                "_description": "NH4-N oxidation in aerobic zones",
                "_reaction": "NH4-N + 2O2 -> NO3-N",
                "CONSUMED": "NH4-N",
                "PRODUCED": "NO3-N",
                "KINETICS": [
                    "k_nitrif_wet * NH4-N * (DO / (Ks_O2 + DO)) * theta^(Treach_K - 293)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_nitrif_wet",
                    "Ks_O2",
                    "theta"
                ],
                "PARAMETER_VALUES": {
                    "k_nitrif_wet": 0.2,
                    "Ks_O2": 1.0,
                    "theta": 1.08
                }
            },
            "3": {
                "_name": "n_plant_uptake",
                "_description": "Nitrogen uptake by emergent vegetation",
                "_notes": "Typha, Phragmites, Scirpus uptake 200-300 kg N/ha/yr",
                "CONSUMED": "NO3-N",
                "PRODUCED": "PLANT_N",
                "KINETICS": [
                    "k_uptake_N * (NO3-N + NH4-N) / (Ks_N + NO3-N + NH4-N) * f_veg * f_season",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_uptake_N",
                    "Ks_N",
                    "f_veg",
                    "f_season"
                ],
                "PARAMETER_VALUES": {
                    "k_uptake_N": 0.1,
                    "Ks_N": 0.5,
                    "f_veg": 1.0,
                    "f_season": 1.0
                }
            },
            "4": {
                "_name": "n_sedimentation",
                "_description": "Particulate organic N settling",
                "CONSUMED": "N_ORG",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "v_settle * N_ORG / depth",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "v_settle",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "v_settle": 0.5,
                    "depth": 0.5
                }
            },
            "5": {
                "_name": "n_mineralization",
                "_description": "Organic N mineralization to NH4-N",
                "CONSUMED": "N_ORG",
                "PRODUCED": "NH4-N",
                "KINETICS": [
                    "k_min_N * N_ORG * theta^(Treach_K - 293)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_min_N",
                    "theta"
                ],
                "PARAMETER_VALUES": {
                    "k_min_N": 0.05,
                    "theta": 1.07
                }
            },
            "6": {
                "_name": "n_plant_senescence",
                "_description": "N release from senescing vegetation",
                "_notes": "Late season return of N to system",
                "CONSUMED": "PLANT_N",
                "PRODUCED": "N_ORG",
                "KINETICS": [
                    "k_senes * PLANT_N * f_senescence",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_senes",
                    "f_senescence"
                ],
                "PARAMETER_VALUES": {
                    "k_senes": 0.01,
                    "f_senescence": 0.0
                }
            }
        },
        "PHOSPHORUS_WETLAND": {
            "_description": "Wetland phosphorus cycling and retention",
            "_notes": [
                "P removal via sedimentation, sorption, and plant uptake",
                "Sorption capacity may saturate over time",
                "Typical removal: 5-50 kg P/ha/yr"
            ],
            "LIST_TRANSFORMATIONS": {
                "1": "p_sedimentation",
                "2": "p_sorption",
                "3": "p_plant_uptake",
                "4": "p_desorption",
                "5": "p_mineralization"
            },
            "1": {
                "_name": "p_sedimentation",
                "_description": "Particulate P settling",
                "CONSUMED": "P_ORG",
                "PRODUCED": "P_SED",
                "KINETICS": [
                    "v_settle_P * P_ORG / depth",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "v_settle_P",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "v_settle_P": 0.3,
                    "depth": 0.5
                }
            },
            "2": {
                "_name": "p_sorption",
                "_description": "PO4-P adsorption to sediments and Fe/Al oxides",
                "_notes": "Langmuir isotherm - finite capacity",
                "CONSUMED": "PO4-P",
                "PRODUCED": "P_SED",
                "KINETICS": [
                    "k_sorp_P * PO4-P * (1 - P_SED / Smax_P)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_sorp_P",
                    "Smax_P"
                ],
                "PARAMETER_VALUES": {
                    "k_sorp_P": 0.2,
                    "Smax_P": 100
                },
                "_parameter_ranges": {
                    "Smax_P": {
                        "min": 10,
                        "max": 500,
                        "units": "mg-P/L equiv",
                        "source": "Depends on soil type"
                    }
                }
            },
            "3": {
                "_name": "p_plant_uptake",
                "_description": "P uptake by wetland vegetation",
                "CONSUMED": "PO4-P",
                "PRODUCED": "PLANT_P",
                "KINETICS": [
                    "k_uptake_P * PO4-P / (Ks_P + PO4-P) * f_veg * f_season",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_uptake_P",
                    "Ks_P",
                    "f_veg",
                    "f_season"
                ],
                "PARAMETER_VALUES": {
                    "k_uptake_P": 0.05,
                    "Ks_P": 0.1,
                    "f_veg": 1.0,
                    "f_season": 1.0
                }
            },
            "4": {
                "_name": "p_desorption",
                "_description": "P release from saturated sediments",
                "_notes": "Can occur under anoxic conditions or high loading",
                "CONSUMED": "P_SED",
                "PRODUCED": "PO4-P",
                "KINETICS": [
                    "k_desorp * P_SED * (Ks_O2 / (Ks_O2 + DO))",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_desorp",
                    "Ks_O2"
                ],
                "PARAMETER_VALUES": {
                    "k_desorp": 0.01,
                    "Ks_O2": 0.5
                }
            },
            "5": {
                "_name": "p_mineralization",
                "_description": "Organic P mineralization",
                "CONSUMED": "P_ORG",
                "PRODUCED": "PO4-P",
                "KINETICS": [
                    "k_min_P * P_ORG * theta^(Treach_K - 293)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_min_P",
                    "theta"
                ],
                "PARAMETER_VALUES": {
                    "k_min_P": 0.03,
                    "theta": 1.07
                }
            }
        },
        "TSS_REMOVAL": {
            "_description": "Suspended solids removal in wetlands",
            "_notes": "Filtration by vegetation and settling are main mechanisms",
            "LIST_TRANSFORMATIONS": {
                "1": "tss_settling",
                "2": "tss_filtration",
                "3": "tss_resuspension"
            },
            "1": {
                "_name": "tss_settling",
                "_description": "Gravitational settling of suspended solids",
                "CONSUMED": "TSS",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "v_settle_tss * TSS / depth",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "v_settle_tss",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "v_settle_tss": 1.0,
                    "depth": 0.5
                }
            },
            "2": {
                "_name": "tss_filtration",
                "_description": "Filtration by emergent vegetation stems",
                "CONSUMED": "TSS",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_filt * TSS * f_veg_density",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_filt",
                    "f_veg_density"
                ],
                "PARAMETER_VALUES": {
                    "k_filt": 0.3,
                    "f_veg_density": 1.0
                }
            },
            "3": {
                "_name": "tss_resuspension",
                "_description": "Wind-driven or bioturbation resuspension",
                "CONSUMED": "NONE",
                "PRODUCED": "TSS",
                "KINETICS": [
                    "k_resusp * TSS_SED * f_wind",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_resusp",
                    "f_wind"
                ],
                "PARAMETER_VALUES": {
                    "k_resusp": 0.01,
                    "f_wind": 0.0
                }
            }
        },
        "BOD_WETLAND": {
            "_description": "BOD removal in treatment wetlands",
            "LIST_TRANSFORMATIONS": {
                "1": "bod_decay",
                "2": "bod_settling"
            },
            "1": {
                "_name": "bod_decay",
                "_description": "Microbial BOD decomposition",
                "CONSUMED": "BOD",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_bod * BOD * (DO / (Ks_O2 + DO)) * theta^(Treach_K - 293)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_bod",
                    "Ks_O2",
                    "theta"
                ],
                "PARAMETER_VALUES": {
                    "k_bod": 0.2,
                    "Ks_O2": 0.5,
                    "theta": 1.06
                }
            },
            "2": {
                "_name": "bod_settling",
                "_description": "Particulate BOD settling",
                "CONSUMED": "BOD",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "f_part * v_settle * BOD / depth",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "f_part",
                    "v_settle",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "f_part": 0.4,
                    "v_settle": 0.5,
                    "depth": 0.5
                }
            }
        },
        "PATHOGEN_WETLAND": {
            "_description": "Pathogen removal in wetlands",
            "_notes": "UV exposure, sedimentation, predation, die-off",
            "LIST_TRANSFORMATIONS": {
                "1": "pathogen_dieoff",
                "2": "pathogen_uv",
                "3": "pathogen_settling"
            },
            "1": {
                "_name": "pathogen_dieoff",
                "_description": "Natural pathogen die-off",
                "CONSUMED": "PATHOGEN",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_dieoff * PATHOGEN * theta^(Treach_K - 293)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_dieoff",
                    "theta"
                ],
                "PARAMETER_VALUES": {
                    "k_dieoff": 0.5,
                    "theta": 1.07
                }
            },
            "2": {
                "_name": "pathogen_uv",
                "_description": "UV inactivation of pathogens",
                "CONSUMED": "PATHOGEN",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_uv * PATHOGEN * (SWrad_Wm2 / 500) * f_depth",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_uv",
                    "f_depth"
                ],
                "PARAMETER_VALUES": {
                    "k_uv": 1.0,
                    "f_depth": 0.3
                }
            },
            "3": {
                "_name": "pathogen_settling",
                "_description": "Pathogen attachment to particles and settling",
                "CONSUMED": "PATHOGEN",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_attach * PATHOGEN * TSS * v_settle / depth",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_attach",
                    "v_settle",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "k_attach": 0.001,
                    "v_settle": 0.5,
                    "depth": 0.5
                }
            }
        },
        "KC_STAR_MODEL": {
            "_description": "First-order k-C* model for wetland design",
            "_reference": "Kadlec & Knight (1996); Kadlec & Wallace (2009)",
            "_notes": [
                "Cout = C* + (Cin - C*) * exp(-k * HRT)",
                "C* = background concentration (irreducible)",
                "k = first-order rate constant (m/day)",
                "HRT = hydraulic retention time (days)"
            ],
            "LIST_TRANSFORMATIONS": {
                "1": "generic_removal"
            },
            "1": {
                "_name": "generic_removal",
                "_description": "Generic first-order removal with background",
                "CONSUMED": "NONE",
                "PRODUCED": "NONE",
                "KINETICS": [
                    "k_removal * (POLLUTANT - C_star)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_removal",
                    "C_star"
                ],
                "PARAMETER_VALUES": {
                    "k_removal": 0.1,
                    "C_star": 0.5
                },
                "_notes": "Adjust k_removal and C_star for specific pollutants"
            }
        }
    }
}