{
    "_DESCRIPTION": "Heavy Metals Cycling - Cu, Zn, Pb, Cd, Hg with sorption and speciation",
    "_REFERENCE": "WASP TOXI, Stumm & Morgan (1996)",
    "_VERSION": "1.0",
    "CHEMICAL_SPECIES": {
        "LIST": {
            "1": "Cu_diss",
            "2": "Cu_part",
            "3": "Zn_diss",
            "4": "Zn_part",
            "5": "Pb_diss",
            "6": "Pb_part",
            "7": "Cd_diss",
            "8": "Cd_part",
            "9": "Hg_diss",
            "10": "Hg_part",
            "11": "MeHg",
            "12": "TSS",
            "13": "DOC",
            "14": "Hg0_loss",
            "15": "SED_Cd_loss",
            "16": "SED_Cu_loss",
            "17": "SED_Hg_loss",
            "18": "SED_Pb_loss",
            "19": "SED_Zn_loss"
        },
        "BGC_GENERAL_MOBILE_SPECIES": [
            "Cu_diss",
            "Cu_part",
            "Zn_diss",
            "Zn_part",
            "Pb_diss",
            "Pb_part",
            "Cd_diss",
            "Cd_part",
            "Hg_diss",
            "Hg_part",
            "MeHg",
            "TSS",
            "DOC"
        ],
        "_LIST_DESCRIPTIONS": {
            "Cu_diss": "Dissolved copper",
            "Cu_part": "Particulate copper",
            "Zn_diss": "Dissolved zinc",
            "Zn_part": "Particulate zinc",
            "Pb_diss": "Dissolved lead",
            "Pb_part": "Particulate lead",
            "Cd_diss": "Dissolved cadmium",
            "Cd_part": "Particulate cadmium",
            "Hg_diss": "Dissolved inorganic mercury",
            "Hg_part": "Particulate mercury",
            "MeHg": "Methylmercury",
            "TSS": "Total suspended solids",
            "DOC": "Dissolved organic carbon (complexation)",
            "Hg0_loss": "Hg0 loss to atmosphere/sediment",
            "SED_Cd_loss": "SED loss to atmosphere/sediment",
            "SED_Cu_loss": "SED loss to atmosphere/sediment",
            "SED_Hg_loss": "SED loss to atmosphere/sediment",
            "SED_Pb_loss": "SED loss to atmosphere/sediment",
            "SED_Zn_loss": "SED loss to atmosphere/sediment"
        }
    },
    "CYCLING_FRAMEWORKS": {
        "COPPER_CYCLE": {
            "_DESCRIPTION": "Copper partitioning and transport",
            "LIST_TRANSFORMATIONS": {
                "1": "CU_SORPTION",
                "2": "CU_DESORPTION",
                "3": "CU_SETTLING"
            },
            "1": {
                "_NAME": "CU_SORPTION",
                "CONSUMED": "Cu_diss",
                "PRODUCED": "Cu_part",
                "KINETICS": [
                    "k_ads_Cu * Cu_diss * TSS / 1000",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_ads_Cu"
                ],
                "PARAMETER_VALUES": {
                    "k_ads_Cu": 1.0
                },
                "_PARAMETERS_INFO": {
                    "k_ads_Cu": {
                        "VALUE": 1.0,
                        "UNITS": "L/mg/day",
                        "RANGE": [
                            0.1,
                            10.0
                        ],
                        "DESCRIPTION": "Cu adsorption rate"
                    }
                }
            },
            "2": {
                "_NAME": "CU_DESORPTION",
                "CONSUMED": "Cu_part",
                "PRODUCED": "Cu_diss",
                "KINETICS": [
                    "k_des_Cu * Cu_part",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_des_Cu"
                ],
                "PARAMETER_VALUES": {
                    "k_des_Cu": 0.1
                },
                "_PARAMETERS_INFO": {
                    "k_des_Cu": {
                        "VALUE": 0.1,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.01,
                            1.0
                        ],
                        "DESCRIPTION": "Cu desorption rate"
                    }
                }
            },
            "3": {
                "_NAME": "CU_SETTLING",
                "CONSUMED": "Cu_part",
                "PRODUCED": "SED_Cu_loss",
                "KINETICS": [
                    "v_s / depth * Cu_part",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "v_s",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "v_s": 1.0,
                    "depth": 2.0
                },
                "_PARAMETERS_INFO": {
                    "v_s": {
                        "VALUE": 1.0,
                        "UNITS": "m/day"
                    },
                    "depth": {
                        "VALUE": 2.0,
                        "UNITS": "m"
                    }
                }
            }
        },
        "ZINC_CYCLE": {
            "_DESCRIPTION": "Zinc partitioning",
            "LIST_TRANSFORMATIONS": {
                "1": "ZN_SORPTION",
                "2": "ZN_DESORPTION",
                "3": "ZN_SETTLING"
            },
            "1": {
                "_NAME": "ZN_SORPTION",
                "CONSUMED": "Zn_diss",
                "PRODUCED": "Zn_part",
                "KINETICS": [
                    "k_ads_Zn * Zn_diss * TSS / 1000",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_ads_Zn"
                ],
                "PARAMETER_VALUES": {
                    "k_ads_Zn": 0.5
                },
                "_PARAMETERS_INFO": {
                    "k_ads_Zn": {
                        "VALUE": 0.5,
                        "UNITS": "L/mg/day",
                        "RANGE": [
                            0.05,
                            5.0
                        ],
                        "DESCRIPTION": "Zn adsorption rate (lower affinity than Cu)"
                    }
                }
            },
            "2": {
                "_NAME": "ZN_DESORPTION",
                "CONSUMED": "Zn_part",
                "PRODUCED": "Zn_diss",
                "KINETICS": [
                    "k_des_Zn * Zn_part",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_des_Zn"
                ],
                "PARAMETER_VALUES": {
                    "k_des_Zn": 0.2
                },
                "_PARAMETERS_INFO": {
                    "k_des_Zn": {
                        "VALUE": 0.2,
                        "UNITS": "1/day"
                    }
                }
            },
            "3": {
                "_NAME": "ZN_SETTLING",
                "CONSUMED": "Zn_part",
                "PRODUCED": "SED_Zn_loss",
                "KINETICS": [
                    "v_s / depth * Zn_part",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "v_s",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "v_s": 1.0,
                    "depth": 2.0
                },
                "_PARAMETERS_INFO": {
                    "v_s": {
                        "VALUE": 1.0,
                        "UNITS": "m/day"
                    },
                    "depth": {
                        "VALUE": 2.0,
                        "UNITS": "m"
                    }
                }
            }
        },
        "LEAD_CYCLE": {
            "_DESCRIPTION": "Lead partitioning (strongly sorbed)",
            "LIST_TRANSFORMATIONS": {
                "1": "PB_SORPTION",
                "2": "PB_DESORPTION",
                "3": "PB_SETTLING"
            },
            "1": {
                "_NAME": "PB_SORPTION",
                "CONSUMED": "Pb_diss",
                "PRODUCED": "Pb_part",
                "KINETICS": [
                    "k_ads_Pb * Pb_diss * TSS / 1000",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_ads_Pb"
                ],
                "PARAMETER_VALUES": {
                    "k_ads_Pb": 5.0
                },
                "_PARAMETERS_INFO": {
                    "k_ads_Pb": {
                        "VALUE": 5.0,
                        "UNITS": "L/mg/day",
                        "RANGE": [
                            1.0,
                            20.0
                        ],
                        "DESCRIPTION": "Pb adsorption rate (high affinity)"
                    }
                }
            },
            "2": {
                "_NAME": "PB_DESORPTION",
                "CONSUMED": "Pb_part",
                "PRODUCED": "Pb_diss",
                "KINETICS": [
                    "k_des_Pb * Pb_part",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_des_Pb"
                ],
                "PARAMETER_VALUES": {
                    "k_des_Pb": 0.02
                },
                "_PARAMETERS_INFO": {
                    "k_des_Pb": {
                        "VALUE": 0.02,
                        "UNITS": "1/day",
                        "DESCRIPTION": "Pb desorption (very slow)"
                    }
                }
            },
            "3": {
                "_NAME": "PB_SETTLING",
                "CONSUMED": "Pb_part",
                "PRODUCED": "SED_Pb_loss",
                "KINETICS": [
                    "v_s / depth * Pb_part",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "v_s",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "v_s": 1.0,
                    "depth": 2.0
                },
                "_PARAMETERS_INFO": {
                    "v_s": {
                        "VALUE": 1.0,
                        "UNITS": "m/day"
                    },
                    "depth": {
                        "VALUE": 2.0,
                        "UNITS": "m"
                    }
                }
            }
        },
        "CADMIUM_CYCLE": {
            "_DESCRIPTION": "Cadmium partitioning",
            "LIST_TRANSFORMATIONS": {
                "1": "CD_SORPTION",
                "2": "CD_DESORPTION",
                "3": "CD_SETTLING"
            },
            "1": {
                "_NAME": "CD_SORPTION",
                "CONSUMED": "Cd_diss",
                "PRODUCED": "Cd_part",
                "KINETICS": [
                    "k_ads_Cd * Cd_diss * TSS / 1000",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_ads_Cd"
                ],
                "PARAMETER_VALUES": {
                    "k_ads_Cd": 0.8
                },
                "_PARAMETERS_INFO": {
                    "k_ads_Cd": {
                        "VALUE": 0.8,
                        "UNITS": "L/mg/day",
                        "RANGE": [
                            0.1,
                            5.0
                        ],
                        "DESCRIPTION": "Cd adsorption rate"
                    }
                }
            },
            "2": {
                "_NAME": "CD_DESORPTION",
                "CONSUMED": "Cd_part",
                "PRODUCED": "Cd_diss",
                "KINETICS": [
                    "k_des_Cd * Cd_part",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_des_Cd"
                ],
                "PARAMETER_VALUES": {
                    "k_des_Cd": 0.15
                },
                "_PARAMETERS_INFO": {
                    "k_des_Cd": {
                        "VALUE": 0.15,
                        "UNITS": "1/day"
                    }
                }
            },
            "3": {
                "_NAME": "CD_SETTLING",
                "CONSUMED": "Cd_part",
                "PRODUCED": "SED_Cd_loss",
                "KINETICS": [
                    "v_s / depth * Cd_part",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "v_s",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "v_s": 1.0,
                    "depth": 2.0
                },
                "_PARAMETERS_INFO": {
                    "v_s": {
                        "VALUE": 1.0,
                        "UNITS": "m/day"
                    },
                    "depth": {
                        "VALUE": 2.0,
                        "UNITS": "m"
                    }
                }
            }
        },
        "MERCURY_CYCLE": {
            "_DESCRIPTION": "Mercury cycling with methylation",
            "LIST_TRANSFORMATIONS": {
                "1": "HG_SORPTION",
                "2": "HG_DESORPTION",
                "3": "HG_METHYLATION",
                "4": "MEHG_DEMETHYLATION",
                "5": "HG_VOLATILIZATION",
                "6": "HG_SETTLING"
            },
            "1": {
                "_NAME": "HG_SORPTION",
                "CONSUMED": "Hg_diss",
                "PRODUCED": "Hg_part",
                "KINETICS": [
                    "k_ads_Hg * Hg_diss * TSS / 1000",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_ads_Hg"
                ],
                "PARAMETER_VALUES": {
                    "k_ads_Hg": 2.0
                },
                "_PARAMETERS_INFO": {
                    "k_ads_Hg": {
                        "VALUE": 2.0,
                        "UNITS": "L/mg/day",
                        "DESCRIPTION": "Hg adsorption rate"
                    }
                }
            },
            "2": {
                "_NAME": "HG_DESORPTION",
                "CONSUMED": "Hg_part",
                "PRODUCED": "Hg_diss",
                "KINETICS": [
                    "k_des_Hg * Hg_part",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_des_Hg"
                ],
                "PARAMETER_VALUES": {
                    "k_des_Hg": 0.05
                },
                "_PARAMETERS_INFO": {
                    "k_des_Hg": {
                        "VALUE": 0.05,
                        "UNITS": "1/day"
                    }
                }
            },
            "3": {
                "_NAME": "HG_METHYLATION",
                "CONSUMED": "Hg_diss",
                "PRODUCED": "MeHg",
                "KINETICS": [
                    "k_meth_Hg * Hg_diss * DOC / (K_doc + DOC)",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_meth_Hg",
                    "K_doc"
                ],
                "PARAMETER_VALUES": {
                    "k_meth_Hg": 0.01,
                    "K_doc": 2.0
                },
                "_NOTES": "Methylation enhanced by DOC and anoxia",
                "_PARAMETERS_INFO": {
                    "k_meth_Hg": {
                        "VALUE": 0.01,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.001,
                            0.1
                        ],
                        "DESCRIPTION": "Mercury methylation rate"
                    },
                    "K_doc": {
                        "VALUE": 2.0,
                        "UNITS": "mg/L",
                        "DESCRIPTION": "DOC half-saturation for methylation"
                    }
                }
            },
            "4": {
                "_NAME": "MEHG_DEMETHYLATION",
                "CONSUMED": "MeHg",
                "PRODUCED": "Hg_diss",
                "KINETICS": [
                    "k_demeth * MeHg",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_demeth"
                ],
                "PARAMETER_VALUES": {
                    "k_demeth": 0.05
                },
                "_PARAMETERS_INFO": {
                    "k_demeth": {
                        "VALUE": 0.05,
                        "UNITS": "1/day",
                        "RANGE": [
                            0.01,
                            0.2
                        ],
                        "DESCRIPTION": "MeHg demethylation rate"
                    }
                }
            },
            "5": {
                "_NAME": "HG_VOLATILIZATION",
                "CONSUMED": "Hg_diss",
                "PRODUCED": "Hg0_loss",
                "KINETICS": [
                    "k_vol_Hg * Hg_diss",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "k_vol_Hg"
                ],
                "PARAMETER_VALUES": {
                    "k_vol_Hg": 0.001
                },
                "_NOTES": "Reduction to Hg0 and volatilization",
                "_PARAMETERS_INFO": {
                    "k_vol_Hg": {
                        "VALUE": 0.001,
                        "UNITS": "1/day",
                        "DESCRIPTION": "Hg0 evasion rate"
                    }
                }
            },
            "6": {
                "_NAME": "HG_SETTLING",
                "CONSUMED": "Hg_part",
                "PRODUCED": "SED_Hg_loss",
                "KINETICS": [
                    "v_s / depth * Hg_part",
                    "1/day"
                ],
                "PARAMETER_NAMES": [
                    "v_s",
                    "depth"
                ],
                "PARAMETER_VALUES": {
                    "v_s": 1.0,
                    "depth": 2.0
                },
                "_PARAMETERS_INFO": {
                    "v_s": {
                        "VALUE": 1.0,
                        "UNITS": "m/day"
                    },
                    "depth": {
                        "VALUE": 2.0,
                        "UNITS": "m"
                    }
                }
            }
        },
        "KD_PARTITIONING": {
            "_DESCRIPTION": "Alternative equilibrium partitioning approach",
            "_NOTES": "Use Kd values instead of kinetic rates for fast equilibration",
            "_FORMULA": "f_part = Kd * TSS / (1 + Kd * TSS); f_diss = 1 - f_part",
            "LIST_TRANSFORMATIONS": {},
            "_EQUILIBRIUM_FORMULAS_INFO": {
                "Cu_Kd": {
                    "VALUE": 50000,
                    "UNITS": "L/kg",
                    "DESCRIPTION": "Cu distribution coefficient"
                },
                "Zn_Kd": {
                    "VALUE": 30000,
                    "UNITS": "L/kg",
                    "DESCRIPTION": "Zn distribution coefficient"
                },
                "Pb_Kd": {
                    "VALUE": 200000,
                    "UNITS": "L/kg",
                    "DESCRIPTION": "Pb distribution coefficient (strongly sorbed)"
                },
                "Cd_Kd": {
                    "VALUE": 40000,
                    "UNITS": "L/kg",
                    "DESCRIPTION": "Cd distribution coefficient"
                },
                "Hg_Kd": {
                    "VALUE": 100000,
                    "UNITS": "L/kg",
                    "DESCRIPTION": "Hg distribution coefficient"
                }
            }
        }
    },
    "_COMPARTMENT_ASSIGNMENT": {
        "RIVER": [
            "COPPER_CYCLE",
            "ZINC_CYCLE",
            "LEAD_CYCLE",
            "CADMIUM_CYCLE",
            "MERCURY_CYCLE"
        ],
        "LAKE": [
            "COPPER_CYCLE",
            "ZINC_CYCLE",
            "LEAD_CYCLE",
            "CADMIUM_CYCLE",
            "MERCURY_CYCLE"
        ],
        "SEDIMENT": [
            "COPPER_CYCLE",
            "ZINC_CYCLE",
            "LEAD_CYCLE",
            "CADMIUM_CYCLE",
            "MERCURY_CYCLE"
        ]
    }
}
